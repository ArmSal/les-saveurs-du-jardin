# 🌿 PORTAIL LSDJ - CONFIGURATION DES VARIABLES D'ENVIRONNEMENT
# --------------------------------------------------------------------------------
# Ce fichier définit les valeurs par défaut pour l'application.
# Pour vos réglages personnels (mots de passe, accès locaux), créez ou modifiez le fichier .env.local
# --------------------------------------------------------------------------------

###> symfony/framework-bundle ###
# APP_ENV: 'dev', 'test' ou 'prod'
APP_ENV=dev

# APP_SECRET: Placeholder pour Git. La vraie clé doit être dans .env.local
# SECURITY WARNING: DO NOT USE THIS SECRET IN PRODUCTION
APP_SECRET=place_your_secret_here_in_dot_env_local
###< symfony/framework-bundle ###

###> symfony/routing ###
DEFAULT_URI=http://localhost
###< symfony/routing ###

###> doctrine/doctrine-bundle ###
# Configuration par défaut pour l'infrastructure Docker (compose.yaml)
DATABASE_URL="mysql://app:app@db:3306/lsj_db?serverVersion=8.0&charset=utf8mb4"
###< doctrine/doctrine-bundle ###

###> symfony/mailer ###
MAILER_DSN=null://null
###< symfony/mailer ###
