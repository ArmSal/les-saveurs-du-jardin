{% extends 'base.html.twig' %}

{% block title %}403 - Accès Refusé | Plateforme LSDJ{% endblock %}

{% block body %}
<div class="error-container">
    <div class="grid-overlay"></div>
    <div class="glow-sphere danger"></div>
    
    <div class="error-card">
        <div class="error-content">
            <div class="error-icon">
                <svg width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path d="M12 15v2m0-8v4m8.857-2.357a10 10 0 11-14.142 0 10 10 0 0114.142 0z" stroke-linecap="round" stroke-linejoin="round"></path>
                </svg>
            </div>
            
            <div class="glitch-wrapper">
                <div class="glitch" data-text="403">403</div>
            </div>
            
            <div class="divider"></div>
            
            <h2>SÉCURITÉ : ACCÈS REFUSÉ</h2>
            <p>Vos protocoles d'accès ne sont pas autorisés à franchir cette passerelle de données.</p>
            
            <div class="controls">
                <button onclick="window.history.back()" class="cyber-btn secondary">
                    <span class="btn-label">RETOUR</span>
                </button>
                <a href="{{ path('app_home') }}" class="cyber-btn danger">
                    <span class="btn-label">ACCUEIL</span>
                </a>
            </div>
        </div>
    </div>
</div>

<style>
    :root {
        --neon-red: #ff0055;
        --neon-purple: #9d50bb;
        --dark-bg: #0b0e14;
        --glass-bg: rgba(255, 255, 255, 0.03);
        --glass-border: rgba(255, 255, 255, 0.1);
    }

    .error-container {
        min-height: calc(100vh - 100px);
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--dark-bg);
        position: relative;
        overflow: hidden;
        font-family: 'Outfit', sans-serif;
        color: #fff;
    }

    .grid-overlay {
        position: absolute;
        width: 200%;
        height: 200%;
        background-image: 
            linear-gradient(to right, rgba(255,0,85, 0.05) 1px, transparent 1px),
            linear-gradient(to bottom, rgba(255,0,85, 0.05) 1px, transparent 1px);
        background-size: 50px 50px;
        transform: perspective(500px) rotateX(60deg) translateY(-50%);
        animation: gridMove 20s linear infinite;
        z-index: 0;
    }

    @keyframes gridMove {
        from { background-position: 0 0; }
        to { background-position: 0 500px; }
    }

    .glow-sphere.danger {
        position: absolute;
        width: 600px;
        height: 600px;
        background: radial-gradient(circle, rgba(255, 0, 85, 0.15) 0%, rgba(157, 80, 187, 0.05) 50%, rgba(0,0,0,0) 70%);
        filter: blur(80px);
        animation: pulseGlow 8s ease-in-out infinite alternate;
        z-index: 1;
    }

    @keyframes pulseGlow {
        from { transform: translate(-10%, -10%) scale(1); }
        to { transform: translate(10%, 10%) scale(1.3); }
    }

    .error-card {
        background: var(--glass-bg);
        backdrop-filter: blur(25px);
        border: 1px solid var(--glass-border);
        padding: 60px;
        border-radius: 32px;
        position: relative;
        max-width: 500px;
        width: 90%;
        text-align: center;
        box-shadow: 0 40px 100px rgba(0,0,0,0.6);
        z-index: 2;
    }

    .error-icon {
        color: var(--neon-red);
        margin-bottom: 20px;
        filter: drop-shadow(0 0 10px var(--neon-red));
        animation: flicker 3s infinite;
    }

    @keyframes flicker {
        0%, 19.999%, 22%, 62.999%, 64%, 64.999%, 70%, 100% { opacity: 1; }
        20%, 21.999%, 63%, 63.999%, 65%, 69.999% { opacity: 0.4; }
    }

    .glitch {
        font-size: 10rem;
        font-weight: 900;
        position: relative;
        text-shadow: 0.05em 0 0 rgba(255,0,85,0.75),
                    -0.025em -0.05em 0 rgba(157, 80, 187,0.75);
        animation: glitch 1s infinite;
        margin-bottom: 20px;
        letter-spacing: -5px;
        color: #fff;
    }

    @keyframes glitch {
        0% { transform: translate(0); }
        20% { transform: translate(-2px, 2px); }
        40% { transform: translate(-2px, -2px); }
        60% { transform: translate(2px, 2px); }
        80% { transform: translate(2px, -2px); }
        100% { transform: translate(0); }
    }

    .divider {
        height: 1px;
        background: linear-gradient(90deg, transparent, var(--neon-red), transparent);
        margin: 30px 0;
        opacity: 0.3;
    }

    h2 {
        font-size: 1rem;
        text-transform: uppercase;
        letter-spacing: 5px;
        margin-bottom: 15px;
        color: var(--neon-red);
        font-weight: 700;
    }

    p {
        font-size: 1.1rem;
        line-height: 1.6;
        color: rgba(255, 255, 255, 0.7);
        margin-bottom: 40px;
    }

    .controls {
        display: flex;
        gap: 20px;
        justify-content: center;
    }

    .cyber-btn {
        position: relative;
        padding: 15px 35px;
        background: transparent;
        color: #fff;
        border: none;
        cursor: pointer;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 2px;
        font-size: 0.8rem;
        transition: all 0.3s;
        text-decoration: none;
        display: inline-block;
    }

    .cyber-btn.danger {
        background: var(--neon-red);
        box-shadow: 0 0 20px rgba(255, 0, 85, 0.3);
    }

    .cyber-btn.secondary {
        border: 1px solid var(--glass-border);
    }

    .cyber-btn:hover {
        transform: scale(1.05);
        filter: brightness(1.2);
    }

    .cyber-btn.danger:hover {
        box-shadow: 0 0 30px rgba(255, 0, 85, 0.5);
    }

    @media (max-width: 600px) {
        .glitch { font-size: 6rem; }
        .error-card { padding: 40px 20px; }
        .controls { flex-direction: column; }
    }
</style>
{% endblock %}


