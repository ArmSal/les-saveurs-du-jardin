{% extends 'base.html.twig' %}

{% block title %}Nouveau Produit | LSDJ{% endblock %}

{% block body %}
<div class="min-h-screen bg-slate-50 py-2 sm:py-4 px-0 sm:px-4 lg:px-8">
    <div class="max-w-3xl mx-auto">
        
        {# Header - Compact Dashboard Style #}
        <div class="mb-4 sm:mb-6 px-3 sm:px-0">
            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
                <div>
                    <h1 class="text-xl sm:text-2xl font-black text-slate-900 tracking-tight">Nouveau Produit</h1>
                </div>
                <a href="{{ path('app_produit_index') }}" class="inline-flex items-center gap-2 text-[10px] font-black uppercase tracking-widest text-slate-400 hover:text-indigo-600 transition-colors group">
                    <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24" class="group-hover:-translate-x-1 transition-transform"><path d="M15 19l-7-7 7-7"></path></svg>
                    Retour
                </a>
            </div>
        </div>

        {{ form_start(form, {'attr': {'enctype': 'multipart/form-data'}}) }}
        <div class="px-3 sm:px-0 space-y-4">

            <!-- Global Form Errors -->
            {% if not form.vars.valid %}
            <div class="bg-rose-50 border border-rose-200 rounded-lg p-3">
                <p class="text-xs font-bold text-rose-600">Veuillez corriger les erreurs ci-dessous</p>
            </div>
            {% endif %}

            <!-- Photo Section - First and Bigger -->
            <div class="bg-white border border-slate-200 rounded-xl overflow-hidden shadow-sm">
                <div class="px-4 py-3 border-b border-slate-100 bg-slate-50/50">
                    <h2 class="text-[9px] font-black text-slate-900 uppercase tracking-[0.15em] flex items-center gap-2">
                        <span class="w-1 h-3 bg-amber-500 rounded-full"></span>
                        Photo du Produit
                    </h2>
                </div>
                <div class="p-4 flex flex-col gap-4">
                    <div class="flex flex-col sm:flex-row items-center gap-4">
                        <div id="photo-placeholder" onclick="document.getElementById('{{ form.image_file.vars.id }}').click()" class="w-32 h-32 sm:w-40 sm:h-40 bg-slate-100 border-2 border-dashed border-slate-300 rounded-xl flex items-center justify-center text-slate-400 overflow-hidden shrink-0 cursor-pointer hover:border-indigo-400 hover:bg-slate-50 transition-all">
                            <svg id="preview-svg" width="40" height="40" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                                <path d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                            </svg>
                            <img id="preview-img" src="" class="w-full h-full object-cover hidden">
                        </div>
                        <div class="text-center sm:text-left flex-1">
                            <p class="text-[11px] font-medium text-slate-500 mb-3">Cliquez pour ajouter une image (JPG, PNG)</p>
                            <span id="photo-hint" class="hidden text-[10px] font-bold text-emerald-600 bg-emerald-50 px-2 py-1 rounded">Nouvelle photo sélectionnée</span>
                        </div>
                    </div>
                    <div class="hidden">
                        {{ form_widget(form.image_file, {'attr': {'onchange': 'handlePhotoSelect(this)'}}) }}
                        {{ form_errors(form.image_file) }}
                    </div>
                </div>
            </div>

            <!-- Product Information -->
            <div class="bg-white border border-slate-200 rounded-xl overflow-hidden shadow-sm">
                <div class="px-4 py-3 border-b border-slate-100 bg-slate-50/50">
                    <h2 class="text-[9px] font-black text-slate-900 uppercase tracking-[0.15em] flex items-center gap-2">
                        <span class="w-1 h-3 bg-emerald-500 rounded-full"></span>
                        Informations Produit
                    </h2>
                </div>
                <div class="p-4 flex flex-col gap-4">
                    <div class="grid grid-cols-2 gap-3">
                        <div>
                            <label class="text-[7px] font-black text-slate-400 uppercase tracking-widest mb-1 block">Référence *</label>
                            {{ form_widget(form.reference, {'attr': {'class': 'w-full h-9 bg-white border border-slate-200 rounded-lg px-3 text-xs font-bold text-slate-700', 'placeholder': 'REF-001'}}) }}
                        </div>
                        <div>
                            <label class="text-[7px] font-black text-slate-400 uppercase tracking-widest mb-1 block">Code-barre</label>
                            {{ form_widget(form.code_barre, {'attr': {'class': 'w-full h-9 bg-white border border-slate-200 rounded-lg px-3 text-xs font-bold text-slate-700', 'placeholder': '0000000000'}}) }}
                        </div>
                    </div>
                    <div>
                        <label class="text-[7px] font-black text-slate-400 uppercase tracking-widest mb-1 block">Catégorie</label>
                        {{ form_widget(form.categoryEntity, {'attr': {'class': 'w-full h-9 bg-white border border-slate-200 rounded-lg px-3 text-xs font-bold text-slate-700 cursor-pointer'}}) }}
                    </div>
                    <div class="grid grid-cols-2 gap-3">
                        <div>
                            <label class="text-[7px] font-black text-slate-400 uppercase tracking-widest mb-1 block">TVA (%)</label>
                            {{ form_widget(form.tva, {'attr': {'class': 'w-full h-9 bg-white border border-slate-200 rounded-lg px-3 pr-8 text-xs font-bold text-slate-700', 'placeholder': '20'}}) }}
                        </div>
                    </div>
                    <div>
                        <label class="text-[7px] font-black text-slate-400 uppercase tracking-widest mb-1 block">Désignation *</label>
                        {{ form_widget(form.designation, {'attr': {'class': 'w-full h-9 bg-white border border-slate-200 rounded-lg px-3 text-xs font-bold text-slate-900', 'placeholder': 'Nom du produit'}}) }}
                    </div>
                    <div class="grid grid-cols-3 gap-3">
                        <div>
                            <label class="text-[7px] font-black text-slate-400 uppercase tracking-widest mb-1 block">Prix HT *</label>
                            <div class="relative">
                                {{ form_widget(form.prix, {'attr': {'class': 'w-full h-9 bg-white border border-slate-200 rounded-lg px-3 pr-8 text-xs font-bold text-slate-700', 'placeholder': '0.00'}}) }}
                                <span class="absolute right-3 top-1/2 -translate-y-1/2 text-xs font-bold text-slate-400">€</span>
                            </div>
                        </div>
                        <div>
                            <label class="text-[7px] font-black text-slate-400 uppercase tracking-widest mb-1 block">Unité *</label>
                            {{ form_widget(form.unite, {'attr': {'class': 'w-full h-9 bg-white border border-slate-200 rounded-lg px-3 text-xs font-bold text-slate-700', 'placeholder': 'kg, pièce...'}}) }}
                        </div>
                        <div>
                            <label class="text-[7px] font-black text-slate-400 uppercase tracking-widest mb-1 block">Stock</label>
                            {{ form_widget(form.qte_stock, {'attr': {'class': 'w-full h-9 bg-white border border-slate-200 rounded-lg px-3 text-xs font-bold text-slate-700', 'placeholder': '0'}}) }}
                        </div>
                    </div>
                    <div>
                        <label class="text-[7px] font-black text-slate-400 uppercase tracking-widest mb-1 block">Description</label>
                        {{ form_widget(form.description, {'attr': {'class': 'w-full h-20 bg-white border border-slate-200 rounded-lg px-3 py-2 text-xs font-bold text-slate-700 resize-none', 'placeholder': 'Description du produit...', 'rows': '3'}}) }}
                    </div>
                </div>
            </div>

            <!-- Submit Button -->
            <div class="flex items-center justify-end gap-3 pt-2">
                <button type="submit" class="inline-flex items-center gap-2 bg-emerald-600 hover:bg-emerald-700 text-white font-bold py-2 px-4 rounded-lg transition-all text-xs uppercase tracking-wider shadow-sm">
                    <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"></path></svg>
                    Créer le produit
                </button>
            </div>

        </div>
        {{ form_end(form) }}
    </div>

    <script>
        function handlePhotoSelect(input) {
            if (input.files && input.files[0]) {
                document.getElementById('photo-hint').classList.remove('hidden');
                const file = input.files[0];
                const reader = new FileReader();
                reader.onload = function (e) {
                    document.getElementById('preview-img').src = e.target.result;
                    document.getElementById('preview-img').classList.remove('hidden');
                    document.getElementById('preview-svg').classList.add('hidden');
                    const container = document.getElementById('photo-placeholder');
                    container.classList.remove('border-dashed', 'bg-slate-100', 'text-slate-400');
                    container.classList.add('border-solid');
                };
                reader.readAsDataURL(file);
            }
        }
    </script>
</div>
{% endblock %}
