{% extends 'base.html.twig' %}

{% block title %}Modifier la Catégorie | Plateforme LSDJ{% endblock %}

{% block body %}
	<div class="max-w-2xl mx-auto py-12 animate-in fade-in slide-in-from-bottom-6 duration-700">
		<div class="text-center mb-10 space-y-2">
			<div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-indigo-50 border-indigo-100/50 border mb-4">
				<span class="w-2 h-2 rounded-full bg-indigo-600 animate-pulse"></span>
				<span class="text-[10px] font-black uppercase tracking-widest text-indigo-600">Mise à jour Élément</span>
			</div>
			<h1 class="text-4xl font-black text-slate-900 tracking-tight">Modifier <span class="text-indigo-600">Catégorie</span></h1>
			<p class="text-slate-500 font-medium">Modifiez le nom de la catégorie logistique "{{ category.nom|upper }}".</p>
		</div>

		<div class="bg-white/80 backdrop-blur-md border border-slate-200/60 rounded-[2.5rem] p-10 shadow-2xl shadow-indigo-100/30">
			{{ include('produit/categories/_form.html.twig') }}
		</div>
	</div>

	<style>
		@keyframes animate-in {
			from { opacity: 0; transform: translateY(20px); }
			to { opacity: 1; transform: translateY(0); }
		}
		.animate-in {
			animation: animate-in 0.8s cubic-bezier(0.16, 1, 0.3, 1) backwards;
		}
	</style>
{% endblock %}
