{{ form_start(form, {'attr': {'class': 'space-y-6'}}) }}
    <div class="space-y-4">
        <div class="relative group">
            <div class="absolute inset-y-0 left-4 flex items-center pointer-events-none transition-colors duration-300 group-focus-within:text-indigo-600 text-slate-400">
                <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"></path></svg>
            </div>
            {{ form_widget(form.nom, {
                'attr': {
                    'class': 'w-full pl-12 pr-6 py-4 bg-slate-50 border-2 border-slate-50 rounded-[1.5rem] outline-none transition-all duration-300 focus:bg-white focus:border-indigo-600/20 focus:ring-4 focus:ring-indigo-600/5 text-sm font-bold text-slate-700 placeholder:text-slate-400',
                    'placeholder': 'Nom de la catégorie logistique (ex: ÉPICERIE)'
                }
            }) }}
        </div>
        <div class="text-[10px] font-black text-rose-500 uppercase tracking-widest px-4">
            {{ form_errors(form.nom) }}
        </div>
    </div>

    <div class="flex items-center gap-4 pt-4">
        <button type="submit" class="flex-[2] h-14 bg-indigo-600 hover:bg-indigo-700 text-white font-black text-xs uppercase tracking-widest rounded-2xl shadow-xl shadow-indigo-100 transition-all transform active:scale-95 border-0 cursor-pointer flex items-center justify-center gap-2 group">
            <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24" class="group-hover:translate-x-0.5 transition-transform"><path d="M5 13l4 4L19 7"></path></svg>
            Enregistrer la Catégorie
        </button>
        <a href="{{ path('app_produit_category_index') }}" class="flex-1 h-14 bg-slate-50 hover:bg-slate-100 text-slate-500 font-bold text-xs uppercase tracking-widest rounded-2xl transition-all border-0 flex items-center justify-center">
            Annuler
        </a>
    </div>
{{ form_end(form) }}
