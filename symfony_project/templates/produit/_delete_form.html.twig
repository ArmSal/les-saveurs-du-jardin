<form method="post" action="{{ path('app_produit_delete', {'id': product.id}) }}" onsubmit="return confirm('Attention : Cette action est irréversible. Voulez-vous supprimer ce produit ?');">
	<input type="hidden" name="_token" value="{{ csrf_token('delete' ~ product.id) }}">
	<button style="background: none; border: none; color: #ef4444; font-weight: 800; font-size: 13px; text-transform: uppercase; letter-spacing: 0.1em; cursor: pointer; text-decoration: underline;">Supprimer définitivement ce produit</button>
</form>
