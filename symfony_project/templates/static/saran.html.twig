{% extends 'base.html.twig' %}

{% block title %}{{ magasin_name }} - Contact | LSDJ{% endblock %}

{% block stylesheets %}
{{ parent() }}
<link rel="stylesheet" href="{{ asset('css/contact-modern.css') }}">
{% endblock %}

{% block body %}
{% set store_name = magasin_name|split(' ')|last %}
{% set currentDay = "now"|date('l')|replace({'Monday':'Lundi','Tuesday':'Mardi','Wednesday':'Mercredi','Thursday':'Jeudi','Friday':'Vendredi','Saturday':'Samedi','Sunday':'Dimanche'}) %}

<div class="contact-page-modern">
    <div class="contact-container">
        
        {# Header Section #}
        <header class="contact-header">
            <div class="contact-badge">
                <span class="contact-badge-dot"></span>
                Contact & Informations
            </div>
            <h1 class="contact-title">
                Les Saveurs du Jardin <span>{{ store_name }}</span>
            </h1>
            <p class="contact-subtitle">Retrouvez toutes les informations de contact et les horaires d'ouverture de votre magasin</p>
            <div class="contact-title-divider"></div>
        </header>

        {# Main Grid #}
        <div class="contact-grid">
            
            {# Sidebar #}
            <aside class="contact-sidebar">
                
                {# Map Card #}
                <div class="contact-map-card">
                    <div class="contact-map-wrapper">
                        <iframe src="https://www.google.com/maps/embed?pb=!1m17!1m12!1m3!1d2672.406410159522!2d1.8890639771729536!3d47.94786466434858!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m2!1m1!2zNDfCsDU2JzUyLjMiTiAxwrA1MycyOS45IkU!5e0!3m2!1sen!2sfr!4v1774887081324!5m2!1sen!2sfr" width="400" height="300" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
                        <div class="contact-map-overlay"></div>
                    </div>
                </div>

                {# Google Reviews Live Component #}
                {% include 'static/_google_reviews.html.twig' %}

                {# Quick Info Card #}
                <div class="contact-info-card">
                    <div class="contact-info-header">
                        <div class="contact-info-icon">
                            <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                <path d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                            </svg>
                        </div>
                        <span class="contact-info-title">Contact Rapide</span>
                    </div>
                    
                    <div class="contact-info-list">
                        <div class="contact-info-item">
                            <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                <path d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                                <path d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                            </svg>
                            <div>
                                <div class="contact-info-label">Adresse</div>
                                <div class="contact-info-value">{{ address }}</div>
                            </div>
                        </div>
                        
                        <div class="contact-info-item">
                            <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                <path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                            </svg>
                            <div>
                                <div class="contact-info-label">Email</div>
                                <div class="contact-info-value">{{ email }}</div>
                            </div>
                        </div>
                        
                        <a href="tel:{{ phone|replace({' ': ''}) }}" class="contact-info-item">
                            <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                <path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 5z"></path>
                            </svg>
                            <div>
                                <div class="contact-info-label">Téléphone</div>
                                <div class="contact-info-value">{{ phone }}</div>
                            </div>
                        </a>
                        
                        <a href="{{ instagram }}" target="_blank" class="contact-info-item">
                            <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
                                <path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37zm1.5-4.87h.01"></path>
                            </svg>
                            <div>
                                <div class="contact-info-label">Instagram</div>
                                <div class="contact-info-value">@lessaveursdujardin</div>
                            </div>
                        </a>
                    </div>
                    
                    <div class="contact-social-links">
                        <a href="{{ instagram }}" target="_blank" class="contact-social-link instagram">
                            <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
                                <path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37zm1.5-4.87h.01"></path>
                            </svg>
                        </a>
                    </div>
                </div>

                {# Hours Card #}
                <div class="contact-hours-card">
                    <div class="contact-hours-header">
                        <div class="contact-hours-icon">
                            <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                <circle cx="12" cy="12" r="10"></circle>
                                <path d="M12 6v6l4 2"></path>
                            </svg>
                        </div>
                        <span class="contact-hours-title">Horaires d'ouverture</span>
                    </div>
                    
                    <div class="contact-hours-list">
                        {% for day, time in hours %}
                            <div class="contact-hours-item {% if day == currentDay %}today{% endif %}">
                                <span class="contact-hours-day">{{ day }}</span>
                                <span class="contact-hours-time">
                                    {{ time }}
                                    {% if day == currentDay %}
                                        <span class="contact-hours-badge">
                                            <span></span> Aujourd'hui
                                        </span>
                                    {% endif %}
                                </span>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            </aside>

            {# Main Content - Management #}
            <main class="contact-main">
                <div class="contact-management-card">
                    <div class="contact-management-header">
                        <div class="contact-management-icon">
                            <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                <path d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
                            </svg>
                        </div>
                        <div>
                            <h2 class="contact-management-title">Direction & Management</h2>
                            <p class="contact-management-subtitle">Équipe de direction du magasin</p>
                        </div>
                    </div>

                    {% macro contact_card(user, role_label) %}
                        <div class="contact-member-card">
                            <div class="contact-member-avatar">
                                {% if user.photo %}
                                    <img src="{{ path('app_media_user', {filename: user.photo}) }}" alt="{{ user.prenom }} {{ user.nom }}">
                                {% else %}
                                    <div class="contact-member-avatar-placeholder">
                                        <svg width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                                            <path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                                        </svg>
                                    </div>
                                {% endif %}
                            </div>
                            
                            <div style="text-align: center;">
                                <span class="contact-member-role {{ role_label|lower }}">{{ role_label }}</span>
                                <h3 class="contact-member-name">{{ user.prenom }} {{ user.nom }}</h3>
                            </div>
                            
                            <div class="contact-member-contacts">
                                <a href="mailto:{{ user.email }}" class="contact-member-link">
                                    <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                        <path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                                    </svg>
                                    {{ user.email }}
                                </a>
                                {% if user.telephone %}
                                    <a href="tel:{{ user.telephone|replace({' ': ''}) }}" class="contact-member-link">
                                        <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                            <path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 5z"></path>
                                        </svg>
                                        {{ user.telephone }}
                                    </a>
                                {% endif %}
                            </div>
                        </div>
                    {% endmacro %}

                    {% if directeurs|length > 0 or managers|length > 0 %}
                        <div class="contact-team-grid">
                            {% import _self as ui %}
                            
                            {% for u in directeurs %}
                                {{ ui.contact_card(u, 'Directeur') }}
                            {% endfor %}
                            
                            {% for u in managers %}
                                {{ ui.contact_card(u, u.roleEntity ? u.roleEntity.label : 'Manager') }}
                            {% endfor %}
                        </div>
                    {% else %}
                        <div class="contact-empty-state">
                            <div class="contact-empty-state-icon">
                                <svg width="40" height="40" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                                    <path d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
                                </svg>
                            </div>
                            <p class="contact-empty-state-text">Aucun membre de direction configuré pour ce magasin</p>
                        </div>
                    {% endif %}

                    <div class="contact-management-footer">
                        <div class="contact-sync-indicator">
                            <span class="contact-sync-dot"></span>
                            <span>Synchronisé en temps réel</span>
                        </div>
                        <p class="contact-sync-text">Les informations sont mises à jour automatiquement depuis la base de données</p>
                    </div>
                </div>
            </main>
        </div>
    </div>
</div>
{% endblock %}
