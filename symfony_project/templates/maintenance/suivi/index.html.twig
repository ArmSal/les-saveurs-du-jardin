{% extends 'base.html.twig' %}

{% block title %}Suivi intervention | Maintenance{% endblock %}

{% block body %}
<div class="min-h-screen bg-slate-50 py-2 sm:py-4 px-0 sm:px-4 lg:px-8">
    <div class="max-w-7xl mx-auto">
        
        {# Header #}
        <div class="mb-4 sm:mb-6 px-3 sm:px-0">
            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
                <div>
                    <h1 class="text-xl sm:text-2xl font-black text-slate-900 tracking-tight">Suivi intervention</h1>
                    <p class="text-xs text-slate-500 mt-0.5">Tracking des tâches</p>
                </div>
                {% if canEdit %}
                <a href="{{ path('app_maintenance_suivi_new') }}" class="inline-flex items-center gap-2 bg-indigo-600 hover:bg-indigo-700 text-white text-[10px] font-black uppercase tracking-wider py-2 px-4 rounded-lg transition-all">
                    <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 4v16m8-8H4"></path></svg>
                    Nouvelle fiche
                </a>
                {% endif %}
            </div>
        </div>

        {# Filters #}
        <div class="bg-white/50 backdrop-blur-sm border border-slate-200/60 rounded-2xl mb-8 overflow-hidden animate-in fade-in slide-in-from-top-6 duration-700">
            <div class="p-4">
                <form method="get" action="{{ path('app_maintenance_suivi') }}" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 items-center gap-4">
                    
                    {# Date From #}
                    <div class="relative">
                        <label class="block text-[10px] font-black text-slate-500 uppercase tracking-widest mb-1.5">Date début</label>
                        <input type="date" name="dateFrom" value="{{ dateFrom }}" class="w-full px-3 py-2 bg-white border border-slate-200 rounded-xl text-[11px] font-semibold text-slate-700 focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 transition-all">
                    </div>

                    {# Date To #}
                    <div class="relative">
                        <label class="block text-[10px] font-black text-slate-500 uppercase tracking-widest mb-1.5">Date fin</label>
                        <input type="date" name="dateTo" value="{{ dateTo }}" class="w-full px-3 py-2 bg-white border border-slate-200 rounded-xl text-[11px] font-semibold text-slate-700 focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 transition-all">
                    </div>

                    {# Magasin Filter #}
                    <div class="relative">
                        <label class="block text-[10px] font-black text-slate-500 uppercase tracking-widest mb-1.5">Magasin</label>
                        <select name="magasin" class="w-full px-3 py-2 bg-white border border-slate-200 rounded-xl text-[11px] font-semibold text-slate-700 focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 transition-all appearance-none">
                            <option value="">Tous les magasins</option>
                            {% for magasin in magasins %}
                                <option value="{{ magasin.id }}" {% if currentMagasin == magasin.id %}selected{% endif %}>{{ magasin.nom }}</option>
                            {% endfor %}
                        </select>
                    </div>

                    {# User Filter (only for full access) #}
                    {% if isFullAccess %}
                    <div class="relative">
                        <label class="block text-[10px] font-black text-slate-500 uppercase tracking-widest mb-1.5">Utilisateur</label>
                        <select name="user" class="w-full px-3 py-2 bg-white border border-slate-200 rounded-xl text-[11px] font-semibold text-slate-700 focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 transition-all appearance-none">
                            <option value="">Tous les utilisateurs</option>
                            {% for user in users %}
                                <option value="{{ user.id }}" {% if currentUser == user.id %}selected{% endif %}>{{ user.nom }} {{ user.prenom }}</option>
                            {% endfor %}
                        </select>
                    </div>
                    {% endif %}

                    {# Actions #}
                    <div class="flex items-end gap-2 {% if not isFullAccess %}lg:justify-end{% endif %}">
                        <button type="submit" class="inline-flex items-center gap-2 bg-indigo-600 hover:bg-indigo-700 text-white text-[10px] font-black uppercase tracking-wider py-2 px-4 rounded-lg transition-all">
                            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                            Filtrer
                        </button>
                        <a href="{{ path('app_maintenance_suivi') }}" class="p-2 bg-slate-100 hover:bg-rose-50 hover:text-rose-600 text-slate-400 rounded-lg transition-all" title="Réinitialiser">
                            <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path d="M6 18L18 6M6 6l12 12"></path></svg>
                        </a>
                    </div>
                </form>
            </div>
        </div>

        {# Tasks List - Cards on mobile, Table on desktop #}
        <div class="bg-white border border-slate-200 rounded-2xl overflow-hidden shadow-sm">
            {# Desktop Table #}
            <div class="hidden md:block overflow-x-auto">
                <table class="w-full">
                    <thead class="bg-slate-50 border-b border-slate-200">
                        <tr>
                            <th class="px-4 py-3 text-left text-[10px] font-black text-slate-600 uppercase tracking-widest">Date</th>
                            <th class="px-4 py-3 text-left text-[10px] font-black text-slate-600 uppercase tracking-widest">Magasin</th>
                            {% if isFullAccess %}
                            <th class="px-4 py-3 text-left text-[10px] font-black text-slate-600 uppercase tracking-widest">Utilisateur</th>
                            {% endif %}
                            <th class="px-4 py-3 text-left text-[10px] font-black text-slate-600 uppercase tracking-widest">Tâches</th>
                            <th class="px-4 py-3 text-center text-[10px] font-black text-slate-600 uppercase tracking-widest">Statut</th>
                            <th class="px-4 py-3 text-right text-[10px] font-black text-slate-600 uppercase tracking-widest">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100">
                        {% for task in tasks %}
                        <tr class="hover:bg-slate-50/50 transition-colors">
                            <td class="px-4 py-3">
                                <a href="{{ path('app_maintenance_suivi_show', {id: task.id}) }}" class="inline-flex items-center gap-1.5 px-2.5 py-1 bg-indigo-50 text-indigo-700 rounded-lg text-[11px] font-black uppercase tracking-wide">
                                    <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                                    {{ task.date|date('d/m/Y') }}
                                </a>
                            </td>
                            <td class="px-4 py-3">
                                <span class="inline-flex items-center gap-1.5 px-2.5 py-1 bg-emerald-50 text-emerald-700 rounded-lg text-[11px] font-black uppercase tracking-wide">
                                    <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5"></path></svg>
                                    {{ task.magasin.nom }}
                                </span>
                            </td>
                            {% if isFullAccess %}
                            <td class="px-4 py-3">
                                <span class="text-[12px] font-semibold text-slate-700">{{ task.user.nom }} {{ task.user.prenom }}</span>
                            </td>
                            {% endif %}
                            <td class="px-4 py-3">
                                <span class="text-[11px] text-slate-600">{{ task.items|length }} tâche(s)</span>
                            </td>
                            <td class="px-4 py-3 text-center">
                                {% if task.isApproved %}
                                    <span class="inline-flex items-center gap-1 px-2 py-1 bg-emerald-100 text-emerald-700 rounded-lg text-[10px] font-black uppercase tracking-wide">
                                        <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"></path></svg>
                                        Approuvé
                                    </span>
                                {% else %}
                                    <span class="inline-flex items-center gap-1 px-2 py-1 bg-amber-50 text-amber-600 rounded-lg text-[10px] font-black uppercase tracking-wide">
                                        <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                                        En cours
                                    </span>
                                {% endif %}
                            </td>
                            <td class="px-4 py-3">
                                <div class="flex items-center justify-end gap-1">
                                    <a href="{{ path('app_maintenance_suivi_show', {id: task.id}) }}" class="w-7 h-7 bg-sky-50 hover:bg-sky-100 text-sky-600 rounded-lg flex items-center justify-center transition-all" title="Voir">
                                        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                                    </a>
                                    {% if not task.isApproved or isFullAccess %}
                                        <a href="{{ path('app_maintenance_suivi_edit', {id: task.id}) }}" class="w-7 h-7 bg-indigo-50 hover:bg-indigo-100 text-indigo-600 rounded-lg flex items-center justify-center transition-all" title="Modifier">
                                            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"></path></svg>
                                        </a>
                                    {% endif %}
                                    {% if isFullAccess or (isPersonalAccess and not task.isApproved) %}
                                    <a href="{{ path('app_maintenance_suivi_delete', {id: task.id}) }}?_token={{ csrf_token('delete' ~ task.id) }}" onclick="event.stopPropagation(); showConfirmModal('Supprimer', 'Êtes-vous sûr de vouloir supprimer cette fiche ?', function() { window.location.href = this.href; }.bind(this)); return false;" class="w-7 h-7 bg-rose-50 hover:bg-rose-100 text-rose-600 rounded-lg flex items-center justify-center transition-all" title="Supprimer">
                                        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                                    </a>
                                    {% endif %}
                                </div>
                            </td>
                        </tr>
                        {% else %}
                        <tr>
                            <td colspan="{% if isFullAccess %}6{% else %}5{% endif %}" class="px-4 py-12 text-center">
                                <div class="w-16 h-16 bg-slate-50 rounded-2xl flex items-center justify-center mx-auto mb-4">
                                    <svg width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.5" class="text-slate-300" viewBox="0 0 24 24">
                                        <path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"></path>
                                    </svg>
                                </div>
                                <p class="text-sm font-bold text-slate-700 mb-1">Aucune fiche</p>
                                <p class="text-xs text-slate-500">Créez une nouvelle fiche</p>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>

            {# Mobile Cards #}
            <div class="md:hidden divide-y divide-slate-100">
                {% for task in tasks %}
                <div class="p-4 hover:bg-slate-50/50 transition-colors">
                    <div class="flex items-start justify-between mb-3">
                        <div class="flex flex-col gap-2">
                            <a href="{{ path('app_maintenance_suivi_show', {id: task.id}) }}" class="inline-flex items-center gap-1.5 px-2.5 py-1 bg-indigo-50 text-indigo-700 rounded-lg text-[11px] font-black uppercase tracking-wide w-fit">
                                <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                                {{ task.date|date('d/m/Y') }}
                            </a>
                            <span class="inline-flex items-center gap-1.5 px-2.5 py-1 bg-emerald-50 text-emerald-700 rounded-lg text-[11px] font-black uppercase tracking-wide w-fit">
                                <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5"></path></svg>
                                {{ task.magasin.nom }}
                            </span>
                        </div>
                        {% if task.isApproved %}
                            <span class="inline-flex items-center gap-1 px-2 py-1 bg-emerald-100 text-emerald-700 rounded-lg text-[10px] font-black uppercase tracking-wide">
                                <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"></path></svg>
                                Approuvé
                            </span>
                        {% else %}
                            <span class="inline-flex items-center gap-1 px-2 py-1 bg-amber-50 text-amber-600 rounded-lg text-[10px] font-black uppercase tracking-wide">
                                <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                                En cours
                            </span>
                        {% endif %}
                    </div>
                    {% if isFullAccess %}
                    <div class="mb-3">
                        <span class="text-[12px] font-semibold text-slate-700">{{ task.user.nom }} {{ task.user.prenom }}</span>
                    </div>
                    {% endif %}
                    <div class="flex items-center justify-between">
                        <span class="text-[11px] text-slate-600">{{ task.items|length }} tâche(s)</span>
                        <div class="flex items-center gap-2">
                            <a href="{{ path('app_maintenance_suivi_show', {id: task.id}) }}" class="w-8 h-8 bg-sky-50 hover:bg-sky-100 text-sky-600 rounded-lg flex items-center justify-center transition-all" title="Voir">
                                <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                            </a>
                            {% if not task.isApproved or isFullAccess %}
                                <a href="{{ path('app_maintenance_suivi_edit', {id: task.id}) }}" class="w-8 h-8 bg-indigo-50 hover:bg-indigo-100 text-indigo-600 rounded-lg flex items-center justify-center transition-all" title="Modifier">
                                    <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"></path></svg>
                                </a>
                            {% endif %}
                            {% if isFullAccess or (isPersonalAccess and not task.isApproved) %}
                            <a href="{{ path('app_maintenance_suivi_delete', {id: task.id}) }}?_token={{ csrf_token('delete' ~ task.id) }}" onclick="event.stopPropagation(); showConfirmModal('Supprimer', 'Êtes-vous sûr de vouloir supprimer cette fiche ?', function() { window.location.href = this.href; }.bind(this)); return false;" class="w-8 h-8 bg-rose-50 hover:bg-rose-100 text-rose-600 rounded-lg flex items-center justify-center transition-all" title="Supprimer">
                                <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                            </a>
                            {% endif %}
                        </div>
                    </div>
                </div>
                {% else %}
                <div class="px-4 py-12 text-center">
                    <div class="w-16 h-16 bg-slate-50 rounded-2xl flex items-center justify-center mx-auto mb-4">
                        <svg width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.5" class="text-slate-300" viewBox="0 0 24 24">
                            <path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"></path>
                        </svg>
                    </div>
                    <p class="text-sm font-bold text-slate-700 mb-1">Aucune fiche</p>
                    <p class="text-xs text-slate-500">Créez une nouvelle fiche</p>
                </div>
                {% endfor %}
            </div>
            
            {# Pagination #}
            {% if tasks.getPageCount() > 1 %}
            <div class="px-4 py-3 border-t border-slate-200 bg-slate-50/50">
                {{ knp_pagination_render(tasks, 'parts/_premium_pagination.html.twig') }}
            </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
