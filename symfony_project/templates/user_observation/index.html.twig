{% extends 'base.html.twig' %}

{% block title %}Observations Employés
{% endblock %}

{% block stylesheets %}
	{{ parent() }}
	<style>
		.filter-tab {
			transition: all 0.2s ease;
		}
		.filter-tab.active {
			background-color: #4f46e5;
			color: white;
			border-color: #4f46e5;
		}
		.filter-tab:not(.active):hover {
			background-color: #f1f5f9;
		}

		/* Custom tooltip styles */
		.input-tooltip {
			position: relative;
		}
		.input-tooltip .tooltip-text {
			visibility: hidden;
			background-color: #1e293b;
			color: white;
			text-align: center;
			padding: 6px 10px;
			border-radius: 6px;
			position: absolute;
			z-index: 10;
			bottom: 125%;
			left: 50%;
			transform: translateX(-50%);
			opacity: 0;
			transition: opacity 0.2s;
			white-space: nowrap;
			font-size: 12px;
			font-weight: 500;
			box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
			max-width: 300px;
			white-space: normal;
			word-wrap: break-word;
		}
		.input-tooltip .tooltip-text::after {
			content: "";
			position: absolute;
			top: 100%;
			left: 50%;
			margin-left: -5px;
			border-width: 5px;
			border-style: solid;
			border-color: #1e293b transparent transparent transparent;
		}
		.input-tooltip:hover .tooltip-text,
		.input-tooltip:focus-within .tooltip-text {
			visibility: visible;
			opacity: 1;
		}

		/* Hide scrollbar */
		.no-scrollbar {
			-ms-overflow-style: none;
			scrollbar-width: none;
		}
		.no-scrollbar::-webkit-scrollbar {
			display: none;
		}

		/* Ensure textarea can expand */
		td[data-label="Observation"] {
			vertical-align: top;
		}
		.auto-expand {
			min-height: 38px;
			overflow: hidden;
		}

		/* Responsive table styles */
		/* Hide expand icon on desktop */
		tbody tr.user-row td[data-label="Employé"] .expand-icon {
			display: none;
		}

		@media (max-width: 768px) {
			.filter-container {
				flex-direction: column !important;
			}
			.filter-container > div {
				width: 100% !important;
			}
		}

		@media (max-width: 640px) {
			/* Compact accordion mobile layout */
			thead {
				display: none;
			}
			tbody {
				display: block;
				padding: 8px;
			}
			tbody tr.user-row {
				display: block;
				background: white;
				border: 1px solid #e2e8f0;
				border-radius: 8px;
				margin-bottom: 8px;
				box-shadow: 0 1px 2px rgba(0,0,0,0.05);
				overflow: hidden;
			}
			/* Accordion header with user + magasin inline */
			tbody tr.user-row td[data-label="Employé"] {
				display: flex;
				align-items: center;
				justify-content: space-between;
				gap: 8px;
				padding: 12px 16px;
				background: #f8fafc;
				border-bottom: 1px solid #e2e8f0;
				cursor: pointer;
			}
			tbody tr.user-row td[data-label="Employé"]::before {
				display: none;
			}
			tbody tr.user-row td[data-label="Employé"] .user-info {
				display: flex;
				align-items: center;
				gap: 8px;
				flex: 1;
			}
			tbody tr.user-row td[data-label="Employé"] .user-name {
				font-size: 14px;
				font-weight: 600;
				color: #1e293b;
			}
			tbody tr.user-row td[data-label="Employé"] .expand-icon {
				font-size: 18px;
				color: #64748b;
				transition: transform 0.2s;
			}
			tbody tr.user-row.expanded td[data-label="Employé"] .expand-icon {
				transform: rotate(180deg);
			}
			/* Magasin badge inline with user name */
			tbody tr.user-row td[data-label="Magasin"] {
				display: none;
			}
			/* Add magasin badge to user-info area */
			tbody tr.user-row td[data-label="Employé"] .user-info::after {
				content: attr(data-magasin-content);
				display: inline-flex;
				align-items: center;
				justify-content: center;
				padding: 2px 8px;
				font-size: 10px;
				font-weight: 500;
				background-color: #e0e7ff;
				color: #3730a3;
				border-radius: 9999px;
				white-space: nowrap;
				margin-left: 8px;
			}
			/* Show expand icon only on mobile */
			tbody tr.user-row td[data-label="Employé"] .expand-icon {
				display: block;
			}
			/* Collapsed content */
			tbody tr.user-row td[data-label="Observation"],
			tbody tr.user-row td[data-label="Ticket Restaurant"],
			tbody tr.user-row td[data-label="Actions"] {
				display: none;
				padding: 8px 16px;
			}
			tbody tr.user-row.expanded td[data-label="Observation"],
			tbody tr.user-row.expanded td[data-label="Ticket Restaurant"],
			tbody tr.user-row.expanded td[data-label="Actions"] {
				display: block;
			}
			tbody tr.user-row td[data-label="Observation"]::before,
			tbody tr.user-row td[data-label="Ticket Restaurant"]::before {
				content: attr(data-label);
				font-weight: 600;
				color: #64748b;
				font-size: 10px;
				text-transform: uppercase;
				letter-spacing: 0.05em;
				display: block;
				margin-bottom: 4px;
			}
			tbody tr.user-row td[data-label="Actions"]::before {
				display: none;
			}
			/* Compact inputs */
			tbody tr.user-row td input[type="text"],
			tbody tr.user-row td input[type="number"] {
				width: 100%;
				min-height: 40px;
				font-size: 14px;
				padding: 8px 12px;
			}
			/* Compact actions button */
			tbody tr.user-row td[data-label="Actions"] {
				padding-top: 4px;
				padding-bottom: 12px;
			}
			tbody tr.user-row td[data-label="Actions"] button {
				width: 100%;
				min-height: 40px;
				justify-content: center;
				font-size: 12px;
			}
			/* Page title mobile adjustments */
			@media (max-width: 480px) {
				.page-header {
					flex-direction: column;
					align-items: flex-start;
					gap: 12px;
					margin-bottom: 16px;
				}
				.page-header h1 {
					font-size: 20px;
				}
				.page-header p {
					font-size: 12px;
				}
				.filter-container {
					padding: 12px;
				}
			}
		}
	</style>
{% endblock %}

{% block body %}
	<div class="page-header mb-8 flex flex-col md:flex-row md:items-center justify-between gap-6">
		<div>
			<h1 class="text-3xl md:text-4xl font-black text-slate-900 mb-2 tracking-tight">Observations Employés</h1>
			<p class="text-slate-500 font-medium flex items-center gap-2">
                <span class="w-2 h-2 bg-emerald-500 rounded-full"></span>
                Gestion des observations et tickets restaurant
            </p>
		</div>
		<a href="{{ path('app_agenda') }}" class="inline-flex items-center gap-2 px-4 py-2 bg-white border border-slate-200 rounded-lg hover:bg-slate-50 text-slate-700 font-semibold text-sm transition-all shadow-sm">
			<svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
				<path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
			</svg>
			Retour aux horaires
		</a>
	</div>

	<div class="bg-white rounded-xl shadow-sm border border-slate-200 p-4 md:p-6 mb-6">
		<div class="filter-container flex flex-col md:flex-row gap-4 items-center">
			<div class="flex-1 w-full">
				<label class="block text-xs font-bold uppercase tracking-wider text-slate-500 mb-1.5 ml-1">Magasin</label>
				<select id="magasinFilter" class="w-full px-3 py-2.5 text-sm border border-slate-200 rounded-lg focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 outline-none bg-slate-50 transition-all font-semibold text-slate-700">
					<option value="">Tous les magasins</option>
					{% for magasin in magasins %}
						<option value="{{ magasin }}" {{ magasinFilter == magasin ? 'selected' : '' }}>{{ magasin }}</option>
					{% endfor %}
				</select>
			</div>

			<div class="flex-1 w-full">
				<label class="block text-xs font-bold uppercase tracking-wider text-slate-500 mb-1.5 ml-1">Employé</label>
				<select id="employeFilter" class="w-full px-3 py-2.5 text-sm border border-slate-200 rounded-lg focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 outline-none bg-slate-50 transition-all font-semibold text-slate-700">
					<option value="">Tous les employés</option>
					{% for user in users %}
						<option value="{{ user.id }}" data-magasin="{{ user.magasin }}">{{ user.prenom }} {{ user.nom }} ({{ user.magasin }})</option>
					{% endfor %}
				</select>
			</div>

			<div class="flex-1 w-full">
				<label class="block text-xs font-bold uppercase tracking-wider text-slate-500 mb-1.5 ml-1">Mois</label>
				<input type="month" id="moisFilter" value="{{ moisFilter }}" class="w-full px-3 py-2.5 text-sm border border-slate-200 rounded-lg focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 outline-none bg-white transition-all font-semibold text-slate-700">
			</div>

			<div class="flex-1 w-full">
				<label class="block text-xs font-bold uppercase tracking-wider text-slate-500 mb-1.5 ml-1">Verrouillage</label>
				<button type="button" id="lockMonthBtn" class="w-full px-3 py-2.5 text-sm border border-slate-200 rounded-lg focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 outline-none transition-all font-semibold flex items-center justify-center gap-2 bg-emerald-100 text-emerald-700 hover:bg-emerald-200">
					<span id="lockIcon">🔓</span>
					<span id="lockText">Déverrouillé</span>
				</button>
			</div>
		</div>
	</div>

	<div id="resultsContainer" class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden" style="display: none;">
		<div class="overflow-x-auto">
			<table class="w-full">
				<thead>
					<tr class="bg-slate-50 border-b border-slate-200">
						<th class="text-left px-4 py-3 text-xs font-bold uppercase tracking-wider text-slate-500">Employé</th>
						<th class="text-left px-4 py-3 text-xs font-bold uppercase tracking-wider text-slate-500">Magasin</th>
						<th class="text-left px-4 py-3 text-xs font-bold uppercase tracking-wider text-slate-500 w-1/3">Observation</th>
						<th class="text-left px-4 py-3 text-xs font-bold uppercase tracking-wider text-slate-500 w-32">Ticket Restaurant</th>
						<th class="text-left px-4 py-3 text-xs font-bold uppercase tracking-wider text-slate-500 w-32">Actions</th>
					</tr>
				</thead>
				<tbody id="usersTableBody">
					{% for user in users %}
						{% set observation = observationsData[user.id] %}
						<tr class="border-b border-slate-100 hover:bg-slate-50 transition-colors user-row" 
						    data-user-id="{{ user.id }}" 
						    data-magasin="{{ user.magasin }}">
							<td class="px-4 py-3" data-label="Employé" onclick="toggleRow(this)">
								<div class="user-info" data-magasin-content="{{ user.magasin }}">
									<span class="user-name">{{ user.prenom }} {{ user.nom }}</span>
								</div>
								<span class="expand-icon">▼</span>
							</td>
							<td class="px-4 py-3" data-label="Magasin">
								<span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-indigo-100 text-indigo-800">
									{{ user.magasin }}
								</span>
							</td>
							<td class="px-4 py-3" data-label="Observation">
								<div class="input-tooltip">
									<textarea 
										   name="observation_{{ user.id }}" 
										   maxlength="150"
										   rows="1"
										   class="w-full px-3 py-2 text-sm border border-slate-200 rounded-lg focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 outline-none bg-white transition-all resize-none auto-expand"
										   placeholder="Ajouter une observation..."
										   oninput="this.parentElement.querySelector('.tooltip-text').textContent = this.value || 'Observation vide'; autoResize(this)">{{ observation ? observation.observation : '' }}</textarea>
									<span class="tooltip-text">{{ observation ? observation.observation : 'Observation vide' }}</span>
								</div>
							</td>
							<td class="px-4 py-3" data-label="Ticket Restaurant">
								<div class="input-tooltip">
									<input type="number" 
										   name="ticket_restaurant_{{ user.id }}" 
										   value="{{ observation ? observation.ticketRestaurant : '' }}" 
										   min="0" 
										   max="99"
										   class="w-full px-3 py-2 text-sm border border-slate-200 rounded-lg focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 outline-none bg-white transition-all"
										   placeholder="0-99"
										   oninput="this.parentElement.querySelector('.tooltip-text').textContent = this.value || 'Ticket Restaurant vide'">
									<span class="tooltip-text">{{ observation ? observation.ticketRestaurant : 'Ticket Restaurant vide' }}</span>
								</div>
							</td>
							<td class="px-4 py-3" data-label="Actions">
								<button type="button" 
										class="apply-btn inline-flex items-center gap-2 px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white rounded-lg font-semibold text-xs uppercase tracking-wider transition-all shadow-sm"
										data-user-id="{{ user.id }}">
									Appliquer
								</button>
							</td>
						</tr>
					{% endfor %}
				</tbody>
			</table>
		</div>
	</div>

	<!-- Toast Notification Container -->
	<div id="toastContainer" class="fixed top-5 right-5 z-[10002] flex flex-col gap-3 pointer-events-none"></div>
{% endblock %}

{% block javascripts %}
	<script>
		document.addEventListener('DOMContentLoaded', function() {
			const magasinFilter = document.getElementById('magasinFilter');
			const moisFilter = document.getElementById('moisFilter');
			const employeFilter = document.getElementById('employeFilter');
		 const applyButtons = document.querySelectorAll('.apply-btn');
			const userRows = document.querySelectorAll('.user-row');

			// Filter handlers
			function applyFilters() {
				const magasinValue = magasinFilter.value;
				const moisValue = moisFilter.value;
				const employeValue = employeFilter.value;
				const resultsContainer = document.getElementById('resultsContainer');

				// Show/hide results container based on whether any filter is applied
				const hasFilter = magasinValue || moisValue || employeValue;
				resultsContainer.style.display = hasFilter ? 'block' : 'none';

				if (!hasFilter) {
					return; // Don't process rows if no filter
				}

				userRows.forEach(row => {
					const rowMagasin = row.dataset.magasin;
					const rowUserId = row.dataset.userId;

					let showRow = true;

					if (magasinValue && rowMagasin !== magasinValue) {
						showRow = false;
					}

					if (employeValue && rowUserId !== employeValue) {
						showRow = false;
					}

					row.style.display = showRow ? '' : 'none';
				});

				// Update URL without reload
				const url = new URL(window.location);
				if (magasinValue) {
					url.searchParams.set('magasin', magasinValue);
				} else {
					url.searchParams.delete('magasin');
				}
				if (moisValue) {
					url.searchParams.set('mois', moisValue);
				} else {
					url.searchParams.delete('mois');
				}
				if (employeValue) {
					url.searchParams.set('employe', employeValue);
				} else {
					url.searchParams.delete('employe');
				}
				window.history.replaceState({}, '', url);
			}

			magasinFilter.addEventListener('change', applyFilters);
			moisFilter.addEventListener('change', applyFilters);
			employeFilter.addEventListener('change', applyFilters);

			// Update employe filter based on magasin selection
			magasinFilter.addEventListener('change', function() {
				const selectedMagasin = this.value;
				employeFilter.innerHTML = '<option value="">Tous les employés</option>';
				
				document.querySelectorAll('#usersTableBody tr.user-row').forEach(row => {
					if (!selectedMagasin || row.dataset.magasin === selectedMagasin) {
						const userId = row.dataset.userId;
						const userName = row.querySelector('td:first-child').textContent.trim();
						const option = document.createElement('option');
						option.value = userId;
						option.textContent = userName;
						option.dataset.magasin = row.dataset.magasin;
						employeFilter.appendChild(option);
					}
				});
			});

			// Month lock functionality
			let isMonthLocked = false;
			const lockMonthBtn = document.getElementById('lockMonthBtn');
			const lockIcon = document.getElementById('lockIcon');
			const lockText = document.getElementById('lockText');

			function updateLockState(locked) {
				isMonthLocked = locked;
				if (locked) {
					lockIcon.textContent = '🔒';
					lockText.textContent = 'Verrouillé';
					lockMonthBtn.classList.remove('bg-emerald-100', 'text-emerald-700', 'hover:bg-emerald-200');
					lockMonthBtn.classList.add('bg-red-100', 'text-red-700', 'hover:bg-red-200');
					// Disable all inputs and buttons
					document.querySelectorAll('#usersTableBody textarea, #usersTableBody input[type="number"]').forEach(el => el.disabled = true);
					document.querySelectorAll('.apply-btn').forEach(btn => {
						btn.disabled = true;
						btn.classList.add('opacity-50', 'cursor-not-allowed');
					});
				} else {
					lockIcon.textContent = '🔓';
					lockText.textContent = 'Déverrouillé';
					lockMonthBtn.classList.remove('bg-red-100', 'text-red-700', 'hover:bg-red-200');
					lockMonthBtn.classList.add('bg-emerald-100', 'text-emerald-700', 'hover:bg-emerald-200');
					// Enable all inputs and buttons
					document.querySelectorAll('#usersTableBody textarea, #usersTableBody input[type="number"]').forEach(el => el.disabled = false);
					document.querySelectorAll('.apply-btn').forEach(btn => {
						btn.disabled = false;
						btn.classList.remove('opacity-50', 'cursor-not-allowed');
					});
				}
			}

			lockMonthBtn.addEventListener('click', function() {
				const moisValue = moisFilter.value;
				if (!moisValue) {
					showToast('Veuillez sélectionner un mois d\'abord', 'error');
					return;
				}

				const newLockState = !isMonthLocked;
				
				// Send lock/unlock request to server
				const formData = new FormData();
				formData.append('mois', moisValue);
				formData.append('is_locked', newLockState ? '1' : '0');

				fetch('{{ path('app_user_observations_lock') }}', {
					method: 'POST',
					body: formData,
					headers: {
						'X-Requested-With': 'XMLHttpRequest'
					}
				})
				.then(response => response.json())
				.then(data => {
					if (data.success) {
						updateLockState(newLockState);
						showToast(newLockState ? 'Mois verrouillé' : 'Mois déverrouillé', 'success');
					} else {
						showToast(data.error || 'Erreur lors du verrouillage', 'error');
					}
				})
				.catch(err => {
					console.error('Error:', err);
					showToast('Erreur lors du verrouillage', 'error');
				});
			});

			// Check initial lock state when month changes
			moisFilter.addEventListener('change', function() {
				const moisValue = this.value;
				if (moisValue) {
					fetch(`{{ path('app_user_observations_check_lock') }}?mois=${moisValue}`)
					.then(response => response.json())
					.then(data => {
						updateLockState(data.isLocked);
					})
					.catch(err => {
						console.error('Error checking lock status:', err);
					});
				}
			});

			// Apply button handlers
			applyButtons.forEach(btn => {
				btn.addEventListener('click', function() {
					const userId = this.dataset.userId;
					const observationInput = document.querySelector(`textarea[name="observation_${userId}"]`);
					const ticketInput = document.querySelector(`input[name="ticket_restaurant_${userId}"]`);
					
					const observation = observationInput.value.replace(/\n/g, ' ').trim();
					const ticketRestaurant = ticketInput.value;
					const mois = moisFilter.value;

					// Validate ticket restaurant
					if (ticketRestaurant !== '' && (ticketRestaurant < 0 || ticketRestaurant > 99)) {
						showToast('Ticket Restaurant doit être entre 0 et 99', 'error');
						return;
					}

					// Send update request
					const formData = new FormData();
					formData.append('user_id', userId);
					formData.append('observation', observation);
					formData.append('ticket_restaurant', ticketRestaurant);
					formData.append('mois', mois);

					fetch('{{ path('app_user_observations_update') }}', {
						method: 'POST',
						body: formData,
						headers: {
							'X-Requested-With': 'XMLHttpRequest'
						}
					})
					.then(response => response.json())
					.then(data => {
						if (data.success) {
							showToast('Observation mise à jour avec succès', 'success');
						} else {
							showToast(data.error || 'Erreur lors de la mise à jour', 'error');
						}
					})
					.catch(err => {
						console.error('Error:', err);
						showToast('Erreur lors de la mise à jour', 'error');
					});
				});
			});

			// Auto-resize textarea based on content
			window.autoResize = function(textarea) {
				textarea.style.height = 'auto';
				const newHeight = textarea.scrollHeight;
				textarea.style.height = newHeight + 'px';
			};

			// Initialize auto-resize for existing textareas
			setTimeout(() => {
				document.querySelectorAll('.auto-expand').forEach(textarea => {
					autoResize(textarea);
				});
			}, 100);

			// Toggle row accordion on mobile
			window.toggleRow = function(element) {
				// Only on mobile (screen width <= 640px)
				if (window.innerWidth > 640) return;
				
				const row = element.closest('tr');
				row.classList.toggle('expanded');
			};

			// Toast notification function
			function showToast(message, type = 'success') {
				const container = document.getElementById('toastContainer');
				const toast = document.createElement('div');
				
				const bgColor = type === 'success' ? 'bg-emerald-500' : 'bg-red-500';
				const icon = type === 'success' ? '✓' : '✕';
				
				toast.className = `${bgColor} text-white px-4 py-3 rounded-lg shadow-lg flex items-center gap-2 font-semibold text-sm pointer-events-auto animate-in slide-in-from-right`;
				toast.innerHTML = `
					<span class="w-5 h-5 rounded-full bg-white/20 flex items-center justify-center text-xs">${icon}</span>
					<span>${message}</span>
				`;
				
				container.appendChild(toast);
				
				setTimeout(() => {
					toast.classList.add('animate-out', 'slide-out-to-right');
					setTimeout(() => toast.remove(), 300);
				}, 3000);
			}

			// Set initial filter values from URL or use default
			const urlParams = new URLSearchParams(window.location.search);
			if (urlParams.get('magasin')) {
				magasinFilter.value = urlParams.get('magasin');
			}
			if (urlParams.get('mois')) {
				moisFilter.value = urlParams.get('mois');
			}
			if (urlParams.get('employe')) {
				employeFilter.value = urlParams.get('employe');
			}
			applyFilters();
			
			// Show results on page load since we have a default month
			if (moisFilter.value) {
				document.getElementById('resultsContainer').style.display = 'block';
			}
		});
	</script>
{% endblock %}
