{% extends 'base.html.twig' %}

{% block title %}Paramètres | LSDJ{% endblock %}

{% block body %}
<div class="min-h-screen bg-slate-50 py-2 sm:py-4 px-0 sm:px-4 lg:px-8">
    <div class="max-w-3xl mx-auto">
        
        {# Header - Compact Dashboard Style #}
        <div class="mb-4 sm:mb-6 px-3 sm:px-0">
            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
                <div>
                    <h1 class="text-xl sm:text-2xl font-black text-slate-900 tracking-tight">Paramètres du Compte</h1>
                </div>
                <a href="{{ path('app_dashboard') }}" class="inline-flex items-center gap-2 text-[10px] font-black uppercase tracking-widest text-slate-400 hover:text-indigo-600 transition-colors group">
                    <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24" class="group-hover:-translate-x-1 transition-transform"><path d="M15 19l-7-7 7-7"></path></svg>
                    Retour
                </a>
            </div>
        </div>

        {{ form_start(profileForm, {'attr': {'id': 'profile-form', 'enctype': 'multipart/form-data'}}) }}
        <div class="px-3 sm:px-0 space-y-4">

            <!-- Photo Section - First and Bigger -->
            <div class="bg-white border border-slate-200 rounded-xl overflow-hidden shadow-sm">
                <div class="px-4 py-3 border-b border-slate-100 bg-slate-50/50">
                    <h2 class="text-[9px] font-black text-slate-900 uppercase tracking-[0.15em] flex items-center gap-2">
                        <span class="w-1 h-3 bg-amber-500 rounded-full"></span>
                        Photo de Profil
                    </h2>
                </div>
                <div class="p-4">
                    <div class="flex flex-col sm:flex-row items-center gap-4">
                        <div id="photo-placeholder" onclick="document.getElementById('profile_form_photo_file').click()" class="w-32 h-32 sm:w-40 sm:h-40 bg-slate-100 border-2 border-dashed border-slate-300 rounded-xl flex items-center justify-center text-slate-400 overflow-hidden shrink-0 cursor-pointer hover:border-indigo-400 hover:bg-slate-50 transition-all relative">
                            {% if app.user.photo %}
                                <img src="{{ path('app_media_user', {filename: app.user.photo}) }}" class="w-full h-full object-cover">
                            {% else %}
                                <svg width="48" height="48" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
                            {% endif %}
                            <div class="absolute inset-0 bg-black/40 flex items-center justify-center opacity-0 hover:opacity-100 transition-opacity">
                                <svg width="32" height="32" fill="none" stroke="#fff" stroke-width="2" viewBox="0 0 24 24">
                                    <path d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"></path>
                                    <path d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"></path>
                                </svg>
                            </div>
                        </div>
                        <div class="flex-1 text-center sm:text-left">
                            <button type="button" onclick="document.getElementById('profile_form_photo_file').click()" class="inline-flex items-center gap-2 bg-white border border-slate-300 text-slate-600 font-bold py-2 px-4 rounded-lg hover:bg-slate-50 transition-all text-xs uppercase tracking-wider shadow-sm">
                                <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                                {% if app.user.photo %}Changer la photo{% else %}Choisir une photo{% endif %}
                            </button>
                            <p class="text-[8px] text-slate-400 mt-2">JPG, PNG - Max 2Mo</p>
                            <div class="hidden">{{ form_widget(profileForm.photo_file, {'id': 'profile_form_photo_file', 'attr': {'onchange': 'handlePhotoSelect(this)'}}) }}</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Section: Accès & Sécurité - LOCKED FIELDS -->
            <div class="bg-white border border-slate-200 rounded-xl overflow-hidden shadow-sm">
                <div class="px-4 py-3 border-b border-slate-100 flex items-center justify-between bg-slate-50/50">
                    <h2 class="text-[9px] font-black text-slate-900 uppercase tracking-[0.15em] flex items-center gap-2">
                        <span class="w-1 h-3 bg-indigo-500 rounded-full"></span>
                        Accès & Sécurité
                    </h2>
                    <span class="text-[8px] font-black uppercase tracking-widest px-2 py-0.5 bg-slate-300 text-slate-600 rounded">Lecture seule</span>
                </div>
                <div class="p-4 grid grid-cols-1 sm:grid-cols-2 gap-4">
                    <div class="sm:col-span-2">
                        <label class="text-[7px] font-black text-slate-400 uppercase tracking-widest mb-1 flex items-center gap-1">
                            Email Professionnel
                            <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="text-slate-300"><path d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
                        </label>
                        <div class="w-full h-9 bg-slate-100 border border-slate-200 rounded-lg px-3 flex items-center text-xs font-bold text-slate-500">{{ app.user.email }}</div>
                    </div>
                    <div>
                        <label class="text-[7px] font-black text-slate-400 uppercase tracking-widest mb-1 flex items-center gap-1">
                            Niveau d'Accès
                            <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="text-slate-300"><path d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
                        </label>
                        <div class="w-full h-9 bg-slate-100 border border-slate-200 rounded-lg px-3 flex items-center text-xs font-bold text-slate-500">
                            {{ app.user.roleEntity ? app.user.roleEntity.label : 'Utilisateur' }}
                        </div>
                    </div>
                    <div>
                        <label class="text-[7px] font-black text-slate-400 uppercase tracking-widest mb-1 flex items-center gap-1">
                            Affectation Magasin
                            <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="text-slate-300"><path d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
                        </label>
                        <div class="w-full h-9 bg-slate-100 border border-slate-200 rounded-lg px-3 flex items-center text-xs font-bold text-slate-500">{{ app.user.magasin }}</div>
                    </div>
                    <div>
                        <label class="text-[7px] font-black text-slate-400 uppercase tracking-widest mb-1 flex items-center gap-1">
                            Matricule
                            <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="text-slate-300"><path d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
                        </label>
                        <div class="w-full h-9 bg-slate-100 border border-slate-200 rounded-lg px-3 flex items-center text-xs font-black text-slate-500 font-mono">{{ app.user.clientNumber ?: 'Non attribué' }}</div>
                    </div>
                    <div>
                        <label class="text-[7px] font-black text-slate-400 uppercase tracking-widest mb-1 flex items-center gap-1">
                            Statut Compte
                            <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="text-slate-300"><path d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
                        </label>
                        <div class="w-full h-9 bg-slate-100 border border-slate-200 rounded-lg px-3 flex items-center text-xs font-bold {{ app.user.isActive ? 'text-emerald-600' : 'text-rose-600' }}">
                            {{ app.user.isActive ? 'Actif' : 'Inactif' }}
                        </div>
                    </div>
                </div>
            </div>

            <!-- Section: Identité - EDITABLE FIELDS -->
            <div class="bg-white border border-slate-200 rounded-xl overflow-hidden shadow-sm">
                <div class="px-4 py-3 border-b border-slate-100 bg-slate-50/50">
                    <h2 class="text-[9px] font-black text-slate-900 uppercase tracking-[0.15em] flex items-center gap-2">
                        <span class="w-1 h-3 bg-emerald-500 rounded-full"></span>
                        Identité & Informations
                    </h2>
                </div>
                <div class="p-4 flex flex-col gap-4">
                    <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
                        <div>
                            <label class="text-[7px] font-black text-slate-400 uppercase tracking-widest mb-1 flex items-center gap-1">
                                Civilité
                                <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="text-slate-300"><path d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
                            </label>
                            <div class="w-full h-9 bg-slate-100 border border-slate-200 rounded-lg px-3 flex items-center text-xs font-bold text-slate-500">{{ app.user.civility }}</div>
                        </div>
                        <div class="col-span-2 sm:col-span-1">
                            <label class="text-[7px] font-black text-slate-400 uppercase tracking-widest mb-1 flex items-center gap-1">
                                Nom
                                <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="text-slate-300"><path d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
                            </label>
                            <div class="w-full h-9 bg-slate-100 border border-slate-200 rounded-lg px-3 flex items-center text-xs font-black text-slate-500">{{ app.user.nom }}</div>
                        </div>
                        <div class="col-span-2 sm:col-span-1">
                            <label class="text-[7px] font-black text-slate-400 uppercase tracking-widest mb-1 flex items-center gap-1">
                                Prénom
                                <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="text-slate-300"><path d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
                            </label>
                            <div class="w-full h-9 bg-slate-100 border border-slate-200 rounded-lg px-3 flex items-center text-xs font-bold text-slate-500">{{ app.user.prenom }}</div>
                        </div>
                    </div>
                    
                    <div class="grid grid-cols-2 sm:grid-cols-3 gap-3 border-t border-dashed border-slate-200 pt-4">
                        <div>
                            <label class="text-[7px] font-black text-slate-400 uppercase tracking-widest mb-1 flex items-center gap-1">
                                Date Naissance
                                <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="text-slate-300"><path d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
                            </label>
                            <div class="w-full h-9 bg-slate-100 border border-slate-200 rounded-lg px-3 flex items-center text-xs font-bold text-slate-500">{{ app.user.dateNaissance ? app.user.dateNaissance|date('d/m/Y') : '-' }}</div>
                        </div>
                        <div>
                            <label class="text-[7px] font-black text-slate-400 uppercase tracking-widest mb-1 block">Téléphone</label>
                            {{ form_widget(profileForm.telephone, {'attr': {'class': 'w-full h-9 bg-white border border-slate-200 rounded-lg px-3 text-xs font-bold text-slate-700'}}) }}
                        </div>
                        <div>
                            <label class="text-[7px] font-black text-slate-400 uppercase tracking-widest mb-1 block">Code Postal</label>
                            {{ form_widget(profileForm.code_postal, {'attr': {'class': 'w-full h-9 bg-white border border-slate-200 rounded-lg px-3 text-xs font-bold text-slate-700'}}) }}
                        </div>
                        <div class="col-span-2">
                            <label class="text-[7px] font-black text-slate-400 uppercase tracking-widest mb-1 block">Adresse</label>
                            {{ form_widget(profileForm.adresse, {'attr': {'class': 'w-full h-9 bg-white border border-slate-200 rounded-lg px-3 text-xs font-bold text-slate-700'}}) }}
                        </div>
                        <div>
                            <label class="text-[7px] font-black text-slate-400 uppercase tracking-widest mb-1 block">Complément</label>
                            {{ form_widget(profileForm.adresse_complement, {'attr': {'class': 'w-full h-9 bg-white border border-slate-200 rounded-lg px-3 text-xs font-bold text-slate-700'}}) }}
                        </div>
                    </div>
                    <div class="hidden">{{ form_widget(profileForm.email) }}{{ form_widget(profileForm.client_number) }}{{ form_widget(profileForm.magasin) }}{{ form_widget(profileForm.civility) }}{{ form_widget(profileForm.nom) }}{{ form_widget(profileForm.prenom) }}{{ form_widget(profileForm.date_naissance) }}{{ form_rest(profileForm) }}</div>
                </div>
            </div>

            <!-- Actions Footer -->
            <div class="flex items-center justify-end gap-3 pt-2">
                <a href="{{ path('app_dashboard') }}" class="inline-flex items-center gap-2 bg-white border border-slate-300 text-slate-600 font-bold py-2 px-4 rounded-lg hover:bg-slate-50 hover:border-slate-400 transition-all text-xs uppercase tracking-wider shadow-sm">
                    Annuler
                </a>
                <button type="submit" class="inline-flex items-center gap-2 bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-2 px-4 rounded-lg transition-all text-xs uppercase tracking-wider shadow-sm">
                    <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"></path></svg>
                    Sauvegarder
                </button>
            </div>
        </div>
        {{ form_end(profileForm) }}

        <!-- Security Section -->
        <div class="px-3 sm:px-0 mt-4">
            <div class="bg-white border border-rose-200 rounded-xl overflow-hidden shadow-sm">
                <div class="px-4 py-3 border-b border-rose-100 bg-rose-50/50 flex items-center justify-between">
                    <h2 class="text-[9px] font-black text-slate-900 uppercase tracking-[0.15em] flex items-center gap-2">
                        <span class="w-1 h-3 bg-rose-500 rounded-full"></span>
                        Sécurité
                    </h2>
                    <span class="text-[8px] font-black uppercase tracking-widest px-2 py-0.5 bg-rose-500 text-white rounded">Zone Critique</span>
                </div>
                <div class="p-4">
                    {{ form_start(passwordForm) }}
                    <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
                        <div>
                            <label class="text-[7px] font-black text-slate-400 uppercase tracking-widest mb-1 block">Mot de passe Actuel</label>
                            <div class="relative">
                                {{ form_widget(passwordForm.currentPassword, {'attr': {'class': 'w-full h-9 bg-white border border-slate-200 rounded-lg px-3 text-xs font-bold text-slate-700 pr-10', 'placeholder': '••••••••'}}) }}
                                <button type="button" class="absolute right-2 top-1/2 -translate-y-1/2 w-6 h-6 flex items-center justify-center text-slate-400 hover:text-indigo-600 transition-colors" onclick="togglePassword('{{ passwordForm.currentPassword.vars.id }}', this)">
                                    <svg width="14" height="14" fill="none" class="eye-open" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg>
                                    <svg width="14" height="14" fill="none" class="eye-closed hidden" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l18 18"></path></svg>
                                </button>
                            </div>
                        </div>
                        <div>
                            <label class="text-[7px] font-black text-slate-400 uppercase tracking-widest mb-1 block">Nouveau</label>
                            <div class="relative">
                                {{ form_widget(passwordForm.newPassword.first, {'attr': {'class': 'w-full h-9 bg-white border border-slate-200 rounded-lg px-3 text-xs font-bold text-slate-700 pr-10', 'placeholder': '••••••••'}}) }}
                                <button type="button" class="absolute right-2 top-1/2 -translate-y-1/2 w-6 h-6 flex items-center justify-center text-slate-400 hover:text-indigo-600 transition-colors" onclick="togglePassword('{{ passwordForm.newPassword.first.vars.id }}', this)">
                                    <svg width="14" height="14" fill="none" class="eye-open" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg>
                                    <svg width="14" height="14" fill="none" class="eye-closed hidden" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l18 18"></path></svg>
                                </button>
                            </div>
                        </div>
                        <div>
                            <label class="text-[7px] font-black text-slate-400 uppercase tracking-widest mb-1 block">Confirmation</label>
                            <div class="relative">
                                {{ form_widget(passwordForm.newPassword.second, {'attr': {'class': 'w-full h-9 bg-white border border-slate-200 rounded-lg px-3 text-xs font-bold text-slate-700 pr-10', 'placeholder': '••••••••'}}) }}
                                <button type="button" class="absolute right-2 top-1/2 -translate-y-1/2 w-6 h-6 flex items-center justify-center text-slate-400 hover:text-indigo-600 transition-colors" onclick="togglePassword('{{ passwordForm.newPassword.second.vars.id }}', this)">
                                    <svg width="14" height="14" fill="none" class="eye-open" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg>
                                    <svg width="14" height="14" fill="none" class="eye-closed hidden" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l18 18"></path></svg>
                                </button>
                            </div>
                        </div>
                    </div>
                    <div class="flex items-center justify-end pt-4">
                        <button type="submit" class="inline-flex items-center gap-2 bg-white border border-rose-400 text-rose-600 hover:bg-rose-50 font-bold py-2 px-4 rounded-lg transition-all text-xs uppercase tracking-wider shadow-sm">
                            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
                            Changer le mot de passe
                        </button>
                    </div>
                    {{ form_end(passwordForm) }}
                </div>
            </div>
        </div>
    </div>

    <script>
        function toPascalCase(str) {
            if (!str) return str;
            return str.toLowerCase().replace(/\b\w/g, char => char.toUpperCase());
        }

        const nomField = document.getElementById('{{ profileForm.nom.vars.id }}');
        const prenomField = document.getElementById('{{ profileForm.prenom.vars.id }}');
        
        if (nomField) {
            nomField.addEventListener('blur', function() {
                this.value = toPascalCase(this.value);
            });
        }
        if (prenomField) {
            prenomField.addEventListener('blur', function() {
                this.value = toPascalCase(this.value);
            });
        }

        document.getElementById('profile-form').addEventListener('submit', function() {
            if (nomField) nomField.value = toPascalCase(nomField.value);
            if (prenomField) prenomField.value = toPascalCase(prenomField.value);
        });

        function handlePhotoSelect(input) {
            if (input.files && input.files[0]) {
                const file = input.files[0];
                const reader = new FileReader();
                reader.onload = function (e) {
                    const container = document.getElementById('photo-placeholder');
                    container.innerHTML = `<img src="${e.target.result}" class="w-full h-full object-cover">`;
                    container.classList.remove('border-dashed', 'bg-slate-100', 'text-slate-400');
                    container.classList.add('border-solid');
                };
                reader.readAsDataURL(file);
            }
        }

        function togglePassword(inputId, btn) {
            const input = document.getElementById(inputId);
            const eyeOpen = btn.querySelector('.eye-open');
            const eyeClosed = btn.querySelector('.eye-closed');
            if (input.type === 'password') {
                input.type = 'text';
                eyeOpen.classList.add('hidden');
                eyeClosed.classList.remove('hidden');
            } else {
                input.type = 'password';
                eyeOpen.classList.remove('hidden');
                eyeClosed.classList.add('hidden');
            }
        }
    </script>
</div>
{% endblock %}

