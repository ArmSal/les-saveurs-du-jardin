            if (document.getElementById('editHoraireModal').style.display === 'flex' && document.getElementById('editModalUser').value === activeUserIdForColor) {
                window.applyColorToModal('editModalUser', 'editModalColor');
            }

            document.getElementById('userColorPickerModal').classList.add('hidden');
            calendar.refetchEvents();
        }
    });
};

