magasinFilter.addEventListener('change', function () {
    const val = this.value;

    // Filter User Filter options
    for (let i = 0; i < userFilter.options.length; i++) {
        let opt = userFilter.options[i];
        if (!opt.value) continue;
        let optMagasin = opt.getAttribute('data-magasin');
        if (!val || optMagasin === val) {
            opt.style.display = '';
        } else {
            opt.style.display = 'none';
        }
    }

    // Reset userFilter if current selection is hidden
    if (userFilter.value) {
        let currentOpt = userFilter.options[userFilter.selectedIndex];
        if (currentOpt.style.display === 'none') {
            userFilter.value = '';
        }
    }

    // Filter Sidebar Personnel
    document.querySelectorAll('.employee-item').forEach(item => {
        if (!val || item.dataset.magasin === val) {
            item.style.display = 'flex';
        } else {
            item.style.display = 'none';
        }
    });

    calendar.refetchEvents();

    // Update week lock status for new magasin selection
    if (canLockWeeks && (window.calendar.view.type === 'timeGridWeek' || window.calendar.view.type === 'timeGridDay')) {
        const weekNo = getCustomWeekNumber(window.calendar.view.currentStart);
        
        // Effective year
        const sun = new Date(window.calendar.view.currentStart);
        sun.setDate(sun.getDate() + 6);
        const year = sun.getFullYear();

        if (val) {
            fetchWeekLockStatus(weekNo, year, val);
        } else {
            updateWeekLockUI();
        }
    }
});

