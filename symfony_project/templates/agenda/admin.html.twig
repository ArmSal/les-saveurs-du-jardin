{% block javascripts %}
	<script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.11/index.global.min.js"></script>
	<script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.11/locales/fr.global.min.js"></script>
	<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
	<script>
		document.addEventListener('DOMContentLoaded', function () {
var calendarEl = document.getElementById('calendar');
var userFilter = document.getElementById('userFilter');
var magasinFilter = document.getElementById('magasinFilter');
var chart = null;
var currentEvents = [];
var canLockWeeks = {{ canLockWeeks ? 'true' : 'false' }};
var isMagasinOnly = {{ isMagasinOnly ? 'true' : 'false' }};


function setModalTimeInputs(dtStr, prefix) {
    if (!dtStr) return;
    var dt = new Date(dtStr);
    var yyyy = dt.getFullYear();
    var mm = String(dt.getMonth() + 1).padStart(2, '0');
    var dd = String(dt.getDate()).padStart(2, '0');
    var h = String(dt.getHours()).padStart(2, '0');
    var min = String(dt.getMinutes()).padStart(2, '0');
    if (!['00', '15', '30', '45'].includes(min)) min = '00';

    document.getElementById(prefix + 'Date').value = yyyy + '-' + mm + '-' + dd;
    document.getElementById(prefix + 'Hour').value = h;
    document.getElementById(prefix + 'Minute').value = min;
}

function getCustomWeekNumber(date) {
    const d = new Date(date);
    d.setHours(0,0,0,0);
    // Find Monday of current week
    d.setDate(d.getDate() - (d.getDay() || 7) + 1);
    
    // Effective year: the year of the Sunday of this week
    const sun = new Date(d);
    sun.setDate(d.getDate() + 6);
    const year = sun.getFullYear();

    const jan1 = new Date(year, 0, 1);
    const mondayW1 = new Date(jan1);
    mondayW1.setDate(jan1.getDate() - (jan1.getDay() || 7) + 1);
    
    const diff = d - mondayW1;
    return 1 + Math.round(diff / (7 * 86400000));
}

// Week lock state
var currentWeekLock = { week: null, year: null, isLocked: true, magasin: null };

function updateWeekLockUI() {
    const container = document.getElementById('weekLockContainer');
    const toggleBtn = document.getElementById('weekLockToggle');
    const icon = document.getElementById('weekLockIcon');
    const text = document.getElementById('weekLockText');

    if (!container || !toggleBtn) return;

    // The button is now always shown, but its clickability and appearance change
    // Allow interactivity in both Week and Day views (useful for mobile)
    const isWeekOrDayView = window.calendar.view.type === 'timeGridWeek' || window.calendar.view.type === 'timeGridDay';
    const hasMagasin = !!document.getElementById('magasinFilter').value;
    const isInteractive = isWeekOrDayView && hasMagasin;

    if (currentWeekLock.isLocked) {
        icon.textContent = '🔒';
        text.textContent = 'Non Visible';
        toggleBtn.className = 'w-full px-4 py-2 rounded-lg font-bold text-[10px] uppercase tracking-widest flex items-center justify-center gap-2 transition-all shadow-sm border h-[42px] bg-red-50 border-red-200 text-red-600' + (isInteractive ? ' cursor-pointer hover:bg-red-100' : ' grayscale opacity-60 cursor-not-allowed');
    } else {
        icon.textContent = '👁️';
        text.textContent = 'Visible';
        toggleBtn.className = 'w-full px-4 py-2 rounded-lg font-bold text-[10px] uppercase tracking-widest flex items-center justify-center gap-2 transition-all shadow-sm border h-[42px] bg-emerald-50 border-emerald-200 text-emerald-600' + (isInteractive ? ' cursor-pointer hover:bg-emerald-100' : ' grayscale opacity-60 cursor-not-allowed');
    }
    
    toggleBtn.style.pointerEvents = isInteractive ? 'auto' : 'none';
}

function fetchWeekLockStatus(week, year, magasin) {
    if (!magasin) return;

    const cleanMagasin = magasin.trim();
    const url = '{{ path("app_agenda_api_week_lock_status") }}?week=' + week + '&year=' + year + '&magasin=' + encodeURIComponent(cleanMagasin);
    fetch(url)
        .then(response => response.json())
        .then(data => {
            currentWeekLock.week = week;
            currentWeekLock.year = year;
            currentWeekLock.magasin = magasin;
            currentWeekLock.isLocked = data.isLocked || false;
            updateWeekLockUI();
        })
        .catch(err => console.error('Failed to fetch week lock status:', err));
}

function toggleWeekLock() {
    if (!currentWeekLock.week || !currentWeekLock.magasin) {
        showToast('Veuillez sélectionner un magasin et être en vue semaine', 'error');
        return;
    }

    const cleanMagasin = currentWeekLock.magasin.trim();
    const url = '{{ path("app_agenda_api_week_lock_toggle") }}';
    
    fetch(url, {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json'
        },
        body: JSON.stringify({
            week: currentWeekLock.week,
            year: currentWeekLock.year,
            magasin: cleanMagasin
        })
    })
    .then(response => {
        if (!response.ok) throw new Error('Network response was not ok');
        return response.json();
    })
    .then(data => {
        if (data.success) {
            currentWeekLock.isLocked = data.isLocked;
            updateWeekLockUI();
            showToast(data.isLocked ? 'Planning désormais Non Visible' : 'Planning désormais Visible', 'success');
            // Refresh calendar to hide/show events for read-only users
            window.calendar.refetchEvents();
        } else {
            showToast(data.error || 'Erreur', 'error');
        }
    })
    .catch(err => {
        console.error('Failed to toggle week lock:', err);
        showToast('Erreur lors du verrouillage', 'error');
    });
}

window.calendar = new FullCalendar.Calendar(calendarEl, {
localeDefs: [
{
code: 'fr'
}
],
locale: 'fr',
firstDay: 1, // Lundi
weekNumberCalculation: getCustomWeekNumber,
buttonText: {
today: "Aujourd'hui",
month: 'Mois',
week: 'Semaine',
day: 'Jour',
list: 'Agenda'
},
initialView: window.innerWidth < 768 ? 'timeGridDay' : 'timeGridWeek',
headerToolbar: {
left: window.innerWidth < 768 ? 'prev,next' : 'prev,next today',
center: 'title',
right: window.innerWidth < 768 ? 'dayGridMonth,timeGridDay' : 'dayGridMonth,timeGridWeek,timeGridDay'
},
datesSet: function (info) {
    if (typeof updateChart === 'function') setTimeout(updateChart, 50);

    setTimeout(() => {
        const titleEl = document.querySelector('.fc-toolbar-title');
        if (titleEl) {
            let text = info.view.title;
            if (info.view.type === 'timeGridWeek' || info.view.type === 'timeGridDay') {
                const weekNo = getCustomWeekNumber(info.view.currentStart);
                text = text + ' (S' + weekNo + ')';
            }
            text = text.replace(/\b(janvier|février|mars|avril|mai|juin|juillet|août|septembre|octobre|novembre|décembre)\b/gi, function(match) {
                return match.charAt(0).toUpperCase() + match.slice(1);
            });
            titleEl.innerText = text;
        }
    }, 10);

    // Fetch week lock status for week or day views
    if (canLockWeeks && (info.view.type === 'timeGridWeek' || info.view.type === 'timeGridDay')) {
        const weekNo = getCustomWeekNumber(info.view.currentStart);
        
        // Effective year should be based on Sunday of that week
        const sun = new Date(info.view.currentStart);
        sun.setDate(sun.getDate() + 6);
        const year = sun.getFullYear();

        let currentMagasin = document.getElementById('magasinFilter').value;
        {% if isMagasinOnly %}
        if (!currentMagasin) {
            const firstOption = document.querySelector('#magasinFilter option:not([value=""])');
            currentMagasin = firstOption ? firstOption.value : '';
        }
        {% endif %}
        
        if (currentMagasin) {
            fetchWeekLockStatus(weekNo, year, currentMagasin);
        } else {
            updateWeekLockUI();
        }
    } else if (canLockWeeks) {
        updateWeekLockUI();
    }
},
eventContent: function(arg) {
    if (arg.event.extendedProps.isBirthday || arg.event.extendedProps.isHoliday) {
        return {
            html: `<div class="fc-content p-1 text-[11px] leading-tight text-white overflow-hidden text-center font-bold">
                ${arg.event.title}
            </div>`
        };
    }

    const formatTime = (date) => {
        if (!date) return '';
        const h = String(date.getHours()).padStart(2, '0');
        const m = String(date.getMinutes()).padStart(2, '0');
        return `${h}h${m}`;
    };
    let startTime = formatTime(arg.event.start);
    let endTime = formatTime(arg.event.end);
    let name = (arg.event.extendedProps.prenom || '') + ' ' + (arg.event.extendedProps.nom || '');
    let status = arg.event.extendedProps.status;
    let note = arg.event.extendedProps.note;

    let timeHtml = arg.event.allDay ? '' : `<div class="font-bold border-b border-white/20 mb-0.5 pb-0.5">${startTime} - ${endTime}</div>`;

    let isLocked = arg.event.extendedProps.isLocked;
    let html = `
        <div class="fc-content p-1 text-[10px] leading-tight text-slate-900 overflow-hidden ${isLocked ? 'opacity-50 cursor-not-allowed' : ''}">
            ${timeHtml}
            <div class="truncate font-medium flex items-center gap-1">
                ${name}${(status && status !== 'Actif') ? ` - <span class="italic opacity-90">${status}</span>` : ''}
                ${isLocked ? '<svg class="w-2 h-2 text-slate-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd"></path></svg>' : ''}
            </div>
            ${note ? `<div class="opacity-75 text-[9px] mt-0.5 italic truncate">${note}</div>` : ''}
        </div>
    `;
    return { html: html };
},
slotMinTime: '06:00:00',
slotMaxTime: '20:00:00',
slotDuration: '00:15:00',
slotLabelInterval: '01:00',
snapDuration: '00:15:00',
allDaySlot: true,
editable: {{ canEdit ? 'true' : 'false' }},
selectable: {{ canEdit ? 'true' : 'false' }},
selectMirror: true,
height: 'auto',
contentHeight: 'auto',
windowResize: function (arg) {
if (window.innerWidth < 768) {
calendar.changeView('timeGridDay');
calendar.setOption('headerToolbar', {
left: 'prev,next',
center: 'title',
right: 'dayGridMonth,timeGridDay'
});
} else {
calendar.changeView('timeGridWeek');
calendar.setOption('headerToolbar', {
left: 'prev,next today',
center: 'title',
right: 'dayGridMonth,timeGridWeek,timeGridDay'
});
}
},
events: function (info, successCallback, failureCallback) {
var url = '{{ path("app_agenda_api_events") }}';
var params = new URLSearchParams();
if (userFilter.value) 
params.append('user_id', userFilter.value);



if (magasinFilter.value) 
params.append('magasin', magasinFilter.value);

params.append('start', info.startStr);
params.append('end', info.endStr);

fetch(url + '?' + params.toString()).then(response => response.json()).then(data => {
            currentEvents = data;
            successCallback(data);
            setTimeout(updateChart, 50);
        }).catch(error => failureCallback(error));
},
select: function (info) {
    let startStr = info.startStr;
    let endStr = info.endStr;

    // For all-day selections, FullCalendar gives us an exclusive end date (next day).
    // We adjust it here so the modal shows the intuitive inclusive date range.
    if (info.allDay) {
        let endDt = new Date(info.end);
        endDt.setDate(endDt.getDate() - 1);
        
        let yyyy = endDt.getFullYear();
        let mm = String(endDt.getMonth() + 1).padStart(2, '0');
        let dd = String(endDt.getDate()).padStart(2, '0');
        endStr = yyyy + '-' + mm + '-' + dd;
    }

    setModalTimeInputs(startStr, 'modalStart');
    setModalTimeInputs(endStr, 'modalEnd');
    openAddModalPopup();
    calendar.unselect();
},
eventClick: function (info) {
    if (!{{ canEdit ? 'true' : 'false' }}) 
        return;

    if (info.event.extendedProps.isLocked) {
        showToast('Cet horaire est verrouillé.', 'error');
        return;
    }



window.eventToEdit = info.event;

var currentMagasin = document.getElementById('magasinFilter').value;
filterSelectByMagasin('editModalUser', currentMagasin);

document.getElementById('editModalUser').value = info.event.extendedProps.user_id;

// Fill Date/Time fields
setModalTimeInputs(info.event.start, 'editModalStart');
setModalTimeInputs(info.event.end, 'editModalEnd');

// If the selected user was hidden by the filter (because magasin doesn't match), make sure we still show it so we don't change it accidentally to someone else just by clicking
var opt = document.getElementById('editModalUser').options[document.getElementById('editModalUser').selectedIndex];
if (opt && opt.style.display === 'none') {
    opt.style.display = '';
}

var currentColor = info.event.backgroundColor || info.event.extendedProps.color || '#4f46e5';
document.getElementById('editModalColor').value = currentColor;
document.getElementById('editModalAllDay').checked = !!info.event.allDay;
document.getElementById('editModalStatus').querySelector('option[value="Actif"]').disabled = !!info.event.allDay;
document.querySelectorAll('.edit-modal-swatch').forEach(s => {
s.classList.remove('ring-2', 'ring-slate-900', 'ring-offset-2', 'scale-110');
if (s.dataset.val.toLowerCase() === currentColor.toLowerCase()) {
s.classList.add('ring-2', 'ring-slate-900', 'ring-offset-2', 'scale-110');
}
});
var isLocked = !!info.event.extendedProps.isLocked;
document.getElementById('editModalStatus').value = info.event.extendedProps.status || 'Actif';
document.getElementById('editModalNote').value = info.event.extendedProps.note || '';

// Handle Lock State
const btnUpdate = document.getElementById('btnUpdateHoraire');
const btnDelete = document.getElementById('btnInitDelete');

btnUpdate.style.display = '';
btnDelete.style.display = '';
document.querySelectorAll('#editHoraireModal input, #editHoraireModal select').forEach(el => el.disabled = false);

document.getElementById('editHoraireModal').style.display = 'flex';
},
eventDrop: function (info) {

    // Auto-change status if dragged to all-day and currently Actif
    if (info.event.allDay && info.event.extendedProps.status === 'Actif') {
        info.event.setExtendedProp('status', 'Autre');
    }

    updateEventApi(info.event, info);
},
eventResize: function (info) {
    updateEventApi(info.event, info);
}
});

window.toggleTimeRange = function(mode) {
    const btnBusiness = document.getElementById('timeRangeBusiness');
    const btnFull = document.getElementById('timeRangeFull');
    
    if (mode === 'business') {
        calendar.setOption('slotMinTime', '06:00:00');
        calendar.setOption('slotMaxTime', '20:00:00');
        btnBusiness.className = 'flex-1 px-2 py-2 text-[10px] font-black uppercase tracking-widest rounded-lg transition-all bg-white text-indigo-600 shadow-sm border border-slate-200 whitespace-nowrap min-w-fit';
        btnFull.className = 'flex-1 px-3 py-2 text-[10px] font-black uppercase tracking-widest rounded-lg transition-all text-slate-500 hover:text-slate-700 whitespace-nowrap min-w-fit';
    } else {
        calendar.setOption('slotMinTime', '00:00:00');
        calendar.setOption('slotMaxTime', '24:00:00');
        btnFull.className = 'flex-1 px-3 py-2 text-[10px] font-black uppercase tracking-widest rounded-lg transition-all bg-white text-indigo-600 shadow-sm border border-slate-200 whitespace-nowrap min-w-fit';
        btnBusiness.className = 'flex-1 px-2 py-2 text-[10px] font-black uppercase tracking-widest rounded-lg transition-all text-slate-500 hover:text-slate-700 whitespace-nowrap min-w-fit';
    }
};

function updateEventApi(event, info = null) {
    const payload = {
        start: event.startStr, 
        end: event.endStr,
        status: event.extendedProps.status
    };

    fetch('{{ path("app_agenda_api_update", {id: "ID_PLACEHOLDER"}) }}'.replace('ID_PLACEHOLDER', event.id), {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
        }).then(response => response.json()).then(data => {
            if (!data.success) {
                showToast(data.error || 'Erreur lors de la mise à jour');
                if (info && info.revert) info.revert();
                calendar.refetchEvents();
            } else {
                setTimeout(updateChart, 50);
            }
        });
}

calendar.render();

