function updateChart() {
    if (typeof calendar === 'undefined' || !calendar) return;

    var hoursByUser = {};
    var hoursByUserId = {};

    var viewStart = calendar.view.activeStart;
    var viewEnd = calendar.view.activeEnd;

    calendar.getEvents().forEach(function (event) {
        const status = event.extendedProps.status;
        // Only count 'Actif' or empty status
        if (status && status !== 'Actif') return;

        var evStart = event.start;
        var evEnd = event.end || event.start;
        if (!evStart || !evEnd) return;

        var calcStart = evStart > viewStart ? evStart : viewStart;
        var calcEnd = evEnd < viewEnd ? evEnd : viewEnd;

        if (calcStart < calcEnd) {
            var hours = (calcEnd - calcStart) / (1000 * 60 * 60);
            var userName = (event.extendedProps.prenom || '') + ' ' + (event.extendedProps.nom || '');
            var userId = event.extendedProps.user_id;

            if (hoursByUser[userName]) {
                hoursByUser[userName] += hours;
            } else {
                hoursByUser[userName] = hours;
            }
            
            if (hoursByUserId[userId]) {
                hoursByUserId[userId] += hours;
            } else {
                hoursByUserId[userId] = hours;
            }
        }
    });

document.querySelectorAll('.employee-hours').forEach(el => {
    let uid = el.dataset.userId;
    let totalH = hoursByUserId[uid] || 0;
    let dH = Math.floor(totalH);
    let dM = Math.round((totalH - dH) * 60);
    if (dM === 60) { dH++; dM = 0; }
    el.textContent = dH + 'h' + (dM < 10 ? '0' : '') + dM;
});

var labels = Object.keys(hoursByUser);
var chartData = Object.values(hoursByUser);

var ctx = document.getElementById('horairesChart').getContext('2d');

if (chart) {
chart.destroy();
}

chart = new Chart(ctx, {
type: 'bar',
data: {
labels: labels,
datasets: [
{
label: 'Heures planifiées',
data: chartData,
backgroundColor: 'rgba(79, 70, 229, 0.5)',
borderColor: 'rgb(79, 70, 229)',
borderWidth: 1
}
]
},
options: {
responsive: true,
maintainAspectRatio: false,
scales: {
y: {
beginAtZero: true,
title: {
display: true,
text: 'Heures'
}
}
}
}
});
}
});
	window.openPrintPdf = function() {
    try {
        console.log('openPrintPdf called');
        
        // Get current filters
        const magasin = document.getElementById('magasinFilter').value;
        const userId = document.getElementById('userFilter').value;
        
        console.log('Filters:', { magasin, userId });
        console.log('Calendar:', calendar);
        console.log('Calendar view:', calendar ? calendar.view : null);
        
        // Get current calendar view dates - format as YYYY-MM-DD in local timezone
        const viewStart = calendar.view.activeStart;
        const viewEnd = calendar.view.activeEnd;
        
        console.log('View dates:', { viewStart, viewEnd });
        
        // Format dates using local timezone to avoid UTC conversion issues
        const formatDateLocal = (date) => {
            const year = date.getFullYear();
            const month = String(date.getMonth() + 1).padStart(2, '0');
            const day = String(date.getDate()).padStart(2, '0');
            return `${year}-${month}-${day}`;
        };
        
        const startStr = formatDateLocal(viewStart);
        const endStr = formatDateLocal(viewEnd);
        
        // Build URL with filters
        let url = '{{ path("app_agenda_export_calendar") }}';
        const params = new URLSearchParams();
        params.append('start', startStr);
        params.append('end', endStr);
        
        if (magasin) {
            params.append('magasin', magasin);
        }
        if (userId) {
            params.append('user_id', userId);
        }
        
        url += '?' + params.toString();
        console.log('Opening URL:', url);
        
        // Open PDF in new tab
        window.open(url, '_blank');
    } catch (err) {
        console.error('Error in openPrintPdf:', err);
        alert('Erreur: ' + err.message);
    }
};

