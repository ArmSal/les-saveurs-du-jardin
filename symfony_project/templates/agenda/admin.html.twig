{% extends 'base.html.twig' %}

{% block title %}Agenda Employés
{% endblock %}

{% block stylesheets %}
	{{ parent() }}
	<link href="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.11/main.min.css" rel="stylesheet"/>
	<style>
		@media(max-width: 767px) {
			.fc .fc-toolbar-title {
				font-size: 0.95rem !important;
				font-weight: 800 !important;
				line-height: 1.2;
			}
			.fc .fc-toolbar {
				flex-direction: column;
				gap: 8px;
			}
			.fc .fc-toolbar-chunk {
				display: flex;
				justify-content: center;
				width: 100%;
			}
		}

		@media print {
			@page {
				size: landscape;
				margin: 5mm;
			}

			/* Hide non-essential page elements */
			nav, 
			.mb-8,
			.flex.flex-col.md\:flex-row.gap-4.mb-6,
			aside.w-full.lg\:w-72,
			#addHoraireModal,
			#editHoraireModal,
			#duplicateWeekModal,
			#userColorPickerModal,
			#toastContainer,
			.mt-8.bg-white,
			button {
				display: none !important;
			}

			/* Reset body */
			body {
				background: white !important;
				-webkit-print-color-adjust: exact !important;
				print-color-adjust: exact !important;
			}

			/* Ensure containers visible */
			.container, main, .flex.flex-col.lg\:flex-row.gap-6 {
				display: block !important;
				width: 100% !important;
				max-width: 100% !important;
				margin: 0 !important;
				padding: 0 !important;
			}

			/* Calendar container */
			#calendar {
				display: block !important;
				width: 100% !important;
				visibility: visible !important;
				overflow: visible !important;
				background: white !important;
				padding: 0 !important;
				border: none !important;
				box-shadow: none !important;
			}

			/* === AGGRESSIVE FULLCALENDAR PRINT FIXES === */
			.fc,
			.fc-view,
			.fc-view-harness,
			.fc-view-harness-active,
			.fc-timegrid,
			.fc-timegrid-body,
			.fc-timegrid-slots,
			.fc-timegrid-cols,
			.fc-timegrid-col,
			.fc-timegrid-col-frame,
			.fc-timegrid-col-events,
			.fc-timegrid-event-harness,
			.fc-scrollgrid,
			.fc-scrollgrid-section,
			.fc-scroller,
			.fc-scroller-liquid-absolute,
			.fc-scroller-harness,
			.fc-scroller-harness-liquid,
			.fc-timegrid-slot,
			.fc-timegrid-slot-label,
			.fc-col-header-cell,
			.fc-col-header-cell-cushion,
			.fc-timegrid-axis,
			.fc-timegrid-axis-frame,
			.fc-timegrid-axis-cushion {
				display: block !important;
				visibility: visible !important;
				opacity: 1 !important;
				overflow: visible !important;
				position: relative !important;
				float: none !important;
				clip: auto !important;
				z-index: auto !important;
			}

			/* Force view harness to expand */
			.fc-view-harness,
			.fc-view-harness-active {
				height: auto !important;
				min-height: 800px !important;
			}

			/* Make tables visible */
			.fc table,
			.fc thead,
			.fc tbody,
			.fc tr,
			.fc td,
			.fc th {
				display: table !important;
				visibility: visible !important;
				border-color: #999 !important;
			}

			.fc tr {
				display: table-row !important;
			}

			.fc td,
			.fc th {
				display: table-cell !important;
			}

			/* Events */
			.fc-event,
			.fc-event-main,
			.fc-event-main-frame,
			.fc-v-event,
			.fc-timegrid-event {
				display: block !important;
				visibility: visible !important;
				opacity: 1 !important;
				print-color-adjust: exact !important;
				-webkit-print-color-adjust: exact !important;
				position: relative !important;
			}

			/* Keep toolbar for context */
			.fc-toolbar {
				display: flex !important;
				visibility: visible !important;
				margin-bottom: 10px !important;
				page-break-after: avoid !important;
			}

			.fc-toolbar-chunk {
				display: inline-block !important;
			}

			/* Ensure proper sizing */
			.fc-timegrid-col {
				width: auto !important;
				min-width: 100px !important;
			}

			/* Background colors for print */
			.fc-event {
				background-color: inherit !important;
				border: 1px solid #333 !important;
			}
		}
	</style>
{% endblock %}

{% block body %}
	{% set palette_colors = ['#ef4444', '#f97316', '#f59e0b', '#eab308', '#84cc16', '#22c55e', '#10b981', '#14b8a6', '#06b6d4', '#0ea5e9', '#3b82f6', '#4f46e5', '#8b5cf6', '#a855f7', '#d946ef', '#ec4899', '#f43f5e', '#64748b', '#71717a', '#a1a1aa'] %}
	<div class="mb-8 flex flex-col md:flex-row md:items-center justify-between gap-6">
		<div>
			<h1 class="text-3xl md:text-4xl font-black text-slate-900 mb-2 tracking-tight">Gestion des Horaires</h1>
			<p class="text-slate-500 font-medium flex items-center gap-2">
                <span class="w-2 h-2 bg-emerald-500 rounded-full"></span>
                Planification et suivi du personnel par magasin
            </p>
		</div>
	</div>
	<div class="flex flex-col xl:flex-row gap-4 mb-6 bg-white p-4 md:p-6 rounded-xl shadow-sm border border-slate-200 items-stretch xl:items-end">
		<div class="grid grid-cols-1 lg:grid-cols-2 xl:flex xl:flex-row flex-1 gap-4 items-end">
			<div class="flex-1 min-w-[200px]" {{ isMagasinOnly ? 'style="display:none;"' : '' }}>
				<label class="block text-xs font-bold uppercase tracking-wider text-slate-500 mb-1.5 ml-1">Magasin</label>
				<select id="magasinFilter" class="w-full px-3 py-2.5 text-sm border border-slate-200 rounded-lg focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 outline-none bg-slate-50 transition-all font-semibold text-slate-700">
					<option value="">Tous les magasins</option>
					{% set magasins = [] %}
					{% for employe in employes %}
						{% if employe.magasin not in magasins %}
							{% set magasins = magasins|merge([employe.magasin]) %}
							<option value="{{ employe.magasin }}" {{ isMagasinOnly and employe.magasin == app.user.magasin ? 'selected' : '' }}>{{ employe.magasin }}</option>
						{% endif %}
					{% endfor %}
				</select>
			</div>

			<div class="flex-1 min-w-[200px]">
				<label class="block text-xs font-bold uppercase tracking-wider text-slate-500 mb-1.5 ml-1">Employé</label>
				<select id="userFilter" class="w-full px-3 py-2.5 text-sm border border-slate-200 rounded-lg focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 outline-none bg-slate-50 transition-all font-semibold text-slate-700">
					<option value="">Tous les employés</option>
					{% for employe in employes %}
						<option value="{{ employe.id }}" data-magasin="{{ employe.magasin }}">{{ employe.prenom }}
							{{ employe.nom }}
							({{ employe.magasin }})</option>
					{% endfor %}
				</select>
			</div>

			<div class="grid grid-cols-2 xl:flex xl:flex-row gap-4 flex-none items-end">
				<div class="flex-1">
					<label class="block text-xs font-bold uppercase tracking-wider text-slate-500 mb-1.5 ml-1">Affichage</label>
					<div class="flex items-center bg-slate-100 p-1 rounded-xl w-full xl:w-fit">
						<button type="button" id="timeRangeBusiness" onclick="toggleTimeRange('business')" class="flex-1 px-2 py-2 text-[10px] font-black uppercase tracking-widest rounded-lg transition-all bg-white text-indigo-600 shadow-sm border border-slate-200 whitespace-nowrap min-w-fit">
							6H - 20H
						</button>
						<button type="button" id="timeRangeFull" onclick="toggleTimeRange('full')" class="flex-1 px-3 py-2 text-[10px] font-black uppercase tracking-widest rounded-lg transition-all text-slate-500 hover:text-slate-700 whitespace-nowrap min-w-fit">
							24H
						</button>
					</div>
				</div>

				{% if canLockWeeks %}
				<div class="flex-1" id="weekLockContainer">
					<label class="block text-xs font-bold uppercase tracking-wider text-slate-500 mb-1.5 ml-1">Visibilité Planning</label>
					<button type="button" id="weekLockToggle" class="w-full px-4 py-2 rounded-lg font-bold text-[10px] uppercase tracking-widest flex items-center justify-center gap-2 transition-all shadow-sm border h-[42px] bg-red-50 border-red-200 text-red-600" style="position: relative; z-index: 10;">
						<span id="weekLockIcon">🔒</span>
						<span id="weekLockText">Non Visible</span>
					</button>
				</div>
				{% endif %}
			</div>
		</div>

		<div class="flex flex-col gap-2 pt-4 xl:pt-0 border-t xl:border-t-0 border-slate-100 mt-2 xl:mt-0">
			<div class="grid grid-cols-2 xl:flex xl:flex-row gap-2">
				{% if canViewObservations %}
					<a href="{{ path('app_user_observations_index') }}" class="w-full h-[42px] bg-amber-50 border border-amber-200 hover:bg-amber-100 text-amber-700 px-5 py-2 rounded-lg font-bold text-[10px] uppercase tracking-widest flex items-center justify-center gap-2 transition-all shadow-sm">
						<svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"></path>
						</svg>
						Observations
					</a>
				{% endif %}

				<button class="w-full h-[42px] bg-white border border-slate-200 hover:bg-slate-50 text-slate-700 px-5 py-2 rounded-lg font-bold text-[10px] uppercase tracking-widest flex items-center justify-center gap-2 transition-all shadow-sm" onclick="openPrintPdf()">
					<svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"></path>
					</svg>
					Imprimer
				</button>
			</div>
			
			<div class="grid grid-cols-2 xl:flex xl:flex-row gap-2">
				{% if canEdit %}
					<button class="w-full h-[42px] bg-indigo-600 hover:bg-indigo-700 text-white px-5 py-2 rounded-lg font-bold text-[10px] uppercase tracking-widest flex items-center justify-center gap-2 transition-all shadow-lg shadow-indigo-200" onclick="openAddModalPopup()">
						<svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"></path>
						</svg>
						Ajouter un horaire
					</button>
				{% endif %}

				{% if canEdit %}
					<button class="w-full h-[42px] bg-slate-100 border border-slate-200 hover:bg-slate-200 text-slate-700 px-5 py-2 rounded-lg font-bold text-[10px] uppercase tracking-widest flex items-center justify-center gap-2 transition-all shadow-sm" onclick="openDuplicateModal()">
						<svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" d="M8 7v8a2 2 0 002 2h6M8 7V5a2 2 0 012-2h4.586a1 1 0 01.707.293l4.414 4.414a1 1 0 01.293.707V15a2 2 0 01-2 2h-2M8 7H6a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2v-2"></path>
						</svg>
						Dupliquer
					</button>
				{% endif %}
			</div>
		</div>
	</div>

	<!-- Add Modal -->
	<div id="addHoraireModal" style="display:none;" class="fixed inset-0 w-full h-full bg-black/50 backdrop-blur-sm z-[9999] items-center justify-center p-4">
		<div class="bg-white p-5 md:p-6 rounded-xl w-full max-w-lg shadow-2xl max-h-[90vh] overflow-y-auto">
			<h3 class="text-xl font-bold text-slate-900 mb-5">Ajouter un Horaire</h3>
			<div>
				<label class="block text-sm font-semibold mb-1 text-slate-700">Employé</label>
				<select id="modalUser" class="w-full px-3 py-2 text-sm border border-slate-300 rounded-md focus:ring-2 focus:ring-indigo-500 outline-none bg-white mb-4">
					{% for employe in employes %}
						<option value="{{ employe.id }}" data-magasin="{{ employe.magasin }}" data-color="{{ employe.calendarColor ?: '#4f46e5' }}">{{ employe.prenom }}
							{{ employe.nom }}
							({{ employe.magasin }})</option>
					{% endfor %}
				</select>

				<div class="mb-4 flex items-center gap-2">
					<input type="checkbox" id="addAllDay" class="w-4 h-4 text-indigo-600 border-slate-300 rounded focus:ring-indigo-500">
					<label for="addAllDay" class="text-sm font-medium text-slate-700 cursor-pointer">Toute la journée (En haut du planning)</label>
				</div>

				<label class="block text-xs font-semibold mb-1 text-slate-500 uppercase tracking-wide">Début</label>
				<div class="grid grid-cols-[1fr_auto_auto] gap-1.5 mb-4">
					<div>
						<div class="text-[10px] text-slate-400 font-bold uppercase mb-0.5">Date</div>
						<input type="date" id="modalStartDate" class="w-full h-9 px-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-indigo-500 outline-none text-sm">
					</div>
					<div style="min-width:60px;">
						<div class="text-[10px] text-slate-400 font-bold uppercase mb-0.5">Heure</div>
						<select id="modalStartHour" class="w-full h-9 px-1 border border-slate-300 rounded-lg focus:ring-2 focus:ring-indigo-500 outline-none text-sm bg-white">
							{% for i in 0..23 %}
								<option value="{{ '%02d'|format(i) }}">{{ '%02d'|format(i) }}h</option>
							{% endfor %}
						</select>
					</div>
					<div style="min-width:60px;">
						<div class="text-[10px] text-slate-400 font-bold uppercase mb-0.5">Min</div>
						<select id="modalStartMinute" class="w-full h-9 px-1 border border-slate-300 rounded-lg focus:ring-2 focus:ring-indigo-500 outline-none text-sm bg-white">
							<option value="00">00</option>
							<option value="15">15</option>
							<option value="30">30</option>
							<option value="45">45</option>
						</select>
					</div>
				</div>

				<label class="block text-xs font-semibold mb-1 text-slate-500 uppercase tracking-wide">Fin</label>
				<div class="grid grid-cols-[1fr_auto_auto] gap-1.5 mb-4">
					<div>
						<div class="text-[10px] text-slate-400 font-bold uppercase mb-0.5">Date</div>
						<input type="date" id="modalEndDate" class="w-full h-9 px-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-indigo-500 outline-none text-sm">
					</div>
					<div style="min-width:60px;">
						<div class="text-[10px] text-slate-400 font-bold uppercase mb-0.5">Heure</div>
						<select id="modalEndHour" class="w-full h-9 px-1 border border-slate-300 rounded-lg focus:ring-2 focus:ring-indigo-500 outline-none text-sm bg-white">
							{% for i in 0..23 %}
								<option value="{{ '%02d'|format(i) }}">{{ '%02d'|format(i) }}h</option>
							{% endfor %}
						</select>
					</div>
					<div style="min-width:60px;">
						<div class="text-[10px] text-slate-400 font-bold uppercase mb-0.5">Min</div>
						<select id="modalEndMinute" class="w-full h-9 px-1 border border-slate-300 rounded-lg focus:ring-2 focus:ring-indigo-500 outline-none text-sm bg-white">
							<option value="00">00</option>
							<option value="15">15</option>
							<option value="30">30</option>
							<option value="45">45</option>
						</select>
					</div>
				</div>

				<label class="block text-sm font-semibold mb-1 text-slate-700">Type d'absence / Statut</label>
				<select id="modalStatus" class="w-full px-3 py-2 text-sm border border-slate-300 rounded-md focus:ring-2 focus:ring-indigo-500 outline-none bg-white mb-4">
					<option value="Actif">Actif</option>
					<option value="CFA - Ecole">CFA - Ecole</option>
					<option value="Congé Payé">Congé Payé</option>
					<option value="Congé sans solde">Congé sans solde</option>
					<option value="Absence injustifiée">Absence injustifiée</option>
					<option value="Arret de travail">Arret de travail</option>
					<option value="Accident de travail">Accident de travail</option>
					<option value="Congé Parental">Congé Parental</option>
					<option value="Autre">Autre</option>
				</select>

				<label class="block text-sm font-semibold mb-1 text-slate-700">Note (ex: Caisse, Réserve...)</label>
				<input type="text" id="modalNote" placeholder="Optionnel" class="w-full px-3 py-2 text-sm border border-slate-300 rounded-md focus:ring-2 focus:ring-indigo-500 outline-none mb-4">

				<input type="hidden" id="modalColor" value="">

				<div class="flex flex-col sm:flex-row gap-3 justify-end mt-4">
					<button type="button" class="w-full sm:w-auto px-4 py-2 bg-white border border-slate-300 text-slate-700 rounded-md hover:bg-slate-50 font-semibold transition-colors" onclick="document.getElementById('addHoraireModal').style.display='none'">Annuler</button>
					<button type="button" class="w-full sm:w-auto px-4 py-2 bg-indigo-600 border border-transparent text-white rounded-md hover:bg-indigo-700 font-semibold transition-colors shadow-sm" id="btnSaveHoraire">Enregistrer</button>
				</div>
			</div>
		</div>
	</div>

	<!-- Edit Modal -->
	<div id="editHoraireModal" style="display:none;" class="fixed inset-0 w-full h-full bg-black/50 backdrop-blur-sm z-[9999] items-center justify-center p-4">
		<div class="bg-white p-5 md:p-6 rounded-xl w-full max-w-lg shadow-2xl">
			<div class="flex justify-between items-center mb-5">
				<h3 class="text-xl font-bold text-slate-900">Modifier l'horaire</h3>
			</div>

			<label class="block text-sm font-semibold mb-1 text-slate-700">Employé</label>
			<select id="editModalUser" class="w-full px-3 py-2 text-sm border border-slate-300 rounded-md focus:ring-2 focus:ring-indigo-500 outline-none bg-white mb-4">
				{% for employe in employes %}
					<option value="{{ employe.id }}" data-magasin="{{ employe.magasin }}" data-color="{{ employe.calendarColor ?: '#4f46e5' }}">{{ employe.prenom }}
						{{ employe.nom }}
						({{ employe.magasin }})</option>
				{% endfor %}
			</select>

			<input type="hidden" id="editModalColor" value="">

			<div class="mb-4 flex items-center gap-2">
				<input type="checkbox" id="editModalAllDay" class="w-4 h-4 text-indigo-600 border-slate-300 rounded focus:ring-indigo-500">
				<label for="editModalAllDay" class="text-sm font-medium text-slate-700 cursor-pointer">Toute la journée (En haut du planning)</label>
			</div>

			<label class="block text-xs font-semibold mb-1 text-slate-500 uppercase tracking-wide">Début</label>
			<div class="grid grid-cols-[1fr_auto_auto] gap-1.5 mb-4">
				<div>
					<div class="text-[10px] text-slate-400 font-bold uppercase mb-0.5">Date</div>
					<input type="date" id="editModalStartDate" class="w-full h-9 px-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-indigo-500 outline-none text-sm">
				</div>
				<div style="min-width:60px;">
					<div class="text-[10px] text-slate-400 font-bold uppercase mb-0.5">Heure</div>
					<select id="editModalStartHour" class="w-full h-9 px-1 border border-slate-300 rounded-lg focus:ring-2 focus:ring-indigo-500 outline-none text-sm bg-white">
						{% for i in 0..23 %}
							<option value="{{ '%02d'|format(i) }}">{{ '%02d'|format(i) }}h</option>
						{% endfor %}
					</select>
				</div>
				<div style="min-width:60px;">
					<div class="text-[10px] text-slate-400 font-bold uppercase mb-0.5">Min</div>
					<select id="editModalStartMinute" class="w-full h-9 px-1 border border-slate-300 rounded-lg focus:ring-2 focus:ring-indigo-500 outline-none text-sm bg-white">
						<option value="00">00</option>
						<option value="15">15</option>
						<option value="30">30</option>
						<option value="45">45</option>
					</select>
				</div>
			</div>

			<label class="block text-xs font-semibold mb-1 text-slate-500 uppercase tracking-wide">Fin</label>
			<div class="grid grid-cols-[1fr_auto_auto] gap-1.5 mb-4">
				<div>
					<div class="text-[10px] text-slate-400 font-bold uppercase mb-0.5">Date</div>
					<input type="date" id="editModalEndDate" class="w-full h-9 px-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-indigo-500 outline-none text-sm">
				</div>
				<div style="min-width:60px;">
					<div class="text-[10px] text-slate-400 font-bold uppercase mb-0.5">Heure</div>
					<select id="editModalEndHour" class="w-full h-9 px-1 border border-slate-300 rounded-lg focus:ring-2 focus:ring-indigo-500 outline-none text-sm bg-white">
						{% for i in 0..23 %}
							<option value="{{ '%02d'|format(i) }}">{{ '%02d'|format(i) }}h</option>
						{% endfor %}
					</select>
				</div>
				<div style="min-width:60px;">
					<div class="text-[10px] text-slate-400 font-bold uppercase mb-0.5">Min</div>
					<select id="editModalEndMinute" class="w-full h-9 px-1 border border-slate-300 rounded-lg focus:ring-2 focus:ring-indigo-500 outline-none text-sm bg-white">
						<option value="00">00</option>
						<option value="15">15</option>
