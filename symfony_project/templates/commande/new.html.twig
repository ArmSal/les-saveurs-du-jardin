{% extends 'base.html.twig' %}

{% block title %}Nouvelle Commande | Plateforme LSDJ
{% endblock %}

{% block body %}
	<nav class="mb-4 pb-3 border-b border-slate-200">
		<a href="{{ path('app_produit_index') }}" class="inline-flex items-center gap-1.5 text-xs font-semibold text-slate-500 hover:text-indigo-600 transition-colors">
			<svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewbox="0 0 24 24">
				<path d="M15 19l-7-7 7-7"></path>
			</svg>
			Retour au Catalogue
		</a>
	</nav>

	<div class="max-w-2xl mx-auto">
		<div class="bg-white border border-slate-200 rounded-xl shadow-sm overflow-hidden">
			<div class="p-4 sm:p-6 border-b border-slate-100">
				<div class="text-xs font-bold uppercase tracking-widest text-indigo-600 mb-1">Commande Manuelle</div>
				<h1 class="text-lg font-bold text-slate-900">Nouvelle Commande</h1>
				<p class="text-slate-500 text-sm">Ajoutez un ou plusieurs articles à la commande.</p>
			</div>

			<div class="p-4 sm:p-6">
				{{ form_start(form) }}

				<div id="commande-items" data-prototype="{{ form_widget(form.items.vars.prototype)|e('html_attr') }}" data-index="{{ form.items|length }}" class="flex flex-col gap-3 mb-4">
					{% for itemForm in form.items %}
						<div class="bg-slate-50 border border-slate-200 rounded-xl p-4">
							<div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mb-3">
								<div>
									<label class="block text-xs font-bold uppercase tracking-widest text-slate-400 mb-1.5">Produit</label>
									{{ form_row(itemForm.product) }}
								</div>
								<div>
									<label class="block text-xs font-bold uppercase tracking-widest text-slate-400 mb-1.5">Quantité</label>
									{{ form_row(itemForm.quantity) }}
								</div>
							</div>
							<button type="button" class="btn py-1.5 px-3 text-xs font-bold rounded-lg text-red-500 border-red-200 hover:bg-red-50 js-remove-item">
								Supprimer
							</button>
						</div>
					{% endfor %}
				</div>

				<div class="flex flex-col sm:flex-row gap-3 mb-4">
					<button type="button" id="add-item" class="btn flex-1 py-2.5 text-sm font-bold rounded-xl text-indigo-600 border-indigo-200 hover:bg-indigo-50">
						+ Ajouter un article
					</button>
				</div>

				<div class="pt-3 border-t border-slate-100 flex flex-col sm:flex-row gap-3">
					<button type="submit" class="btn btn-primary flex-[2] h-11 text-sm font-bold rounded-xl">
						Créer la Commande
					</button>
					<a href="{{ path('app_produit_index') }}" class="btn flex-1 h-11 text-sm font-bold rounded-xl text-center text-slate-500">
						Annuler
					</a>
				</div>

				{{ form_end(form) }}
			</div>
		</div>
	</div>

	<style>
		#commande-items .form-group,
		#commande-items .mb-3 {
			margin-bottom: 0 !important;
		}
		#commande-items select,
		#commande-items input[type="number"] {
			width: 100%;
			height: 40px;
			border: 1px solid #e2e8f0;
			border-radius: 8px;
			padding: 0 12px;
			font-size: 14px;
			background: #fff;
			outline: none;
		}
		#commande-items select:focus,
		#commande-items input:focus {
			border-color: #4f46e5;
			box-shadow: 0 0 0 2px rgba(79, 70, 229, 0.1);
		}
	</style>
{% endblock %}

{% block javascripts %}
	{{ parent() }}
	<script>
		(function () {
const container = document.getElementById('commande-items');
if (! container) 
return;

const addBtn = document.getElementById('add-item');

function styleItem(wrapper) {
wrapper.className = 'bg-slate-50 border border-slate-200 rounded-xl p-4';
}

function addRemoveHandler(wrapper) {
const btn = wrapper.querySelector('.js-remove-item');
if (! btn) 
return;

btn.addEventListener('click', () => wrapper.remove());
}

function addItem() {
const prototype = container.dataset.prototype;
const index = parseInt(container.dataset.index, 10);
const html = prototype.replace(/__name__/g, index);
container.dataset.index = (index + 1).toString();

const wrapper = document.createElement('div');
styleItem(wrapper);
wrapper.innerHTML = `<div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mb-3">${html}</div><button type="button" class="btn py-1.5 px-3 text-xs font-bold rounded-lg text-red-500 border-red-200 hover:bg-red-50 js-remove-item">Supprimer</button>`;
container.appendChild(wrapper);
addRemoveHandler(wrapper);
}

addBtn && addBtn.addEventListener('click', addItem);
container.querySelectorAll('.bg-slate-50').forEach(addRemoveHandler);
})();
	</script>
{% endblock %}

