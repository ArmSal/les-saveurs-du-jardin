{% extends 'base.html.twig' %}

{% block title %}Détails Commande #{{ commande.id }}
	| Plateforme LSDJ
{% endblock %}

{% block body %}
	<nav class="mb-4 pb-3 border-b border-slate-200">
		<a href="{{ path('app_commande_my') }}" class="inline-flex items-center gap-1.5 text-xs font-semibold text-slate-500 hover:text-indigo-600 transition-colors">
			<svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewbox="0 0 24 24">
				<path d="M15 19l-7-7 7-7"></path>
			</svg>
			Retour à mes commandes
		</a>
	</nav>

	<div class="max-w-2xl mx-auto">
		<div
			class="bg-white border border-slate-200 rounded-xl shadow-sm overflow-hidden">
			<!-- Header -->
			<div class="p-4 sm:p-6 border-b border-slate-100">
				<div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3">
					<div>
						<div class="text-xs font-bold uppercase tracking-widest text-indigo-600 mb-1">Manifeste de Commande</div>
						<div class="inline-flex items-center bg-slate-50 border border-slate-200 rounded-lg px-3 py-1.5 font-mono text-sm font-bold text-slate-900">
							#{{ commande.slug|slice(0,12)|upper }}
						</div>
					</div>
					<div class="text-left sm:text-right">
						{% set statusConfig = {
							'delivered': {'bg': '#dcfce7', 'color': '#166534', 'label': 'Livrée'},
							'canceled': {'bg': '#fee2e2', 'color': '#991b1b', 'label': 'Annulée'},
							'pending': {'bg': '#fef9c3', 'color': '#854d0e', 'label': 'En Attente'},
							'processing': {'bg': '#eef2ff', 'color': '#4f46e5', 'label': 'En Préparation'},
							'confirmed': {'bg': '#e0f2fe', 'color': '#0369a1', 'label': 'Confirmée'},
							'processed': {'bg': '#f0fdf4', 'color': '#15803d', 'label': 'Préparée'},
							'archived': {'bg': '#f8fafc', 'color': '#475569', 'label': 'Archivée'},
							'updated': {'bg': '#fff7ed', 'color': '#c2410c', 'label': 'Modifiée'}
						} %}
						{% set config = statusConfig[commande.status] | default({'bg': '#f1f5f9', 'color': '#475569', 'label': commande.status}) %}
						<span class="badge text-xs font-bold uppercase px-3 py-1.5 rounded-lg inline-block mb-1" style="background: {{ config.bg }}; color: {{ config.color }}; border: 1px solid {{ config.color }};">
							{{ config.label }}
						</span>
						<div class="text-xs text-slate-400 font-medium">Initié le
							{{ commande.createdAt|date('d/m/Y à H:i') }}</div>
					</div>
				</div>
			</div>

			<!-- Items -->
			<div class="p-4 sm:p-6 border-b border-slate-100">
				<h3 class="text-xs font-bold uppercase tracking-widest text-slate-400 mb-3">Articles Commandés</h3>
				<div class="overflow-x-auto">
					<table class="w-full" style="min-width:300px;">
						<thead>
							<tr>
								<th class="text-left pb-2 text-xs text-slate-400 font-bold border-b border-slate-100">Produit</th>
								<th class="text-center pb-2 text-xs text-slate-400 font-bold border-b border-slate-100">Unité</th>
								<th class="text-right pb-2 text-xs text-slate-400 font-bold border-b border-slate-100">Qté</th>
							</tr>
						</thead>
						<tbody>
							{% for i in commande.items %}
								<tr class="border-b border-slate-50">
									<td class="py-3 pr-3">
										<div class="flex items-center gap-3">
											<div class="w-9 h-9 rounded-lg overflow-hidden bg-slate-100 border border-slate-200 flex items-center justify-center shrink-0">
												{% if i.product.imageUrl %}
													<img src="{{ path('app_media_product', {filename: i.product.imageUrl}) }}" alt="{{ i.product.designation }}" class="w-full h-full object-cover">
												{% else %}
													<svg width="14" height="14" fill="none" stroke="#cbd5e1" stroke-width="1.5" viewbox="0 0 24 24">
														<path d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
													</svg>
												{% endif %}
											</div>
											<span class="font-bold text-slate-900 text-xs sm:text-sm truncate max-w-[130px] sm:max-w-none">{{ i.product.designation }}</span>
										</div>
									</td>
									<td class="py-3 text-center text-xs text-slate-500 font-medium">{{ i.product.unite }}</td>
									<td class="py-3 text-right font-bold text-slate-900 text-sm">{{ i.quantity }}</td>
								</tr>
							{% endfor %}
						</tbody>
					</table>
				</div>
			</div>

			<!-- History -->
			<div class="p-4 sm:p-6">
				<h3 class="text-xs font-bold uppercase tracking-widest text-slate-400 mb-3">Journal des Mises à Jour</h3>
				<div class="flex flex-col gap-2">
					{% for h in commande.histories|sort((a, b) => b.changedAt <=> a.changedAt) %}
						<div class="flex items-center gap-3 p-3 bg-slate-50 border border-slate-200 rounded-xl">
							<div class="text-lg shrink-0">
								{% if h.status == 'delivered' %}✅{% elseif h.status == 'canceled' %}❌{% else %}📦
								{% endif %}
							</div>
							<div class="flex-1 min-w-0">
								<div class="font-bold text-slate-900 text-xs sm:text-sm truncate">
									{{ h.detail ?: "Mise à jour : " ~ (statusConfig[h.status].label | default(h.status)) }}
								</div>
								<div class="text-[10px] text-slate-400 mt-0.5">{{ h.changedBy ? (h.changedBy.nom ~ ' ' ~ h.changedBy.prenom) : 'Gestion Automatisée' }}</div>
							</div>
							<div class="text-right shrink-0">
								<div class="font-bold text-xs text-slate-900">{{ h.changedAt|date('H:i') }}</div>
								<div class="text-[10px] text-slate-400">{{ h.changedAt|date('d/m/Y') }}</div>
							</div>
						</div>
					{% endfor %}

					<!-- Origin -->
					<div class="flex items-center gap-3 p-3 bg-white border border-slate-200 rounded-xl opacity-60">
						<div class="text-lg shrink-0">🛒</div>
						<div class="flex-1 min-w-0">
							<div class="font-bold text-slate-900 text-xs sm:text-sm">Initialisation de la demande</div>
							<div class="text-[10px] text-slate-400">Système LSDJ</div>
						</div>
						<div class="text-right shrink-0">
							<div class="font-bold text-xs text-slate-900">{{ commande.createdAt|date('H:i') }}</div>
							<div class="text-[10px] text-slate-400">{{ commande.createdAt|date('d/m/Y') }}</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
{% endblock %}

