{% extends 'base.html.twig' %}

{% block title %}Flux Magasin : {{ magasin }} | Plateforme LSDJ{% endblock %}

{% block body %}
	<!-- Ultra-Compact Header -->
	<div class="mb-6 flex flex-col md:flex-row md:items-center justify-between gap-4 pb-4 border-b border-slate-100 transition-all duration-500 animate-in fade-in slide-in-from-top-3">
		<div class="space-y-0.5">
			<h1 class="text-2xl font-black text-slate-900 tracking-tight flex items-center gap-3">
				Flux <span class="text-indigo-600">{{ magasin|upper }}</span>
				<span class="px-2 py-0.5 rounded-lg bg-indigo-50 text-indigo-600 text-[10px] font-black uppercase tracking-widest border border-indigo-100/50">{{ commandes.getTotalItemCount }}</span>
			</h1>
			<p class="text-slate-400 text-xs font-medium">Surveillance logistique divisionaire point de vente.</p>
		</div>
		
		<div class="flex items-center gap-2">
			<a href="{{ path('admin_magasin_commandes_index') }}" class="h-10 px-4 bg-slate-50 hover:bg-slate-100 text-slate-500 text-[10px] font-black uppercase tracking-widest rounded-xl transition-all flex items-center gap-2 border border-slate-200/60">
				<svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path d="M6 18L18 6M6 6l12 12"></path></svg>
				RESET
			</a>
		</div>
	</div>

	<!-- Precise Filter Hub -->
	<div class="bg-white/50 backdrop-blur-sm border border-slate-200/60 rounded-2xl mb-6 overflow-hidden animate-in fade-in slide-in-from-top-4 duration-500">
		<div class="p-3">
			<form method="get" action="{{ path('admin_magasin_commandes_index') }}" class="flex items-center gap-3">
				<div class="relative flex-1 max-w-[240px]">
					<div class="absolute inset-y-0 left-3 flex items-center pointer-events-none">
						<svg class="w-3.5 h-3.5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
					</div>
					<select name="status" onchange="this.form.submit()" class="appearance-none w-full pl-9 pr-9 py-2 bg-white border border-slate-200 text-[9px] font-black text-slate-700 uppercase tracking-widest cursor-pointer focus:ring-4 focus:ring-indigo-500/5 focus:border-indigo-400 transition-all rounded-lg hover:border-slate-300">
						<option value="all">Statuts (Tous)</option>
						{% for val, label in statusLabels %}
							<option value="{{ val }}" {% if currentStatus == val %}selected{% endif %}>{{ label }}</option>
						{% endfor %}
					</select>
					<div class="absolute inset-y-0 right-3 flex items-center pointer-events-none">
						<svg class="w-3.5 h-3.5 text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3"><path d="M19 9l-7 7-7-7"></path></svg>
					</div>
				</div>

				<div class="hidden lg:block h-6 w-px bg-slate-100 mx-2"></div>
				
				<!-- Precise Top Pagination -->
				{% if commandes.pageCount > 1 %}
					<div class="flex items-center gap-1.5 ml-auto">
						<span class="text-[9px] font-black text-slate-300 uppercase tracking-widest mr-2">Page {{ commandes.currentPageNumber }}/{{ commandes.pageCount }}</span>
						<div class="flex items-center gap-1 bg-white border border-slate-200 rounded-lg p-0.5">
							{{ knp_pagination_render(commandes, 'admin/parts/_mini_pagination.html.twig') }}
						</div>
					</div>
				{% else %}
					<span class="text-[9px] font-bold text-slate-300 uppercase tracking-[0.2em] italic ml-auto">Magasin Distribution Monitoring</span>
				{% endif %}
			</form>
		</div>
	</div>

	<!-- High-Density Orders Grid -->
	<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-3 mb-10">
		{% for c in commandes %}
			{% set statusConfig = {
				'delivered': {'bg': 'bg-emerald-50', 'text': 'text-emerald-700', 'border': 'border-emerald-100', 'label': 'Livrée', 'dot': 'bg-emerald-500'},
				'canceled': {'bg': 'bg-rose-50', 'text': 'text-rose-700', 'border': 'border-rose-100', 'label': 'Annulée', 'dot': 'bg-rose-500'},
				'pending': {'bg': 'bg-amber-50', 'text': 'text-amber-700', 'border': 'border-amber-100', 'label': 'Attente', 'dot': 'bg-amber-500'},
				'processing': {'bg': 'bg-indigo-50', 'text': 'text-indigo-700', 'border': 'border-indigo-100', 'label': 'Prépa', 'dot': 'bg-indigo-500'},
				'confirmed': {'bg': 'bg-sky-50', 'text': 'text-sky-700', 'border': 'border-sky-100', 'label': 'Confirme', 'dot': 'bg-sky-500'},
				'processed': {'bg': 'bg-emerald-500', 'text': 'text-white', 'border': 'border-emerald-500', 'label': 'Prête', 'dot': 'bg-white'},
				'archived': {'bg': 'bg-slate-100', 'text': 'text-slate-500', 'border': 'border-slate-200', 'label': 'Archivée', 'dot': 'bg-slate-400'}
			} %}
			{% set config = statusConfig[c.status] | default({'bg': 'bg-slate-100', 'text': 'text-slate-700', 'border': 'border-slate-200', 'label': c.status, 'dot': 'bg-slate-500'}) %}

			<div class="group relative bg-white border border-slate-100 rounded-2xl p-2.5 transition-all duration-300 hover:shadow-[0_10px_30px_rgba(0,0,0,0.03)] hover:border-indigo-200 flex items-center gap-3 animate-in fade-in slide-in-from-bottom-2">
				
				<!-- client Identifier: Ultra-Compact -->
				<div class="relative w-14 h-14 rounded-xl overflow-hidden bg-slate-100 border border-slate-50 flex items-center justify-center text-slate-900 font-black text-[10px] shrink-0 group-hover:scale-105 transition-all duration-500 shadow-sm text-center p-1">
					{{ c.user.nom|slice(0,1)|upper }}{{ c.user.prenom|slice(0,1)|upper }}
					<div class="absolute inset-x-0 bottom-0 bg-slate-900/10 backdrop-blur-[1px] p-0.5">
						<div class="text-[5px] font-black text-center text-slate-500 uppercase tracking-tighter truncate">{{ c.user.magasin|default('LSDJ')|slice(0,4)|upper }}</div>
					</div>
				</div>

				<!-- Info Matrix: Ultra-Compact -->
				<div class="flex-1 min-w-0">
					<div class="text-[8px] font-bold text-slate-400 mb-0.5 flex items-center gap-1.5 uppercase tracking-widest">
						<span class="w-1 h-1 rounded-full {{ config.dot }} {{ c.status == 'processing' ? 'animate-pulse' : '' }}"></span>
						EXP-{{ c.id|format('%04d') }}
					</div>
					<h3 class="font-bold text-slate-900 text-[11px] leading-tight truncate mb-1 group-hover:text-indigo-600 transition-colors uppercase">{{ c.user.nom }}</h3>
					
					<div class="flex items-center gap-1.5">
						<span class="inline-flex items-center px-1.5 py-0.5 rounded-md text-[7px] font-black uppercase tracking-tighter {{ config.bg }} {{ config.text }} border {{ config.border }}">
							{{ config.label }}
						</span>
						<span class="text-[7px] font-bold text-slate-300 uppercase tracking-tighter">{{ c.createdAt|date('d/m H:i') }}</span>
					</div>
				</div>

				<!-- Precise Action -->
				<div class="shrink-0">
					<a href="{{ path('admin_commandes_show', {id: c.id}) }}" class="w-10 h-10 bg-slate-900 hover:bg-black text-white rounded-xl flex items-center justify-center transition-all hover:scale-105 active:scale-95 shadow-md border-0" title="Suivi">
						<svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
					</a>
				</div>
			</div>
		{% else %}
			<div class="col-span-full py-24 px-8 border-2 border-dashed border-slate-200 bg-white rounded-[3.5rem] text-center animate-in fade-in zoom-in duration-700">
				<div class="w-24 h-24 bg-indigo-50 text-indigo-500 rounded-[2.5rem] flex items-center justify-center mx-auto mb-8 shadow-inner transform rotate-12">
					<svg width="48" height="48" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path></svg>
				</div>
				<h3 class="text-2xl font-black text-slate-900 tracking-tight uppercase">Aucun flux Magasin</h3>
				<p class="text-sm font-bold text-slate-400 uppercase tracking-[0.2em] mt-3">Aucune commande n'est disponible pour le filtre sélectionné.</p>
			</div>
		{% endfor %}
	</div>

	<!-- Premium Pagination -->
	{% if commandes is not empty %}
		<div class="flex justify-center pb-12 transition-all duration-500 animate-in fade-in slide-in-from-bottom-4">
			<div class="p-2 bg-white/40 backdrop-blur-md rounded-[2rem] border border-white/60 shadow-xl shadow-slate-100/50">
				{{ knp_pagination_render(commandes, 'parts/_premium_pagination.html.twig') }}
			</div>
		</div>
	{% endif %}

	<style>
		@keyframes animate-in {
			from { opacity: 0; transform: translateY(20px); }
			to { opacity: 1; transform: translateY(0); }
		}
		.animate-in {
			animation: animate-in 0.6s ease-out backwards;
		}
		{% for i in 1..20 %}
			.animate-in:nth-child({{ i }}) { animation-delay: {{ i * 0.05 }}s; }
		{% endfor %}
	</style>
{% endblock %}
