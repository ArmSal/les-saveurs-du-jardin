# =============================================================================
# Secrets Ansible (chiffré via ansible-vault)
# =============================================================================
# IMPORTANT : Ce fichier ne doit JAMAIS être commité en clair.
# Pour chiffrer : ansible-vault encrypt ansible/vault/secrets.yml
# Pour éditer   : ansible-vault edit ansible/vault/secrets.yml
# =============================================================================

# Mot de passe root MySQL
mysql_root_password: "REMPLACER_PAR_MOT_DE_PASSE_FORT"

# Mot de passe utilisateur applicatif MySQL
mysql_password: "REMPLACER_PAR_MOT_DE_PASSE_FORT"

# Mot de passe admin Grafana
grafana_admin_password: "REMPLACER_PAR_MOT_DE_PASSE_FORT"

# Token GHCR (Personal Access Token GitHub avec scope read:packages)
ghcr_token: "REMPLACER_PAR_TOKEN_GHCR"

# Utilisateur GitHub
github_user: "REMPLACER_PAR_USERNAME_GITHUB"
