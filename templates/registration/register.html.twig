{% extends 'base.html.twig' %}

{% block title %}Créer un Compte | Plateforme LSDJ
{% endblock %}

{% block body %}
	<div class="auth-card" style="max-width: 600px;">
		<div style="text-align: center; margin-bottom: 32px;">
			<div style="display: flex; justify-content: center; margin-bottom: 20px;">
				<img src="{{ asset('logo.svg') }}" alt="Logo" width="40" height="70">
			</div>
			<h1 style="font-size: 24px; letter-spacing: -1.5px; margin-bottom: 8px;">Rejoindre l'Écosystème</h1>
			<p class="muted" style="font-size: 15px;">Établissez votre profil pour commencer à gérer vos commandes et inventaires.</p>
		</div>

		{{ form_start(registrationForm, {'attr': {'style': 'display: flex; flex-direction: column; gap: 4px;'}}) }}
		<div class="form-row">
			{{ form_label(registrationForm.civility, 'Civilité') }}
			{{ form_widget(registrationForm.civility, {'attr': {'style': 'height: 42px;  width: 100%; border: 1px solid var(--border); padding: 0 10px;'}}) }}
		</div>

		<div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 24px; margin-top: 24px;">
			<div class="form-group" style="display: flex; flex-direction: column; gap: 10px;">
				{{ form_label(registrationForm.prenom, 'Prénom') }}
				{{ form_widget(registrationForm.prenom, {'attr': {'style': 'height: 42px;  border: 1px solid var(--border); padding: 0 20px;', 'placeholder': 'Prénom'}}) }}
			</div>
			<div class="form-group" style="display: flex; flex-direction: column; gap: 10px;">
				{{ form_label(registrationForm.nom, 'Nom') }}
				{{ form_widget(registrationForm.nom, {'attr': {'style': 'height: 42px;  border: 1px solid var(--border); padding: 0 20px;', 'placeholder': 'Nom'}}) }}
			</div>
		</div>

		<div class="form-row">
			{{ form_label(registrationForm.email, 'Email Personnel') }}
			{{ form_widget(registrationForm.email, {'attr': {'style': 'height: 42px;  width: 100%; border: 1px solid var(--border); padding: 0 20px;', 'placeholder': 'perso@email.com'}}) }}
		</div>

		<div class="form-row" style="margin-top: 24px;">
			{{ form_label(registrationForm.plainPassword, 'Mot de Passe de Sécurité') }}
			{{ form_widget(registrationForm.plainPassword, {'attr': {'style': 'height: 42px;  width: 100%; border: 1px solid var(--border); padding: 0 20px;', 'placeholder': '••••••••••••'}}) }}
			<p style="font-size: 11px; color: var(--text-muted); margin-top: 8px;">Doit contenir au moins 12 caractères avec des symboles.</p>
		</div>

		<div style="margin-top: 32px; display: flex; flex-direction: column; gap: 16px;">
			<button class="btn btn-primary" type="submit" style="width: 100%; height: 40px;  font-size: 16px; font-weight: 800;">
				Finaliser l'Inscription
			</button>
			<a class="btn" href="{{ path('app_login') }}" style="width: 100%; height: 40px;  border: none; background: transparent;">
				Déjà un compte ? Se connecter
			</a>
		</div>
		{{ form_end(registrationForm) }}
	</div>
{% endblock %}

