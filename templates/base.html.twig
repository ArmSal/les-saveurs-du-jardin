<!DOCTYPE html>
<html lang="fr">
	<head>
		<meta charset="UTF-8">
		<meta name="viewport" content="width=device-width, initial-scale=1.0">
		<title>
			{% block title %}Plateforme LSDJ
			{% endblock %}
		</title>
		<link rel="icon" type="image/svg+xml" href="{{ asset('logo.svg') }}">
		<link rel="apple-touch-icon" href="{{ asset('apple-touch-icon.png') }}">
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
		<script src="https://cdn.tailwindcss.com"></script>
		<script>
			tailwind.config = {
theme: {
extend: {
fontFamily: {
sans: ['Plus Jakarta Sans', 'Inter', 'sans-serif']
}
}
}
}
		</script>

		{% block stylesheets %}
			<link rel="stylesheet" href="{{ asset('css/base.css') }}?v={{ 'now'|date('U') }}">
			<style>
				/* Loader Styles */
				@import url('https://fonts.googleapis.com/css2?family=Dancing+Script:wght@600&display=swap');

				#main-loader {
					position: fixed;
					inset: 0;
					z-index: 9999;
					background: #fff;
					display: flex;
					align-items: center;
					justify-content: center;
					transition: opacity 0.6s ease-in-out, visibility 0.6s;
				}
				#main-loader.fade-out {
					opacity: 0;
					visibility: hidden;
				}
				.loader-content {
					display: flex;
					flex-direction: column;
					align-items: center;
					gap: 2px; /* Very small margin under the circle */
				}
				.loader-circle-container {
					position: relative;
					width: 120px;
					height: 120px;
					display: flex;
					align-items: center;
					justify-content: center;
				}
				.loader-svg-circle {
					position: absolute;
					width: 100%;
					height: 100%;
					transform: rotate(-90deg); /* Start from top */
				}
				.circle-bg {
					fill: none;
					stroke: #f1f5f9;
					stroke-width: 4;
				}
				.circle-draw {
					fill: none;
					stroke: #a9df51;
					stroke-width: 4;
					stroke-linecap: round;
					stroke-dasharray: 283; /* 2 * PI * 45 */
					stroke-dashoffset: 283;
					animation: drawCircleCounterClockwise 0.45s ease-out forwards; /* Reduced by 70% */
					transform-origin: center;
					transform: scaleY(-1); /* Flips for counterclockwise */
				}
				.loader-carrot-static {
					width: 55px;
					height: auto;
					z-index: 2;
					transform: translateX(-4px); /* Shifted slightly left */
				}
				.loader-text-lsdj {
					display: flex;
					justify-content: center;
					gap: 8px;
					width: 100%;
					margin-right: -0.05em; /* Compensate for letter-spacing on the last letter */
				}
				.letter {
					font-size: 28px;
					font-weight: 900;
					color: #234954;
					letter-spacing: 0.05em;
					opacity: 0;
					transform: translateY(10px);
					animation: letterAppear 0.2s cubic-bezier(0.34, 1.56, 0.64, 1) forwards; /* Faster appearance */
				}
				.letter:nth-child(1) {
					animation-delay: 0s;
				}
				.letter:nth-child(2) {
					animation-delay: 0.05s;
				}
				.letter:nth-child(3) {
					animation-delay: 0.10s;
				}
				.letter:nth-child(4) {
					animation-delay: 0.15s;
				}

				@keyframes drawCircleCounterClockwise {
					0% {
						stroke-dashoffset: 283;
					}
					100% {
						stroke-dashoffset: 0;
					}
				}
				@keyframes letterAppear {
					to {
						opacity: 1;
						transform: translateY(0);
					}
				}

				/* Sidebar brand icon */
				.sidebar-brand-icon {
					position: relative;
					width: 68px;
					height: 68px;
					display: flex;
					align-items: center;
					justify-content: center;
					cursor: pointer;
					padding: 6px;
				}
				.brand-square-svg {
					position: absolute;
					top: 0;
					left: 0;
					width: 100%;
					height: 100%;
				}
				.brand-square-draw {
					stroke: #a9df51;
					stroke-width: 2.5;
					stroke-linecap: round;
					stroke-linejoin: round;
					fill: none;
					stroke-dasharray: 216;
					stroke-dashoffset: 216;
					animation: drawSquare 3s ease-in-out infinite;
				}
				.brand-inner {
					position: relative;
					z-index: 2;
					display: flex;
					align-items: center;
					justify-content: center;
					width: 100%;
					height: 100%;
				}
				.brand-carrot {
					width: 28px;
					height: auto;
					position: absolute;
					transition: opacity 0.8s ease, transform 0.8s ease;
					opacity: 1;
					transform: scale(1);
				}
				.brand-carrot.hidden {
					opacity: 0;
					transform: scale(0.8);
				}
				.brand-lsdj {
					position: absolute;
					font-size: 18px;
					font-weight: 900;
					color: #a9df51;
					transform: rotate(-45deg) scale(0.8);
					letter-spacing: 0.05em;
					transition: opacity 0.8s ease, transform 0.8s ease;
					opacity: 0;
				}
				.brand-lsdj.visible {
					opacity: 1;
					transform: rotate(-45deg) scale(1);
				}
				@keyframes drawSquare {
					0% {
						stroke-dashoffset: 216;
					} /* Empty */
					50% {
						stroke-dashoffset: 0;
					} /* Fully drawn (1.5s) */
					100% {
						stroke-dashoffset: -216;
					}; /* Undrawn (1.5s) */
				}

				/* Notification Styles */
				.notifications-dropdown {
					position: absolute;
					top: calc(100% + 12px);
					right: -80px;
					width: 360px;
					background: #fff;
					border: 1px solid #eef2f6;
					border-radius: 12px;
					box-shadow: 0 20px 25px -5px rgba(0,0,0,0.05), 0 8px 10px -6px rgba(0,0,0,0.05);
					z-index: 1000;
					display: none;
					flex-direction: column;
					overflow: hidden;
					transform-origin: top right;
					animation: dropdownAppear 0.2s cubic-bezier(0.16, 1, 0.3, 1);
				}
				@keyframes dropdownAppear {
					from { opacity: 0; transform: scale(0.95) translateY(-10px); }
					to { opacity: 1; transform: scale(1) translateY(0); }
				}
				.notifications-dropdown.open {
					display: flex;
				}
				.notif-header {
					padding: 16px 20px;
					border-bottom: 1px solid #f1f5f9;
					display: flex;
					align-items: center;
					justify-content: space-between;
					background: #fff;
				}
				.notif-list {
					max-height: 480px;
					overflow-y: auto;
				}
				.notif-item {
					padding: 14px 20px;
					border-bottom: 1px solid #f8fafc;
					display: flex;
					gap: 12px;
					transition: all 0.2s;
					text-decoration: none;
					color: inherit;
					position: relative;
				}
				.notif-item:hover {
					background: #f8fafc;
				}
				.notif-item.unread {
					background: #fff;
				}
				.notif-item.unread::before {
					content: '';
					position: absolute;
					left: 0;
					top: 0;
					bottom: 0;
					width: 3px;
					background: #4f46e5;
				}
				.notif-dot-indicator {
					width: 6px;
					height: 6px;
					border-radius: 50%;
					background: #4f46e5;
					margin-top: 6px;
					flex-shrink: 0;
				}
				.notif-body {
					flex: 1;
					min-width: 0;
				}
				.notif-title {
					font-size: 13px;
					font-weight: 800;
					color: #1e293b;
					margin-bottom: 2px;
				}
				.notif-content {
					font-size: 12px;
					color: #64748b;
					line-height: 1.5;
				}
				.notif-time {
					font-size: 10px;
					color: #94a3b8;
					margin-top: 6px;
					font-weight: 600;
					display: block;
				}
				.notif-empty {
					padding: 30px 16px;
					text-align: center;
					color: var(--text-muted);
					font-size: 13px;
				}
				.notif-footer {
					padding: 10px;
					text-align: center;
					border-top: 1px solid var(--border);
					background: var(--bg-main);
				}
				.notif-footer a {
					font-size: 12px;
					font-weight: 600;
					color: var(--primary);
					text-decoration: none;
				}
				.unread-badge {
					position: absolute;
					top: -5px;
					right: -5px;
					background: #ef4444;
					color: #fff;
					font-size: 10px;
					font-weight: 800;
					min-width: 16px;
					height: 16px;
					border-radius: 8px;
					display: flex;
					align-items: center;
					justify-content: center;
					padding: 0 4px;
					border: 2px solid #fff;
				}
				/* Global Toast Container */
				#global-toast-container {
					position: fixed;
					top: 24px;
					right: 24px;
					z-index: 10000;
					display: flex;
					flex-direction: column;
					gap: 12px;
					pointer-events: none;
				}

				.global-toast {
					pointer-events: auto;
					min-width: 320px;
					max-width: 420px;
					padding: 16px;
					border-radius: 12px;
					background: #ffffff;
					box-shadow: 0 20px 25px -5px rgba(0,0,0,0.1), 0 8px 10px -6px rgba(0,0,0,0.1);
					border: 1px solid var(--border);
					display: flex;
					align-items: center;
					gap: 12px;
					transform: translateX(40px);
					opacity: 0;
					transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
				}

				.global-toast.show {
					transform: translateX(0);
					opacity: 1;
				}

				.global-toast-success { color: #065f46; background: #ecfdf5; border-color: #a7f3d0; }
				.global-toast-error { color: #991b1b; background: #fef2f2; border-color: #fecaca; }

				/* Access Level Badges & Tokens */
				.badge-access-aucun { color: #64748b; background: #f1f5f9; border: 1px solid #e2e8f0; }
				.badge-access-total { color: #065f46; background: #ecfdf5; border: 1px solid #a7f3d0; }
				.badge-access-admin { color: #4338ca; background: #eef2ff; border: 1px solid #c7d2fe; }
				.badge-access-lecture-totale { color: #0369a1; background: #f0f9ff; border: 1px solid #bae6fd; }
				.badge-access-lecture-magasin { color: #0f766e; background: #f0fdfa; border: 1px solid #99f6e4; }
				.badge-access-personnel { color: #92400e; background: #fffbeb; border: 1px solid #fde68a; }

				.access-select {
					transition: all 0.3s ease;
					text-transform: uppercase;
					letter-spacing: 0.05em;
					font-weight: 800;
					font-size: 10px;
				}
			</style>
		{% endblock %}

		{% block javascripts %}{% endblock %}
	</head>
	<body class="{% block body_class %}{% endblock %}">
		{% if app.request.get('_route') != 'app_login' %}
			<div id="main-loader">
				<div class="loader-content">
					<div class="loader-circle-container">
						<svg class="loader-svg-circle" viewbox="0 0 100 100">
							<circle class="circle-bg" cx="50" cy="50" r="45"></circle>
							<circle class="circle-draw" cx="50" cy="50" r="45"></circle>
						</svg>
						<img src="{{ asset('logo.svg') }}" class="loader-carrot-static" alt="Logo">
					</div>
					<div class="loader-text-lsdj">
						<span class="letter">L</span>
						<span class="letter">S</span>
						<span class="letter">D</span>
						<span class="letter">J</span>
					</div>
				</div>
			</div>
		{% endif %}

		{% if app.user %}
			<!-- Mobile overlay -->
			<div class="sidebar-overlay" id="sidebarOverlay" onclick="closeSidebar()"></div>

			<!-- Sidebar -->
			<aside class="sidebar" id="sidebar">
				<div class="sidebar-header">
					<a href="{{ path('app_home') }}" class="sidebar-brand-icon" id="sidebarBrandIcon" style="text-decoration: none; color: inherit; display: flex; align-items: center; width: 100%;">
						<svg class="brand-square-svg" viewbox="0 0 60 60" fill="none">
							<rect class="brand-square-draw" x="3" y="3" width="54" height="54" rx="6"></rect>
						</svg>
						<div class="brand-inner" id="brandInner">
							<img src="{{ asset('logo.svg') }}" class="brand-carrot" id="brandCarrot" alt="Logo">
							<span class="brand-lsdj" id="brandLsdj">LSDJ</span>
						</div>
					</a>
				</div>
				<nav style="padding: 8px 0; flex: 1;">
				{# ============================================================
				   UNIFIED NAV — Visibility controlled ONLY by MODULE_VIEW.
				   If user has AUCUN_ACCES for a module → link is hidden.
				   Any other access level → link is shown.
				   Role checks are only used for label personalization.
				   ============================================================ #}

				{# Section label adapts to user role for context #}
				<div class="nav-label">{{ is_granted('ROLE_RESPONSABLE') ? 'Management' : 'Mon Espace' }}</div>

				{# 1. Tableau de bord — visible if user has any non-AUCUN access #}
				{% if is_granted('MODULE_VIEW', 'dashboard') %}
					<a href="{{ path('app_dashboard') }}" class="{{ app.request.get('_route') == 'app_dashboard' ? 'active' : '' }}">
						<svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewbox="0 0 24 24">
							<path d="M16 8v8m-4-5v5m-4-2v2m-2 4h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
						</svg>
						<span class="sidebar-label">Tableau de bord</span>
					</a>
				{% endif %}

				{# 2. Gestion des Accès — visible if user has any non-AUCUN access #}
				{% if is_granted('MODULE_VIEW', 'access_management') %}
					<a href="{{ path('admin_access_index') }}" class="{{ app.request.get('_route') == 'admin_access_index' ? 'active' : '' }}">
						<svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewbox="0 0 24 24">
							<path d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
						</svg>
						<span class="sidebar-label">Gestion des Accès</span>
					</a>
				{% endif %}

				{# 3. RH Dropdown — shown if user has access to at least one RH module #}
				{% if is_granted('MODULE_VIEW', 'agenda') or is_granted('MODULE_VIEW', 'users') or is_granted('MODULE_VIEW', 'rh_validation') or is_granted('MODULE_VIEW', 'rh_conge') or is_granted('MODULE_VIEW', 'rh_documents') %}
					<div class="nav-dropdown">
						<button class="nav-dropdown-trigger" onclick="toggleNavDropdown(this)">
							<svg fill="none" stroke="currentColor" stroke-width="2" viewbox="0 0 24 24">
								<path d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
							</svg>
							<span class="sidebar-label">RH</span>
							<svg class="chevron" fill="none" stroke="currentColor" stroke-width="2" viewbox="0 0 24 24"><path d="M19 9l-7 7-7-7"></path></svg>
						</button>
						<div class="nav-dropdown-content">
							{% if is_granted('MODULE_VIEW', 'agenda') %}
								<a href="{{ path('app_agenda') }}" class="{{ app.request.get('_route') == 'app_agenda' ? 'active' : '' }}">{{ is_granted('ROLE_RESPONSABLE') ? 'Planning' : 'Mon Planning' }}</a>
							{% endif %}
							{% if is_granted('MODULE_VIEW', 'rh_validation') %}
								<a href="{{ path('app_rh_validation') }}" class="{{ app.request.get('_route') starts with 'app_rh_validation' ? 'active' : '' }}">
									{{ is_granted('ROLE_RESPONSABLE') ? 'Validation des Horaires' : 'Valider mes heures' }}
								</a>
							{% endif %}
							{% if is_granted('MODULE_VIEW', 'rh_conge') %}
								<a href="{{ path('app_rh_conge') }}" class="{{ app.request.get('_route') == 'app_rh_conge' ? 'active' : '' }}">Demande de congé</a>
							{% endif %}
							{% if is_granted('MODULE_VIEW', 'rh_documents') %}
								<a href="{{ path('app_rh_documents') }}" class="{{ app.request.get('_route') == 'app_rh_documents' ? 'active' : '' }}">{{ is_granted('ROLE_RESPONSABLE') ? 'Documents RH & Contrats' : 'Mes Documents RH' }}</a>
							{% endif %}
							{% if is_granted('MODULE_VIEW', 'users') %}
								<a href="{{ path('admin_users_index') }}" class="{{ app.request.get('_route') starts with 'admin_users' ? 'active' : '' }}">Gestion du personnel</a>
							{% endif %}
						</div>
					</div>
				{% endif %}

				{# 4. Transport & Logistique #}
				{% if is_granted('MODULE_VIEW', 'transport_logistique') %}
					<a href="{{ path('app_transport_logistique') }}" class="{{ app.request.get('_route') == 'app_transport_logistique' ? 'active' : '' }}">
						<svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewbox="0 0 24 24">
							<path d="M8 14h.01M16 14h.01M5 8h14M5 8a2 2 0 00-2 2v6a2 2 0 002 2h14a2 2 0 002-2v-6a2 2 0 00-2-2M5 8l1-3h12l1 3M9 14v1m6-1v1"></path>
						</svg>
						<span class="sidebar-label">Transport & logistique</span>
					</a>
				{% endif %}

				{# 4. Maintenance Dropdown #}
				{% if is_granted('MODULE_VIEW', 'maintenance_signalement') or is_granted('MODULE_VIEW', 'maintenance_suivi') %}
					<div class="nav-dropdown">
						<button class="nav-dropdown-trigger" onclick="toggleNavDropdown(this)">
							<svg fill="none" stroke="currentColor" stroke-width="2" viewbox="0 0 24 24">
								<path d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path>
								<path d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
							</svg>
							<span class="sidebar-label">Maintenance</span>
							<svg class="chevron" fill="none" stroke="currentColor" stroke-width="2" viewbox="0 0 24 24"><path d="M19 9l-7 7-7-7"></path></svg>
						</button>
						<div class="nav-dropdown-content">
							{% if is_granted('MODULE_VIEW', 'maintenance_signalement') %}
								<a href="{{ path('app_maintenance_signalement') }}" class="{{ app.request.get('_route') == 'app_maintenance_signalement' ? 'active' : '' }}">Signalement matériel</a>
							{% endif %}
							{% if is_granted('MODULE_VIEW', 'maintenance_suivi') %}
								<a href="{{ path('app_maintenance_suivi') }}" class="{{ app.request.get('_route') == 'app_maintenance_suivi' ? 'active' : '' }}">Suivi intervention</a>
							{% endif %}
						</div>
					</div>
				{% endif %}

				{# 5. Commandes Dropdown #}
				{% if is_granted('MODULE_VIEW', 'produits') or is_granted('MODULE_VIEW', 'commandes') %}
					<div class="nav-dropdown">
						<button class="nav-dropdown-trigger" onclick="toggleNavDropdown(this)">
							<svg fill="none" stroke="currentColor" stroke-width="2" viewbox="0 0 24 24">
								<path d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path>
							</svg>
							<span class="sidebar-label">Commandes</span>
							<svg class="chevron" fill="none" stroke="currentColor" stroke-width="2" viewbox="0 0 24 24"><path d="M19 9l-7 7-7-7"></path></svg>
						</button>
						<div class="nav-dropdown-content">
							{% if is_granted('MODULE_VIEW', 'produits') %}
								<a href="{{ path('app_produit_index') }}" class="{{ app.request.get('_route') starts with 'app_produit' ? 'active' : '' }}">Catégorie Produits</a>
							{% endif %}
							{% if is_granted('MODULE_VIEW', 'commandes') %}
								<a href="{{ path('admin_commandes_index') }}" class="{{ app.request.get('_route') starts with 'admin_commandes' ? 'active' : '' }}">Gestion Commandes</a>
							{% endif %}
						</div>
					</div>
				{% endif %}

				{# 6. Documents Généraux #}
				{% if is_granted('MODULE_VIEW', 'documents') %}
				<a href="{{ path('app_document_index') }}" class="{{ app.request.get('_route') starts with 'app_document' ? 'active' : '' }}">
					<svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewbox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/>
					</svg>
					<span class="sidebar-label">Documents Généraux</span>
				</a>
				{% endif %}

				{# 7. Contact Utile — always visible for all logged-in users #}
				<div class="nav-label mt-4">Informations</div>
				<div class="nav-dropdown">
					<button class="nav-dropdown-trigger" onclick="toggleNavDropdown(this)">
						<svg fill="none" stroke="currentColor" stroke-width="2" viewbox="0 0 24 24">
							<path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
						</svg>
						<span class="sidebar-label">Contact Utile</span>
						<svg class="chevron" fill="none" stroke="currentColor" stroke-width="2" viewbox="0 0 24 24"><path d="M19 9l-7 7-7-7"></path></svg>
					</button>
					<div class="nav-dropdown-content">
						<a href="{{ path('app_contact_olivet') }}" class="{{ app.request.get('_route') == 'app_contact_olivet' ? 'active' : '' }}">Olivet</a>
						<a href="{{ path('app_contact_st_gervais') }}" class="{{ app.request.get('_route') == 'app_contact_st_gervais' ? 'active' : '' }}">St Gervais</a>
						<a href="{{ path('app_contact_villemandeur') }}" class="{{ app.request.get('_route') == 'app_contact_villemandeur' ? 'active' : '' }}">Villemandeur</a>
						<a href="{{ path('app_contact_noyers') }}" class="{{ app.request.get('_route') == 'app_contact_noyers' ? 'active' : '' }}">Noyers</a>
						<a href="{{ path('app_contact_saran') }}" class="{{ app.request.get('_route') == 'app_contact_saran' ? 'active' : '' }}">Saran</a>
					</div>
				</div>
			</nav>
			</aside>
		{% endif %}

		<div class="main-content" {% if not app.user %} style="margin-left: 0 !important;" {% endif %}>
			{% if app.user %}
				<header
					class="top-bar">
					<!-- Left: Hamburger + Brand -->
					<div style="display:flex; align-items:center; gap:10px; min-width:0; flex:1;">
						<button class="hamburger-btn" id="hamburgerBtn" onclick="toggleSidebar()" aria-label="Menu">
							<svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5" viewbox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
							</svg>
						</button>
						{% if is_granted('ROLE_USER') %}
							<a href="{{ path('app_home') }}" class="top-bar-brand hover:text-indigo-600 transition-colors">LES SAVEURS DU JARDIN</a>
						{% endif %}
					</div>

					<!-- Right: Cart + User -->
					<div style="display:flex; align-items:center; gap:10px; flex-shrink:0;">
						{% if is_granted('ROLE_USER') %}
							{# Notifications Dropdown #}
							<div class="dropdown" id="notifDropdown" style="position:relative;">
								<button type="button" class="relative inline-flex items-center p-2 text-slate-500 hover:text-indigo-600 transition-colors bg-transparent border-0 cursor-pointer" id="notifDropdownTrigger" onclick="toggleNotifDropdown(event)" aria-label="Notifications">
									<svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="2.2" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 005.454-1.31A8.967 8.967 0 0118 9.75v-.7V9A6 6 0 006 9v.75a8.967 8.967 0 01-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 01-5.714 0m5.714 0a3 3 0 11-5.714 0" />
									</svg>
									{% if unreadNotificationsCount|default(0) > 0 %}
                                        <span class="absolute top-0 right-[-2px] flex h-4 w-4" id="global-notif-badge">
                                            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-rose-400 opacity-75"></span>
                                            <span class="relative inline-flex rounded-full h-4 w-4 bg-rose-600 text-[10px] font-black text-white items-center justify-center shadow-lg border-2 border-white" id="global-notif-count">
                                                {{ unreadNotificationsCount }}
                                            </span>
                                        </span>
									{% endif %}
								</button>
								<div class="notifications-dropdown" id="notifDropdownContent">
									<div class="notif-header">
										<span class="text-[10px] font-black uppercase tracking-widest text-slate-400">Notifications</span>
										{% if unreadNotificationsCount|default(0) > 0 %}
											<button onclick="markAllNotificationsAsRead(event)" class="text-[10px] font-black text-indigo-600 uppercase tracking-widest bg-transparent border-0 cursor-pointer hover:text-slate-900 transition-colors">Tout marquer</button>
										{% endif %}
									</div>
									<div class="notif-list" id="notif-list-container">
										{% for notif in notifications|default([]) %}
											<a href="{{ notif.link ?: '#' }}" 
                                               id="notif-item-{{ notif.id }}"
                                               onclick="handleNotifClick('{{ notif.id }}', event)"
                                               class="notif-item {{ notif.isRead ? '' : 'unread' }}">
												{% if not notif.isRead %}
													<div class="notif-dot-indicator"></div>
												{% else %}
                                                    <div class="w-[6px] flex-shrink-0"></div>
												{% endif %}
												<div class="notif-body">
													<div class="notif-title">{{ notif.title }}</div>
													<div class="notif-content">{{ notif.content }}</div>
													<span class="notif-time">{{ notif.createdAt|date('d/m H:i') }}</span>
												</div>
											</a>
										{% else %}
											<div class="notif-empty">
                                                <div class="text-3xl mb-2 opacity-20">🔔</div>
                                                <div class="text-[10px] font-black uppercase tracking-widest text-slate-300">Aucune notification</div>
                                            </div>
										{% endfor %}
									</div>
									<div class="notif-footer" style="padding: 12px; border-top: 1px solid #f8fafc;">
										<a href="{{ path('app_notifications_index') }}" class="text-[10px] font-black text-slate-400 uppercase tracking-widest hover:text-indigo-600 transition-colors no-underline block text-center">Historique Complet</a>
									</div>
								</div>
							</div>

							<a href="{{ path('app_cart_index') }}" class="relative inline-flex items-center p-2 text-slate-500 hover:text-indigo-600 transition-colors group" title="Mon Panier">
								<svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="2.2" viewBox="0 0 24 24">
									<path d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"></path>
								</svg>
								{% set cartCount = cart_item_count() %}
								{% if cartCount > 0 %}
									<span class="absolute top-0 right-[-2px] flex h-4 w-4">
										<span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-rose-400 opacity-75"></span>
										<span class="relative inline-flex rounded-full h-4 w-4 bg-rose-600 text-[10px] font-black text-white items-center justify-center shadow-lg border-2 border-white">
											{{ cartCount }}
										</span>
									</span>
								{% endif %}
							</a>
						{% endif %}

						<div class="dropdown" id="userDropdown">
							<button type="button" class="dropdown-trigger" id="userDropdownTrigger" onclick="toggleUserDropdown(event)" aria-expanded="false" aria-haspopup="true">
								{% if app.user.photo %}
									<div style="width:30px; height:30px; border-radius:50%; border:2px solid var(--primary); overflow:hidden; flex-shrink:0;">
										<img src="{{ path('app_media_user', {filename: app.user.photo}) }}" style="width:100%; height:100%; object-fit:cover;">
									</div>
								{% else %}
									<div style="width:30px; height:30px; background:var(--primary); color:#fff; display:flex; align-items:center; justify-content:center; font-weight:800; font-size:13px; border-radius:50%; flex-shrink:0;">
										{{ app.user.prenom|slice(0,1)|upper ?: app.user.userIdentifier|slice(0,1)|upper }}
									</div>
								{% endif %}
								<span style="font-size:13px; font-weight:700; color:var(--dark); max-width:90px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; display:none;" class="user-name-label">{{ app.user.prenom }}</span>
								<svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5" viewbox="0 0 24 24" id="dropdownChevron" style="transition:transform 0.2s; flex-shrink:0;">
									<path d="M19 9l-7 7-7-7"></path>
								</svg>
							</button>
							<div class="dropdown-content" id="userDropdownContent" style="display:none;">
								<div style="padding:12px 16px; border-bottom:1px solid var(--border);">
									<div style="font-size:11px; font-weight:800; color:var(--text-muted); text-transform:uppercase; letter-spacing:0.1em;">Compte</div>
									<div style="font-size:13px; font-weight:600; color:var(--dark); margin-top:2px;">{{ app.user.prenom }}
										{{ app.user.nom }}</div>
								</div>
								{% if is_granted('ROLE_USER') %}
									<a href="{{ path('app_commande_my') }}">
										<svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewbox="0 0 24 24">
											<path d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path>
										</svg>
										Suivi Commandes
									</a>
								{% endif %}
								<a href="{{ path('app_settings') }}">
									<svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewbox="0 0 24 24">
										<path d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path>
										<path d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
									</svg>
									Paramètres
								</a>
								<div class="dropdown-divider"></div>
								<a href="{{ path('app_logout') }}" style="color:#ef4444;">
									<svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewbox="0 0 24 24">
										<path d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path>
									</svg>
									Déconnexion
								</a>
							</div>
						</div>
					</div>
				</header>
			{% endif %}

			<main class="{{ not app.user ? 'auth-layout' : 'page-wrapper' }}">
				{% if app.user %}
					{% for message in app.flashes('success') %}
						<div class="alert">
							<svg width="18" height="18" fill="currentColor" viewbox="0 0 20 20">
								<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
							</svg>
							{{ message }}
						</div>
					{% endfor %}
					{% for message in app.flashes('error') %}
						<div class="alert alert-error">
							<svg width="18" height="18" fill="currentColor" viewbox="0 0 20 20">
								<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"></path>
							</svg>
							{{ message }}
						</div>
					{% endfor %}
				{% endif %}

				{% block body %}{% endblock %}
			</main>
		</div>

		<div id="global-toast-container"></div>

		<script>
			window.showToast = function(message, type = 'success') {
				const container = document.getElementById('global-toast-container');
				const toast = document.createElement('div');
				toast.className = `global-toast global-toast-${type}`;
				
				const icon = type === 'success' 
					? '<svg width="20" height="20" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>'
					: '<svg width="20" height="20" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"></path></svg>';

				toast.innerHTML = `
					<div class="shrink-0">${icon}</div>
					<div class="text-sm font-bold flex-1">${message}</div>
				`;
				
				container.appendChild(toast);
				
				// Force reflow
				toast.offsetHeight;
				toast.classList.add('show');
				
				setTimeout(() => {
					toast.classList.remove('show');
					setTimeout(() => toast.remove(), 400);
				}, 4000);
			};
		</script>
		<script src="{{ asset('js/base.js') }}"></script>
		<script src="{{ asset('js/modal.js') }}"></script>
	</body>
</html>

