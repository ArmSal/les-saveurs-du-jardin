{{ form_start(form, {'attr': {'class': 'space-y-5', 'novalidate': 'novalidate'}}) }}

{% if form_errors(form) %}
	<div class="flex items-start gap-2 p-3 bg-rose-50 border border-rose-200 rounded-xl text-xs text-rose-700 font-bold">
		<svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" class="shrink-0 mt-0.5"><path d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
		{{ form_errors(form) }}
	</div>
{% endif %}

{# --- Nom + Parent (stacked on mobile, side by side on sm+) --- #}
<div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
	<div class="space-y-1">
		{{ form_label(form.name, null, {'label_attr': {'class': 'block text-[9px] font-black text-slate-400 uppercase tracking-widest ml-1'}}) }}
		{{ form_widget(form.name, {'attr': {'class': 'w-full bg-slate-50 border-2 border-slate-100 rounded-xl py-3 px-4 text-xs font-bold text-slate-900 outline-none focus:bg-white focus:border-indigo-500 transition-all', 'placeholder': 'Ex: Contrats, Plannings...'}}) }}
		<div class="text-[10px] text-rose-500 font-bold ml-1">{{ form_errors(form.name) }}</div>
	</div>
	<div class="space-y-1">
		{{ form_label(form.parent, null, {'label_attr': {'class': 'block text-[9px] font-black text-slate-400 uppercase tracking-widest ml-1'}}) }}
		{{ form_widget(form.parent, {'attr': {'class': 'w-full bg-slate-50 border-2 border-slate-100 rounded-xl py-3 px-4 text-xs font-bold text-slate-900 outline-none focus:bg-white focus:border-indigo-500 transition-all cursor-pointer appearance-none'}}) }}
		<div class="text-[10px] text-rose-500 font-bold ml-1">{{ form_errors(form.parent) }}</div>
	</div>
</div>

{# --- Permissions par Rôle --- #}
<div class="bg-slate-50 border border-slate-100 rounded-2xl p-5">
	<div class="flex items-center gap-2 mb-4">
		<div class="w-6 h-6 bg-indigo-100 rounded-lg flex items-center justify-center">
			<svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" class="text-indigo-600"><path d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
		</div>
		<span class="text-[9px] font-black text-slate-600 uppercase tracking-widest">Visible par les rôles</span>
	</div>
	<div class="grid grid-cols-2 sm:grid-cols-4 gap-2">
		{% for child in form.rolesPermitted %}
			<label class="flex items-center gap-2 p-3 bg-white border-2 border-slate-100 rounded-xl cursor-pointer hover:border-indigo-400 transition-all has-[:checked]:border-indigo-500 has-[:checked]:bg-indigo-50 group">
				{{ form_widget(child, {'attr': {'class': 'w-3.5 h-3.5 accent-indigo-600 cursor-pointer shrink-0'}}) }}
				<span class="text-[9px] font-black uppercase tracking-widest text-slate-500 group-hover:text-indigo-700 transition-colors leading-none">{{ form_label(child) }}</span>
			</label>
		{% endfor %}
	</div>
</div>

{# --- Actions --- #}
<div class="flex items-center justify-between pt-3 border-t border-slate-100">
	<a href="{{ path('app_document_index') }}" class="text-[9px] font-black text-slate-400 uppercase tracking-widest hover:text-slate-700 transition-colors">← Annuler</a>
	<button type="submit" class="bg-slate-950 text-white font-black py-3 px-8 rounded-xl hover:bg-indigo-600 transition-all text-[9px] uppercase tracking-widest shadow-lg">
		{{ button_label|default('Créer') }} ✓
	</button>
</div>

{{ form_end(form) }}
