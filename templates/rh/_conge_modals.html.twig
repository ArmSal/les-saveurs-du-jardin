<style>
    @keyframes modal-in { from { opacity: 0; transform: translateY(20px) scale(0.98); } to { opacity: 1; transform: translateY(0) scale(1); } }
    .animate-modal-in { animation: modal-in 0.4s cubic-bezier(0.19, 1, 0.22, 1) both; }
</style>
