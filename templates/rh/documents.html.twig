                        <td class="px-4 py-3 text-right">
                            <div class="flex items-center justify-end gap-1.5">
                                <a href="{{ path('app_rh_document_stream', {id: doc.id}) }}" target="_blank" class="inline-flex items-center gap-1.5 bg-white text-slate-600 font-bold py-1.5 px-2.5 rounded-lg hover:bg-slate-50 transition-all text-[9px] uppercase tracking-wider border border-slate-200 shadow-sm">
                                    <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg>
                                    Voir
                                </a>
                                {% if doc.type == 'CONTRACT' and doc.status == 'PENDING_SIGNATURE' and doc.targetUser == app.user %}
                                    <button onclick="openSignModal('{{ doc.id }}', '{{ doc.title|e('js') }}')" class="inline-flex items-center gap-1 bg-indigo-600 text-white font-bold py-1.5 px-2.5 rounded-lg hover:bg-indigo-700 transition-all text-[9px] uppercase tracking-wider shadow-sm">
                                        <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M15.232 5.232l3.536 3.536M9 11l6-6 3 3-6 6H9v-3z"></path></svg>
                                        Signer
                                    </button>
                                {% endif %}
                                {% if canEdit %}
                                    <form action="{{ path('app_rh_document_delete', {id: doc.id}) }}" method="POST" onsubmit="return confirm('Supprimer ce document ?');" class="inline">
                                        <button type="submit" class="w-8 h-8 flex items-center justify-center bg-white text-slate-400 border border-slate-200 hover:text-rose-600 hover:bg-rose-50 rounded-lg transition-all">
                                            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                                        </button>
                                    </form>
                                {% endif %}
                            </div>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    {# PAGINATION #}
    {% if pagination.getTotalItemCount > pagination.getItemNumberPerPage %}
        <div class="py-10 flex justify-center">
            <div class="portal-pagination scale-110">
                {{ knp_pagination_render(pagination) }}
            </div>
        </div>
    {% endif %}
{% endif %}
</div> <!-- documents-list-container -->
</div> <!-- max-w-7xl -->
</div> <!-- min-h-screen -->

{# ===== MODAL: Envoyer / Déposer ===== #}
<div id="send-doc-modal" class="fixed inset-0 bg-slate-950/40 backdrop-blur-sm z-[500] hidden items-center justify-center p-4">
    <div class="bg-white rounded-xl w-full max-w-lg shadow-xl animate-modal-in overflow-hidden border border-slate-200">
        <div class="flex items-center justify-between px-6 py-4 border-b border-slate-100">
            <div>
                <h3 class="text-sm font-bold text-slate-900 uppercase tracking-wider">{{ canEdit ? 'Envoyer un document' : 'Déposer un document' }}</h3>
                <p class="text-[10px] text-slate-400 mt-0.5">Espace RH sécurisé</p>
            </div>
            <button onclick="closeModal('send-doc-modal')" class="w-8 h-8 flex items-center justify-center bg-slate-50 hover:bg-slate-100 rounded-lg transition-colors">
                <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M6 18L18 6M6 6l12 12"></path></svg>
            </button>
        </div>
        <form action="{{ path('app_rh_document_send') }}" method="POST" enctype="multipart/form-data" class="p-6 space-y-4">
            <div class="space-y-1.5">
                <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-wider">Titre du document</label>
                <input type="text" name="title" required placeholder="Ex: Contrat de travail..." class="w-full bg-slate-50 border border-slate-200 rounded-lg px-4 py-2 text-sm text-slate-700 focus:ring-1 focus:ring-indigo-100 focus:border-indigo-400 outline-none transition-all">
            </div>

            {% if canEdit %}
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div class="space-y-1.5">
                    <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-wider">Établissement</label>
                    <select id="send_magasin_select" onchange="filterSendEmployees(this.value)" class="w-full bg-slate-50 border border-slate-200 rounded-lg px-3 py-2 text-sm text-slate-700 outline-none focus:border-indigo-400 focus:ring-1 focus:ring-indigo-100 cursor-pointer">
                        <option value="">Tous les établissements</option>
                        {% for mag in magasins %}
                            <option value="{{ mag }}">{{ mag|upper }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="space-y-1.5">
                    <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-wider">Destinataire</label>
                    <select id="send_employee_select" name="target_user_id" required class="w-full bg-slate-50 border border-slate-200 rounded-lg px-3 py-2 text-sm text-slate-700 outline-none focus:border-indigo-400 focus:ring-1 focus:ring-indigo-100 cursor-pointer">
                        <option value="">Choisir un employé...</option>
                        {% for emp in employes %}
                            <option value="{{ emp.id }}" data-magasin="{{ emp.magasin }}">{{ emp.prenom }} {{ emp.nom }}</option>
                        {% endfor %}
                    </select>
                </div>
            </div>
            <div class="space-y-1.5">
                <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-wider">Type de document</label>
                <select name="type" id="docTypeSelect" onchange="toggleDirectorLabel(this.value)" class="w-full bg-slate-50 border border-slate-200 rounded-lg px-3 py-2 text-sm text-slate-700 outline-none focus:border-indigo-400 focus:ring-1 focus:ring-indigo-100 cursor-pointer">
                    <option value="EMPLOYEE_DOC">Document standard</option>
                    <option value="CONTRACT">Contrat (nécessite signature)</option>
                </select>
            </div>
            {% endif %}

            <div id="directorLabelContainer" class="space-y-1.5 hidden">
                <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-wider">Mention de signature</label>
                <input type="text" name="director_label" placeholder="Ex: Lu et approuvé, le Directeur," class="w-full bg-slate-50 border border-slate-200 rounded-lg px-4 py-2 text-sm text-slate-700 focus:ring-1 focus:ring-indigo-100 focus:border-indigo-400 outline-none">
            </div>

            <div class="space-y-1.5">
                <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-wider">Fichier PDF</label>
                <div class="relative group">
                    <input type="file" name="file" id="documentFileInput" required accept=".pdf,.doc,.docx,.jpg,.jpeg,.png" class="absolute inset-0 opacity-0 cursor-pointer z-10 w-full h-full" onchange="document.getElementById('fileNameDisplay').textContent = this.files[0] ? this.files[0].name : 'Sélectionner un fichier'">
                    <div class="bg-slate-50 border border-dashed border-slate-200 group-hover:border-indigo-400 group-hover:bg-indigo-50/30 rounded-lg p-6 py-8 text-center transition-all pointer-events-none">
                        <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" class="mx-auto mb-2 text-slate-300"><path d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"></path></svg>
                        <p id="fileNameDisplay" class="text-xs font-bold text-slate-400 truncate px-4 text-center">Sélectionner un fichier PDF, Word ou Image</p>
                    </div>
                </div>
            </div>

            <div class="space-y-1.5">
                <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-wider">Commentaire (optionnel)</label>
                <textarea name="message" rows="2" placeholder="Ajouter une note..." class="w-full bg-slate-50 border border-slate-200 rounded-lg px-4 py-2 text-sm text-slate-700 focus:ring-1 focus:ring-indigo-100 focus:border-indigo-400 outline-none resize-none"></textarea>
            </div>

            <div class="flex gap-3 pt-2">
                <button type="button" onclick="closeModal('send-doc-modal')" class="flex-1 py-2.5 bg-slate-100 text-slate-700 font-bold rounded-lg hover:bg-slate-200 transition-all text-xs uppercase tracking-wider">Annuler</button>
                <button type="submit" class="flex-1 py-2.5 bg-indigo-600 text-white font-bold rounded-lg hover:bg-slate-900 transition-all text-xs uppercase tracking-wider shadow-md">Envoyer le document</button>
            </div>
        </form>
    </div>
</div>

{# ===== MODAL: Signer le contrat ===== #}
<div id="sign-doc-modal" class="fixed inset-0 bg-slate-950/40 backdrop-blur-sm z-[600] hidden items-center justify-center p-4">
    <div class="bg-white rounded-xl w-full max-w-sm shadow-xl animate-modal-in overflow-hidden border border-slate-200">
        <div class="flex items-center justify-between px-6 py-4 border-b border-slate-100">
            <div>
                <h3 class="text-sm font-bold text-slate-900 uppercase tracking-wider">Signer le contrat</h3>
                <p id="sign-doc-title" class="text-[10px] text-indigo-600 font-bold truncate max-w-[200px] mt-0.5"></p>
            </div>
            <button onclick="closeModal('sign-doc-modal')" class="w-8 h-8 flex items-center justify-center bg-slate-50 hover:bg-slate-100 rounded-lg transition-colors">
                <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M6 18L18 6M6 6l12 12"></path></svg>
            </button>
        </div>
        <form id="sign-doc-form" method="POST" class="p-6 space-y-4">
            <p class="text-[10px] text-slate-500 italic">Veuillez signer à l'intérieur du cadre ci-dessous :</p>
            <div class="relative bg-slate-50 border border-slate-200 rounded-lg overflow-hidden" style="height:160px">
                <canvas id="doc-signature-pad" class="absolute inset-0 w-full h-full touch-none cursor-crosshair"></canvas>
                <button type="button" id="clear-doc-signature" class="absolute bottom-2 right-2 z-20 w-7 h-7 flex items-center justify-center bg-white border border-slate-200 text-slate-400 hover:text-rose-500 rounded-lg transition-all shadow-sm">
                    <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                </button>
            </div>
            <input type="hidden" name="signature" id="doc-signature-input">
            <div class="flex gap-3">
                <button type="button" onclick="closeModal('sign-doc-modal')" class="flex-1 py-2.5 bg-slate-100 text-slate-700 font-bold rounded-lg hover:bg-slate-200 transition-all text-xs uppercase tracking-wider">Annuler</button>
                <button type="submit" class="flex-1 py-2.5 bg-emerald-600 text-white font-bold rounded-lg hover:bg-slate-900 transition-all text-xs uppercase tracking-wider shadow-md">Signer le document ✓</button>
            </div>
        </form>
    </div>
</div>

{# ===== MODAL: Signature Directeur ===== #}
{% if canEdit %}
<div id="director-signature-modal" class="fixed inset-0 bg-slate-950/40 backdrop-blur-sm z-[600] hidden items-center justify-center p-4">
    <div class="bg-white rounded-xl w-full max-w-sm shadow-xl animate-modal-in overflow-hidden border border-slate-200">
        <div class="flex items-center justify-between px-6 py-4 border-b border-slate-100">
            <div>
                <h3 class="text-sm font-bold text-slate-900 uppercase tracking-wider">Ma Signature Directeur</h3>
                <p class="text-[10px] text-slate-400 mt-0.5">Enregistrer votre signature officielle</p>
            </div>
            <button onclick="closeModal('director-signature-modal')" class="w-8 h-8 flex items-center justify-center bg-slate-50 hover:bg-slate-100 rounded-lg transition-colors">
                <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M6 18L18 6M6 6l12 12"></path></svg>
            </button>
        </div>
        <div class="p-6 space-y-4">
            {% if app.user.signature %}
            <div class="p-3 bg-slate-50 border border-slate-100 rounded-lg">
                <label class="block text-[9px] font-bold text-slate-500 uppercase tracking-wider mb-2">Signature actuelle :</label>
                <img src="{{ app.user.signature }}" alt="Ma Signature" class="max-h-12 mx-auto mix-blend-multiply opacity-80">
            </div>
            {% endif %}
            <div class="relative bg-slate-50 border border-slate-200 rounded-lg overflow-hidden" style="height:140px">
                <canvas id="director-signature-pad" class="absolute inset-0 w-full h-full touch-none cursor-crosshair"></canvas>
                <button type="button" onclick="directorPad.clear()" class="absolute bottom-2 right-2 z-20 w-7 h-7 flex items-center justify-center bg-white border border-slate-200 text-slate-400 hover:text-rose-500 rounded-lg transition-all shadow-sm">
                    <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                </button>
            </div>
            <div class="flex gap-3">
                <button type="button" onclick="closeModal('director-signature-modal')" class="flex-1 py-2.5 bg-slate-100 text-slate-700 font-bold rounded-lg hover:bg-slate-200 transition-all text-xs uppercase tracking-wider">Annuler</button>
                <button type="button" onclick="saveDirectorSignature()" class="flex-1 py-2.5 bg-indigo-600 text-white font-bold rounded-lg hover:bg-emerald-600 transition-all text-xs uppercase tracking-wider shadow-md">Enregistrer ✓</button>
            </div>
        </div>
    </div>
</div>
{% endif %}

<script src="https://cdn.jsdelivr.net/npm/signature_pad@4.1.7/dist/signature_pad.umd.min.js"></script>
<script>
function toggleDirectorLabel(val) {
    const container = document.getElementById('directorLabelContainer');
    const fileInput = document.getElementById('documentFileInput');
    if (container) {
        if (val === 'CONTRACT') {
            container.classList.remove('hidden');
            if (fileInput) fileInput.setAttribute('accept', '.pdf');
        } else {
            container.classList.add('hidden');
            if (fileInput) fileInput.setAttribute('accept', '.pdf,.doc,.docx,.jpg,.jpeg,.png');
        }
    }
}

let docPad = null, directorPad = null;
function resizeCanvas(mode) {
    const ratio = Math.max(window.devicePixelRatio || 1, 1);
    const canvas = document.getElementById(mode === 'director' ? 'director-signature-pad' : 'doc-signature-pad');
    if (!canvas) return;
    canvas.width = canvas.offsetWidth * ratio;
    canvas.height = canvas.offsetHeight * ratio;
    canvas.getContext('2d').scale(ratio, ratio);
}
function openModal(id) { 
    const m = document.getElementById(id); if (!m) return;
    m.classList.remove('hidden'); m.classList.add('flex');
    if (id === 'director-signature-modal') {
        const can = document.getElementById('director-signature-pad');
        if (can && !directorPad) directorPad = new SignaturePad(can, { penColor: 'rgb(15,23,42)' });
        setTimeout(() => resizeCanvas('director'), 50);
    }
}
function closeModal(id) {
    const m = document.getElementById(id); if (m) { m.classList.add('hidden'); m.classList.remove('flex'); }
}
function openSignModal(id, title) {
    document.getElementById('sign-doc-form').action = `/rh/documents/sign/${id}`;
    document.getElementById('sign-doc-title').textContent = title;
    openModal('sign-doc-modal');
    const can = document.getElementById('doc-signature-pad');
    if (can && !docPad) docPad = new SignaturePad(can, { penColor: 'rgb(15,23,42)' });
    setTimeout(() => resizeCanvas('doc'), 50);
}
function saveDirectorSignature() {
    if (!directorPad || directorPad.isEmpty()) { alert('Signez d\'abord.'); return; }
    const formData = new URLSearchParams(); formData.append('signature', directorPad.toDataURL());
    fetch('{{ path('app_rh_document_save_director_signature') }}', {
        method: 'POST', body: formData.toString(),
        headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'X-Requested-With': 'XMLHttpRequest' }
    }).then(r => r.json()).then(d => d.success ? location.reload() : alert('Erreur')).catch(() => alert('Erreur réseau'));
}
document.addEventListener('DOMContentLoaded', () => {
    document.getElementById('sign-doc-form')?.addEventListener('submit', e => {
        if (!docPad || docPad.isEmpty()) { e.preventDefault(); alert('Signez le contrat.'); return; }
        document.getElementById('doc-signature-input').value = docPad.toDataURL();
    });
    document.getElementById('clear-doc-signature')?.addEventListener('click', () => docPad?.clear());
});
function filterSendEmployees(magasin) {
    const select = document.getElementById('send_employee_select');
    const options = select.querySelectorAll('option');
    select.value = ""; 
    
    options.forEach(opt => {
        if (opt.value === "") {
            opt.style.display = ""; 
            return;
        }
        const optMag = opt.getAttribute('data-magasin');
        if (!magasin || optMag === magasin) {
            opt.style.display = "";
        } else {
            opt.style.display = "none";
        }
    });
}
</script>
<style>
@keyframes modal-in { from { opacity: 0; transform: scale(0.98) translateY(10px); } to { opacity:1; transform: scale(1) translateY(0); } }
.animate-modal-in { animation: modal-in .2s ease-out both; }
.truncate { white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
</style>
{% endblock %}
