{% extends 'base.html.twig' %}
{% block title %}Documents RH | LSDJ{% endblock %}

{% block body %}
<div class="min-h-screen bg-slate-50 py-2 sm:py-4 px-0 sm:px-4 lg:px-8">
<div class="max-w-7xl mx-auto">

    {# Header #}
    <div class="mb-4 sm:mb-6 px-3 sm:px-0">
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
            <div>
                <h1 class="text-xl sm:text-2xl font-black text-slate-900 tracking-tight">Documents & Contrats</h1>
                <p class="text-xs text-slate-500 mt-0.5 flex items-center gap-2">
                    <span class="w-2 h-2 bg-emerald-500 rounded-full animate-pulse"></span>
                    <span>Portail RH • LSDJ Group</span>
                </p>
            </div>
            <div class="flex items-center gap-2">
                {% if canEdit %}
                    <button onclick="openModal('director-signature-modal')" class="flex-1 sm:flex-none inline-flex items-center justify-center gap-2 bg-white text-slate-900 font-bold py-2 px-4 rounded-lg hover:bg-slate-50 transition-all text-[11px] uppercase tracking-wider border border-slate-200 shadow-sm relative">
                        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
                        <span>Signature</span>
                        {% if app.user.signature %}
                            <span class="absolute -top-1 -right-1 flex h-2.5 w-2.5">
                                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
                                <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-emerald-500"></span>
                            </span>
                        {% endif %}
                    </button>
                {% endif %}
                <button onclick="openModal('send-doc-modal')" class="flex-1 sm:flex-none inline-flex items-center justify-center gap-2 bg-indigo-600 text-white font-bold py-2 px-6 rounded-lg hover:bg-indigo-700 transition-all text-[11px] uppercase tracking-wider shadow-sm">
                    <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path d="M12 4v16m8-8H4"></path></svg>
                    {{ canEdit ? 'Envoyer' : 'Déposer' }}
                </button>
            </div>
        </div>
    </div>

{# PENDING REVIEW SECTION (FOR DIRECTOR) #}
{% if canEdit and pendingDocuments|length > 0 %}
<section class="mb-6 px-3 sm:px-0">
    <div class="bg-indigo-600 rounded-lg p-4 text-white shadow-md relative overflow-hidden">
        <div class="absolute -right-4 -top-4 w-24 h-24 bg-white/10 rounded-full blur-2xl"></div>
        <div class="relative z-10">
            <div class="flex items-center gap-3 mb-4">
                <div class="w-10 h-10 bg-white/20 rounded-lg flex items-center justify-center backdrop-blur-sm">
                    <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                </div>
                <div>
                    <h3 class="text-[11px] font-black uppercase tracking-wider mb-0.5">Dossiers à traiter</h3>
                    <p class="text-[9px] font-bold text-white/60 uppercase tracking-widest">Votre signature est attendue</p>
                </div>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-3">
                {% for doc in pendingDocuments %}
                    <div class="bg-white/10 border border-white/20 backdrop-blur-md rounded-lg p-3 flex items-center gap-3 transition-all hover:bg-white/20 group">
                        <div class="w-9 h-9 rounded-lg bg-white/10 flex items-center justify-center text-[10px] font-black uppercase shadow-inner">
                            {{ doc.targetUser ? (doc.targetUser.prenom|first ~ doc.targetUser.nom|first) : '??' }}
                        </div>
                        <div class="min-w-0 flex-1">
                            <p class="text-xs font-bold truncate group-hover:text-indigo-200 transition-colors">{{ doc.title }}</p>
                            <p class="text-[9px] font-bold text-white/60 uppercase tracking-widest truncate">{{ doc.targetUser ? (doc.targetUser.prenom ~ ' ' ~ doc.targetUser.nom) : 'Général' }}</p>
                        </div>
                        <a href="{{ path('app_rh_document_stream', {id: doc.id}) }}" target="_blank" class="shrink-0 w-8 h-8 bg-white text-indigo-600 rounded-lg flex items-center justify-center hover:scale-105 transition-transform shadow-md" title="Voir le document">
                            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg>
                        </a>
                    </div>
                {% endfor %}
            </div>
        </div>
    </div>
</section>
{% endif %}

{# FILTERS & LIST SECTION #}
<div id="documents-container" data-employees="{{ employes|json_encode|e('html_attr') }}">

    {% if canEdit %}
    <div class="bg-white rounded-lg shadow-sm border border-slate-200 p-3 sm:p-4 transition-all mb-4">
        <div class="flex flex-col xl:flex-row xl:items-center gap-4">
            <div class="flex items-center gap-3 flex-1 min-w-0">
                <div class="shrink-0 w-8 h-8 bg-slate-50 rounded-lg flex items-center justify-center text-slate-400">
                    <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg>
                </div>
                <div class="flex-1 min-w-0">
                    <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-1">Établissement</label>
                    <select id="filter_magasin_select" onchange="updateFilters()" class="w-full bg-slate-50 border border-slate-200 rounded-lg px-3 py-1.5 text-xs font-bold text-slate-700 focus:ring-1 focus:ring-indigo-100 focus:border-indigo-400 outline-none cursor-pointer h-9">
                        <option value="">Tous les établissements</option>
                        {% for mag in magasins %}
                            <option value="{{ mag }}" {{ currentMagasin == mag ? 'selected' : '' }}>{{ mag|upper }}</option>
                        {% endfor %}
                    </select>
                </div>
            </div>
            
            <div class="hidden xl:block w-[1px] h-10 bg-slate-100"></div>
            
            <div class="flex items-center gap-3 flex-1 min-w-0">
                <div class="shrink-0 w-8 h-8 bg-slate-50 rounded-lg flex items-center justify-center text-slate-400">
                    <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
                </div>
                <div class="flex-1 min-w-0">
                    <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-1">Employé</label>
                    <select id="filter_employee_select" onchange="updateFilters()" class="w-full bg-slate-50 border border-slate-200 rounded-lg px-3 py-1.5 text-xs font-bold text-slate-700 focus:ring-1 focus:ring-indigo-100 focus:border-indigo-400 outline-none cursor-pointer h-9">
                        <option value="">Tous les employés</option>
                        {% for emp in employes %}
                            <option value="{{ emp.id }}" data-magasin="{{ emp.magasin }}" {{ currentEmployee == emp.id ? 'selected' : '' }}>{{ emp.prenom }} {{ emp.nom }}</option>
                        {% endfor %}
                    </select>
                </div>
            </div>

            {% if currentMagasin or currentEmployee %}
            <div id="reset-button-container" class="xl:ml-auto">
                <button onclick="resetFilters()" class="inline-flex items-center justify-center gap-2 px-4 py-2 bg-rose-50 text-rose-600 hover:bg-rose-100 rounded-lg text-xs font-bold uppercase tracking-wider transition-colors w-full xl:w-auto h-9">
                    <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M6 18L18 6M6 6l12 12"></path></svg>
                    Réinitialiser
                </button>
            </div>
            {% endif %}
        </div>
    </div>
</div>
{% endif %}

<script>
// Store all employees data from the rendered options
let allEmployees = [];

function initializeEmployeesData() {
    const employeeSelect = document.getElementById('filter_employee_select');
    if (!employeeSelect) return;
    
    const options = employeeSelect.querySelectorAll('option[value]:not([value=""])');
    allEmployees = [];
    
    options.forEach(function(option) {
        allEmployees.push({
            id: option.value,
            name: option.textContent,
            magasin: option.getAttribute('data-magasin')
        });
    });
    
    console.log('Initialized', allEmployees.length, 'employees');
}

function updateFilters() {
    const magasinSelect = document.getElementById('filter_magasin_select');
    const employeeSelect = document.getElementById('filter_employee_select');
    
    if (!magasinSelect || !employeeSelect) {
        console.error('Select elements not found!');
        return;
    }
    
    const selectedMagasin = magasinSelect.value;
    const currentValue = employeeSelect.value;
    
    console.log('Filtering by magasin:', selectedMagasin);
    
    // Rebuild employee dropdown
    employeeSelect.innerHTML = '<option value="">Tous les employés</option>';
    
    let hasCurrentValue = false;
    let addedCount = 0;
    
    allEmployees.forEach(function(emp) {
        // Show all if no magasin selected, or only matching magasin
        if (!selectedMagasin || emp.magasin === selectedMagasin) {
            const option = document.createElement('option');
            option.value = emp.id;
            option.textContent = emp.name;
            option.setAttribute('data-magasin', emp.magasin);
            
            if (emp.id === currentValue) {
                option.selected = true;
                hasCurrentValue = true;
            }
            
            employeeSelect.appendChild(option);
            addedCount++;
        }
    });
    
    console.log('Added', addedCount, 'employees');
    
    // Clear value if current selection not in list
    if (!hasCurrentValue && selectedMagasin) {
        employeeSelect.value = '';
    }
    
    updateDocumentsList();
}

function resetFilters() {
    const magasinSelect = document.getElementById('filter_magasin_select');
    const employeeSelect = document.getElementById('filter_employee_select');
    
    if (magasinSelect) magasinSelect.value = '';
    if (employeeSelect) employeeSelect.value = '';
    
    // Reset employee dropdown to show all
    employeeSelect.innerHTML = '<option value="">Tous les employés</option>';
    allEmployees.forEach(function(emp) {
        const option = document.createElement('option');
        option.value = emp.id;
        option.textContent = emp.name;
        option.setAttribute('data-magasin', emp.magasin);
        employeeSelect.appendChild(option);
    });
    
    updateDocumentsList();
}

function updateDocumentsList() {
    const magasinSelect = document.getElementById('filter_magasin_select');
    const employeeSelect = document.getElementById('filter_employee_select');
    
    const magasin = magasinSelect ? magasinSelect.value : '';
    const employee = employeeSelect ? employeeSelect.value : '';
    
    const url = new URL(window.location.href);
    url.searchParams.delete('magasin');
    url.searchParams.delete('employee');
    url.searchParams.delete('page');
    
    if (magasin) url.searchParams.set('magasin', magasin);
    if (employee) url.searchParams.set('employee', employee);
    
    window.history.pushState({}, '', url);
    fetchDocuments(url.toString());
    updateResetButton();
}

function fetchDocuments(url) {
    const container = document.getElementById('documents-list-container');
    if (!container) return;
    
    container.style.opacity = '0.5';
    
    fetch(url, {headers: {'X-Requested-With': 'XMLHttpRequest'}})
        .then(r => r.text())
        .then(html => {
            const parser = new DOMParser();
            const doc = parser.parseFromString(html, 'text/html');
            const newContent = doc.getElementById('documents-list-container');
            if (newContent) {
                container.innerHTML = newContent.innerHTML;
                attachPaginationListeners();
            }
        })
        .catch(e => console.error('Fetch error:', e))
        .finally(() => container.style.opacity = '1');
}

function attachPaginationListeners() {
    document.querySelectorAll('.portal-pagination a').forEach(link => {
        link.addEventListener('click', function(e) {
            e.preventDefault();
            fetchDocuments(this.href);
        });
    });
}

function updateResetButton() {
    const magasinSelect = document.getElementById('filter_magasin_select');
    const employeeSelect = document.getElementById('filter_employee_select');
    
    const hasFilters = (magasinSelect && magasinSelect.value) || 
                       (employeeSelect && employeeSelect.value);
    const btn = document.getElementById('reset-button-container');
    if (btn) btn.style.display = hasFilters ? 'block' : 'none';
}

// Initialize when DOM is ready
document.addEventListener('DOMContentLoaded', function() {
    console.log('Initializing...');
    initializeEmployeesData();
    attachPaginationListeners();
    updateResetButton();
});
</script>

    <div id="documents-list-container" class="px-3 sm:px-0">
    {% if pagination|length == 0 %}
    <div class="bg-white rounded-lg border border-slate-200 py-12 text-center shadow-sm">
        <div class="w-12 h-12 bg-slate-50 rounded-full flex items-center justify-center mx-auto mb-3">
            <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" class="text-slate-300"><path d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
        </div>
        <p class="text-xs font-bold text-slate-400 uppercase tracking-widest">Aucun document trouvé</p>
    </div>
{% else %}
    {# ADAPTIVE CARDS VIEW (For screens < 1280px) #}
    <div class="xl:hidden space-y-3">
        {% for doc in pagination %}
            <div class="bg-white border border-slate-200 rounded-lg p-4 shadow-sm space-y-3">
                <div class="flex items-start justify-between gap-3">
                    <div class="flex items-center gap-3 min-w-0">
                        <div class="w-9 h-9 bg-slate-50 rounded-lg flex items-center justify-center text-slate-400 shrink-0">
                            <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"></path></svg>
                        </div>
                        <div class="min-w-0">
                            <h4 class="text-xs font-bold text-slate-900 leading-tight truncate">{{ doc.title }}</h4>
                            <p class="text-[10px] text-slate-400 mt-0.5">{{ doc.uploadedAt|date('d/m/Y à H:i') }}</p>
                        </div>
                    </div>
                    <div class="shrink-0">
                        <span class="inline-flex px-1.5 py-0.5 rounded text-[9px] font-bold uppercase tracking-wider {{ doc.type == 'CONTRACT' ? 'bg-indigo-50 text-indigo-600' : 'bg-slate-50 text-slate-500' }}">
                            {{ doc.type == 'CONTRACT' ? 'Contrat' : 'Fichier' }}
                        </span>
                    </div>
                </div>
                
                {% if doc.message %}
                    <p class="text-[11px] text-slate-600 bg-slate-50 p-2.5 rounded-lg italic">"{{ doc.message }}"</p>
                {% endif %}

                <div class="flex items-center justify-between border-t border-slate-50 pt-3">
                    {% if canEdit or isFullAccess %}
                        <div class="flex items-center gap-2">
                            <div class="w-6 h-6 bg-slate-100 rounded-full flex items-center justify-center text-[8px] font-bold text-slate-500 uppercase">{{ doc.targetUser ? doc.targetUser.prenom|first : '?' }}</div>
                            <span class="text-[10px] font-bold text-slate-700 truncate max-w-[100px]">{{ doc.targetUser ? (doc.targetUser.prenom ~ ' ' ~ doc.targetUser.nom) : 'Direction' }}</span>
                        </div>
                    {% endif %}
                    
                    {% if doc.type == 'CONTRACT' %}
                        <span class="inline-flex items-center gap-1 text-[9px] font-bold uppercase tracking-wider {{ doc.status == 'SIGNED' ? 'text-emerald-600' : 'text-amber-500' }}">
                            <span class="w-1.5 h-1.5 rounded-full {{ doc.status == 'SIGNED' ? 'bg-emerald-500' : 'bg-amber-500 animate-pulse' }}"></span>
                            {{ doc.status == 'SIGNED' ? 'Signé' : 'En attente' }}
                        </span>
                    {% endif %}
                </div>

                <div class="flex items-center gap-2 pt-1">
                    <a href="{{ path('app_rh_document_stream', {id: doc.id}) }}" target="_blank" class="flex-1 inline-flex items-center justify-center gap-2 bg-slate-100 text-slate-700 font-bold py-2 rounded-lg hover:bg-slate-200 transition-all text-[10px] uppercase tracking-wider">
                        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg>
                        Ouvrir
                    </a>
                    {% if doc.type == 'CONTRACT' and doc.status == 'PENDING_SIGNATURE' and doc.targetUser == app.user %}
                        <button onclick="openSignModal('{{ doc.id }}', '{{ doc.title|e('js') }}')" class="flex-1 inline-flex items-center justify-center gap-2 bg-indigo-600 text-white font-bold py-2 rounded-lg hover:bg-indigo-700 transition-all text-[10px] uppercase tracking-wider shadow-sm">
                            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M15.232 5.232l3.536 3.536M9 11l6-6 3 3-6 6H9v-3z"></path></svg>
                            Signer
                        </button>
                    {% endif %}
                    {% if canEdit %}
                        <form action="{{ path('app_rh_document_delete', {id: doc.id}) }}" method="POST" onsubmit="return confirm('Supprimer ce document ?');" class="shrink-0">
                            <button type="submit" class="w-9 h-9 flex items-center justify-center bg-white text-slate-400 border border-slate-200 hover:text-rose-600 hover:bg-rose-50 rounded-lg transition-all">
                                <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                            </button>
                        </form>
                    {% endif %}
                </div>
            </div>
        {% endfor %}
    </div>

    {# DESKTOP TABLE VIEW (xl screens >= 1280px) #}
    <div class="hidden xl:block bg-white border border-slate-200 rounded-lg overflow-hidden shadow-sm">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-slate-50 border-b border-slate-100">
                        <th class="px-4 py-2.5 text-[10px] font-bold text-slate-500 uppercase tracking-wider">Document</th>
                        {% if canEdit %}
                        <th class="px-4 py-2.5 text-[10px] font-bold text-slate-500 uppercase tracking-wider">Employé</th>
                        {% endif %}
                        <th class="px-4 py-2.5 text-[10px] font-bold text-slate-500 uppercase tracking-wider">Type</th>
                        <th class="px-4 py-2.5 text-[10px] font-bold text-slate-500 uppercase tracking-wider">Statut</th>
                        <th class="px-4 py-2.5 text-[10px] font-bold text-slate-500 uppercase tracking-wider">Date</th>
                        <th class="px-4 py-2.5 text-[10px] font-bold text-slate-500 uppercase tracking-wider text-right">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-50">
                    {% for doc in pagination %}
                    <tr class="hover:bg-slate-50/80 transition-colors">
                        <td class="px-4 py-3">
                            <div class="flex items-center gap-3">
                                <div class="w-8 h-8 bg-slate-50 rounded-lg flex items-center justify-center text-slate-400 shrink-0 border border-slate-100">
                                    <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"></path></svg>
                                </div>
                                <div class="min-w-0">
                                    <p class="text-xs font-bold text-slate-900 truncate max-w-[200px]">{{ doc.title }}</p>
                                    {% if doc.message %}
                                    <p class="text-[10px] text-slate-400 italic mt-0.5 truncate max-w-[200px]">"{{ doc.message }}"</p>
                                    {% endif %}
                                </div>
                            </div>
                        </td>
                        {% if canEdit or isFullAccess %}
                        <td class="px-4 py-3">
                            <div class="flex items-center gap-2">
                                <div class="w-6 h-6 bg-slate-200 rounded-full flex items-center justify-center text-[8px] font-bold text-slate-600 uppercase shrink-0">{{ doc.targetUser ? doc.targetUser.prenom|first : '?' }}</div>
                                <span class="text-[10px] font-bold text-slate-700 truncate max-w-[120px]">{{ doc.targetUser ? (doc.targetUser.prenom ~ ' ' ~ doc.targetUser.nom) : 'Direction' }}</span>
