                        <td class="px-4 py-3">
                            <span class="inline-flex px-1.5 py-0.5 rounded text-[9px] font-bold uppercase tracking-wider {{ doc.type == 'CONTRACT' ? 'bg-indigo-50 text-indigo-600' : 'bg-slate-100 text-slate-500' }}">
                                {{ doc.type == 'CONTRACT' ? 'Contrat' : 'Fichier' }}
