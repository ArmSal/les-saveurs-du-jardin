{% extends 'base.html.twig' %}

{% block title %}Contact - Les Saveurs Du Jardin{% endblock %}

{% block body %}
<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 card shadow p-4">
            <h1 class="text-center mb-4">🌿 Contactez-nous</h1>

            {% for message in app.flashes('success') %}
                <div class="alert alert-success mt-3">
                    {{ message }}
                </div>
            {% endfor %}

            {{ form_start(form) }}
                <div class="mb-3">
                    {{ form_row(form.name) }}
                </div>
                <div class="mb-3">
                    {{ form_row(form.email) }}
                </div>
                <div class="mb-3">
                    {{ form_row(form.message) }}
                </div>
                <div class="d-grid">
                    {{ form_widget(form.envoyer) }}
                </div>
            {{ form_end(form) }}
        </div>
    </div>
</div>
{% endblock %}
