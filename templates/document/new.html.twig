{% extends 'base.html.twig' %}
{% block title %}Nouveau Document{% endblock %}
{% block body %}
<div class="min-h-screen bg-[#f8fafc] py-6 px-4 sm:px-6 font-sans">
	<div class="max-w-2xl mx-auto">

		<header class="mb-6">
			<a href="{{ path('app_document_index') }}" class="inline-flex items-center gap-1.5 text-[9px] font-black text-slate-400 uppercase tracking-widest hover:text-indigo-600 transition-colors mb-4 group">
				<svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24" class="group-hover:-translate-x-0.5 transition-transform"><path d="M19 12H5M12 19l-7-7 7-7"></path></svg>
				Retour
			</a>
			<div class="flex items-center gap-3">
				<div class="w-10 h-10 bg-emerald-50 rounded-2xl flex items-center justify-center shrink-0">
					<svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" class="text-emerald-600"><path d="M9 13h6m-3-3v6m5 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
				</div>
				<div>
					<h1 class="text-2xl font-black text-slate-950 tracking-tight uppercase leading-none">Nouveau Document</h1>
					<p class="text-[10px] font-bold text-slate-400 mt-0.5 italic">Ajoutez et configurez les droits d'accès de votre fichier</p>
				</div>
			</div>
		</header>

		<div class="bg-white border border-slate-200 rounded-[2rem] p-6 sm:p-8 shadow-sm">
			{{ include('document/_form.html.twig') }}
		</div>

	</div>
</div>
{% endblock %}
