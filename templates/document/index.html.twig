{% extends 'base.html.twig' %}



{% block title %}Documents et Procédures | LSDJ{% endblock %}



{% macro getFileIcon(extension) %}

    {% if extension == 'pdf' %}

        <div class="w-10 h-10 rounded-lg bg-rose-50 flex items-center justify-center shrink-0">

            <svg width="20" height="20" fill="none" stroke="#f43f5e" stroke-width="1.5" viewBox="0 0 24 24">

                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/>

            </svg>

        </div>

    {% elseif extension in ['doc', 'docx'] %}

        <div class="w-10 h-10 rounded-lg bg-blue-50 flex items-center justify-center shrink-0">

            <svg width="20" height="20" fill="none" stroke="#3b82f6" stroke-width="1.5" viewBox="0 0 24 24">

                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5-3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/>

            </svg>

        </div>

    {% elseif extension in ['jpg', 'jpeg', 'png', 'gif', 'webp'] %}

        <div class="w-10 h-10 rounded-lg bg-emerald-50 flex items-center justify-center shrink-0">

            <svg width="20" height="20" fill="none" stroke="#10b981" stroke-width="1.5" viewBox="0 0 24 24">

                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 001.5-1.5V6a1.5 1.5 0 00-1.5-1.5H3.75A1.5 1.5 0 002.25 6v12a1.5 1.5 0 001.5 1.5zm10.5-11.25h.008v.008h-.008V8.25zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z"/>

            </svg>

        </div>

    {% else %}

        <div class="w-10 h-10 rounded-lg bg-slate-50 flex items-center justify-center shrink-0">

            <svg width="20" height="20" fill="none" stroke="#64748b" stroke-width="1.5" viewBox="0 0 24 24">

                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/>

            </svg>

        </div>

    {% endif %}

{% endmacro %}



{% macro renderDocumentCard(doc, isAdmin) %}

    {% set extension = doc.filename|split('.')|last|lower %}

    <div class="group bg-white rounded-lg border border-slate-100 hover:border-teal-200 hover:shadow-md transition-all duration-300 overflow-hidden" x-data="{ showDetails: false }">

        <div class="p-4">

            <div class="flex items-start gap-3">

                {{ _self.getFileIcon(extension) }}

                <div class="flex-1 min-w-0">

                    <h4 class="text-sm font-bold text-slate-800 truncate group-hover:text-teal-600 transition-colors">

                        <a href="{{ path('app_document_download', {'id': doc.id}) }}" target="_blank" class="hover:underline">

                            {{ doc.title }}

                        </a>

                    </h4>

                    <div class="flex items-center gap-2 mt-1.5 flex-wrap">

                        <span class="text-[10px] font-medium text-slate-400 uppercase tracking-wide">{{ extension }}</span>

                        <span class="w-1 h-1 rounded-full bg-slate-200"></span>

                        <span class="text-[10px] text-slate-400">{{ doc.uploadedAt ? doc.uploadedAt|date('d/m/Y') : '' }}</span>

                        {% if doc.rolesPermitted|length > 0 %}

                            <span class="text-[9px] px-1.5 py-0.5 bg-teal-50 text-teal-600 rounded font-medium">

                                {{ doc.rolesPermitted|length }} rôle{{ doc.rolesPermitted|length > 1 ? 's' : '' }}

                            </span>

                        {% endif %}

                    </div>

                </div>

                

                <div class="flex items-center gap-1 shrink-0">

                    <button @click="showDetails = !showDetails" type="button" 

                            class="p-2 text-slate-400 hover:text-teal-600 hover:bg-teal-50 rounded-md transition-all touch-manipulation"

                            :class="{ 'text-teal-600 bg-teal-50': showDetails }">

                        <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" class="sm:w-5 sm:h-5">

                            <circle cx="12" cy="12" r="1.5" fill="currentColor" stroke="none"/>

                            <circle cx="19" cy="12" r="1.5" fill="currentColor" stroke="none"/>

                            <circle cx="5" cy="12" r="1.5" fill="currentColor" stroke="none"/>

                        </svg>

                    </button>

                    

                    {% if isAdmin %}

                        <div class="flex sm:hidden items-center gap-1 ml-1">

                            <a href="{{ path('app_document_edit', {'id': doc.id}) }}" 

                               class="p-2 text-slate-400 hover:text-teal-600 active:bg-teal-50 rounded-md transition-all touch-manipulation"

                               title="Modifier">

                                <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">

                                    <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L6.832 19.82a4.5 4.5 0 01-1.89 1.13l-2.685.8.8-2.685a4.5 4.5 0 011.13-1.89l12.683-12.683z"/>

                                </svg>

                            </a>

                            <form method="post" action="{{ path('app_document_delete', {'id': doc.id}) }}" 

                                  onsubmit="return confirm('Supprimer ce document ?');" class="m-0">

                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ doc.id) }}">

                                <button type="submit" class="p-2 text-slate-400 hover:text-rose-500 active:bg-rose-50 rounded-md transition-all touch-manipulation">

                                    <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">

                                        <path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79"/>

                                    </svg>

                                </button>

                            </form>

                        </div>

                        <div class="hidden sm:flex items-center gap-1 ml-1 pl-1 border-l border-slate-100">

                            <a href="{{ path('app_document_edit', {'id': doc.id}) }}" 

                               class="p-2 text-slate-400 hover:text-teal-600 hover:bg-teal-50 rounded-md transition-all"

                               title="Modifier">

                                <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">

                                    <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L6.832 19.82a4.5 4.5 0 01-1.89 1.13l-2.685.8.8-2.685a4.5 4.5 0 011.13-1.89l12.683-12.683z"/>

                                </svg>

                            </a>

                            <form method="post" action="{{ path('app_document_delete', {'id': doc.id}) }}" 

                                  onsubmit="return confirm('Supprimer ce document ?');" class="m-0">

                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ doc.id) }}">

                                <button type="submit" class="p-2 text-slate-400 hover:text-rose-500 hover:bg-rose-50 rounded-md transition-all">

                                    <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">

                                        <path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79"/>

                                    </svg>

                                </button>

                            </form>

                        </div>

                    {% endif %}

                </div>

            </div>

            

            <div x-show="showDetails" x-collapse class="mt-3 pt-3 border-t border-slate-100">

                <div class="space-y-2 text-xs">

                    {% if doc.description %}

                        <div>

                            <span class="text-slate-400 font-medium">Description:</span>

                            <p class="text-slate-600 mt-0.5 leading-relaxed">{{ doc.description }}</p>

                        </div>

                    {% endif %}

                    <div class="flex flex-wrap gap-3">

                        <div>

                            <span class="text-slate-400 font-medium">Type:</span>

                            <span class="text-slate-700 ml-1 uppercase font-semibold">{{ extension }}</span>

                        </div>

                        <div>

                            <span class="text-slate-400 font-medium">Ajouté le:</span>

                            <span class="text-slate-700 ml-1">{{ doc.uploadedAt ? doc.uploadedAt|date('d/m/Y à H:i') : '-' }}</span>

                        </div>

                    </div>

                    {% if doc.rolesPermitted|length > 0 %}

                        <div>

                            <span class="text-slate-400 font-medium">Visible par:</span>

                            <div class="flex flex-wrap gap-1 mt-1.5">

                                {% for role in doc.rolesPermitted %}

                                    {% if role is not iterable %}
                                        {% set roleName = role %}
                                    {% elseif role.name is defined %}
                                        {% set roleName = role.name %}
                                    {% else %}
                                        {% set roleName = '' %}
                                    {% endif %}

                                    {% if roleName %}
                                        <span class="px-2 py-1 bg-teal-50 text-teal-600 rounded-md text-[10px] font-bold border border-teal-100">

                                            {{ roleName|replace({'ROLE_': ''}) }}

                                        </span>
                                    {% endif %}

                                {% endfor %}

                            </div>

                        </div>

                    {% endif %}

                    <div class="pt-2">

                        <a href="{{ path('app_document_download', {'id': doc.id}) }}" target="_blank" 

                           class="inline-flex items-center gap-1.5 px-4 py-2 bg-teal-500 hover:bg-teal-600 text-white rounded-md text-xs font-bold transition-colors">

                            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">

                                <path stroke-linecap="round" stroke-linejoin="round" d="M12 10.5v6m3-3H9m4.06-7.19l-2.12-2.12a1.5 1.5 0 00-1.061-.44H4.5A2.25 2.25 0 002.25 6v12a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18V9a2.25 2.25 0 00-2.25-2.25h-5.379a1.5 1.5 0 01-1.06-.44z"/>

                            </svg>

                            Télécharger

                        </a>

                    </div>

                </div>

            </div>

        </div>

    </div>

{% endmacro %}



{% macro renderFolderCard(folder, folderDocsMap, isAdmin, level, visibleFolderIds) %}

    <div class="group" x-data="{ expanded: {{ level == 0 ? 'true' : 'false' }} }">

        <div class="flex items-center gap-3 p-3 rounded-lg hover:bg-slate-50 transition-colors cursor-pointer"

             @click="expanded = !expanded">

            <button type="button" class="p-1 text-slate-400 hover:text-teal-500 transition-colors">

                <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"

                     :class="{ 'rotate-90': expanded }" class="transition-transform duration-200">

                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>

                </svg>

            </button>

            <div class="w-10 h-10 rounded-lg bg-gradient-to-br from-teal-400 to-cyan-400 flex items-center justify-center shrink-0 shadow-sm">

                <svg width="20" height="20" fill="white" viewBox="0 0 24 24">

                    <path d="M20 6h-8l-2-2H4c-1.11 0-1.99.89-1.99 2L2 18c0 1.11.89 2 2 2h16c1.11 0 2-.89 2-2V8c0-1.11-.89-2-2-2zm0 12H4V8h16v10z"/>

                </svg>

            </div>

            <div class="flex-1 min-w-0">

                <h3 class="text-sm font-bold text-slate-800 truncate">{{ folder.name }}</h3>

                <div class="flex items-center gap-2 mt-0.5">

                    <span class="text-[10px] text-slate-400">

                        {{ folderDocsMap[folder.id]|default([])|length }} document{{ folderDocsMap[folder.id]|default([])|length > 1 ? 's' : '' }}

                    </span>

                    {% set visibleChildCount = 0 %}
                    {% for child in folder.children %}
                        {% if visibleFolderIds[child.id] is defined %}
                            {% set visibleChildCount = visibleChildCount + 1 %}
                        {% endif %}
                    {% endfor %}

                    {% if visibleChildCount > 0 %}

                        <span class="text-[10px] text-slate-400">

                            • {{ visibleChildCount }} sous-dossier{{ visibleChildCount > 1 ? 's' : '' }}

                        </span>

                    {% endif %}

                </div>

            </div>

            {% if isAdmin %}

                <div class="flex sm:hidden items-center gap-1 opacity-100 sm:opacity-0 group-hover:opacity-100 transition-opacity">

                    <a href="{{ path('app_document_folder_edit', {'id': folder.id}) }}" 

                       @click.stop

                       class="p-2 text-slate-400 hover:text-teal-600 active:bg-teal-50 rounded-md transition-all touch-manipulation">

                        <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">

                            <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L6.832 19.82a4.5 4.5 0 01-1.89 1.13l-2.685.8.8-2.685a4.5 4.5 0 011.13-1.89l12.683-12.683z"/>

                        </svg>

                    </a>

                    <form method="post" action="{{ path('app_document_folder_delete', {'id': folder.id}) }}" 

                          onsubmit="return confirm('Supprimer ce dossier ?');" class="m-0" @click.stop>

                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ folder.id) }}">

                        <button type="submit" class="p-2 text-slate-400 hover:text-rose-500 active:bg-rose-50 rounded-md transition-all touch-manipulation">

                            <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">

                                <path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79"/>

                            </svg>

                        </button>

                    </form>

                </div>

                <div class="hidden sm:flex items-center gap-1 opacity-0 group-hover:opacity-100 transition-opacity">

                    <a href="{{ path('app_document_folder_edit', {'id': folder.id}) }}" 

                       @click.stop

                       class="p-2 text-slate-400 hover:text-teal-600 hover:bg-teal-50 rounded-md transition-all">

                        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">

                            <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L6.832 19.82a4.5 4.5 0 01-1.89 1.13l-2.685.8.8-2.685a4.5 4.5 0 011.13-1.89l12.683-12.683z"/>

                        </svg>

                    </a>

                    <form method="post" action="{{ path('app_document_folder_delete', {'id': folder.id}) }}" 

                          onsubmit="return confirm('Supprimer ce dossier ?');" class="m-0" @click.stop>

                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ folder.id) }}">

                        <button type="submit" class="p-2 text-slate-400 hover:text-rose-500 hover:bg-rose-50 rounded-md transition-all">

                            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">

                                <path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79"/>

                            </svg>

                        </button>

                    </form>

                </div>

            {% endif %}

        </div>

        

            <div x-show="expanded" x-collapse class="ml-2 sm:ml-6 pl-2 sm:pl-4 border-l-2 border-slate-100 overflow-x-hidden">

                {% if folderDocsMap[folder.id]|default(false) %}

                    <div class="py-2 space-y-2">

                        {% for doc in folderDocsMap[folder.id] %}

                            {{ _self.renderDocumentCard(doc, isAdmin) }}

                        {% endfor %}

                    </div>

                {% endif %}

                

                {% for childFolder in folder.children %}
                    {% if visibleFolderIds[childFolder.id] is defined %}
                        {{ _self.renderFolderCard(childFolder, folderDocsMap, isAdmin, level + 1, visibleFolderIds) }}
                    {% endif %}

                {% endfor %}

            </div>

    </div>

{% endmacro %}



{% block body %}

<div class="min-h-screen bg-gradient-to-br from-slate-50 to-slate-100 py-4 sm:py-8 px-0 sm:px-4 lg:px-8">

    <div class="max-w-6xl mx-auto">

        

        <div class="mb-6 sm:mb-8 px-4 sm:px-0">

            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">

                <div>

                    <h1 class="text-2xl sm:text-3xl font-black text-slate-900 tracking-tight">Documents et Procédures</h1>

                    <p class="text-sm text-slate-500 mt-1">Consultez et gérez les documents selon vos accès</p>

                </div>

                {% if isAdmin %}

                    <div class="flex items-center gap-2 w-full sm:w-auto">

                        <a href="{{ path('app_document_folder_new') }}" 

                           class="flex-1 sm:flex-none inline-flex items-center justify-center gap-2 px-3 sm:px-4 py-2.5 bg-white border border-slate-200 text-slate-700 rounded-lg text-xs font-bold uppercase tracking-wider hover:bg-slate-50 hover:border-teal-200 transition-all shadow-sm">

                            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">

                                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/>

                            </svg>

                            <span class="hidden sm:inline">Dossier</span>

                            <span class="sm:hidden">Dossier</span>

                        </a>

                        <a href="{{ path('app_document_new') }}" 

                           class="flex-1 sm:flex-none inline-flex items-center justify-center gap-2 px-3 sm:px-4 py-2.5 bg-gradient-to-r from-teal-500 to-cyan-500 text-white rounded-lg text-xs font-bold uppercase tracking-wider hover:from-teal-600 hover:to-cyan-600 transition-all shadow-md hover:shadow-lg">

                            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">

                                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/>

                            </svg>

                            <span class="hidden sm:inline">Document</span>

                            <span class="sm:hidden">Document</span>

                        </a>

                    </div>

                {% endif %}

            </div>

        </div>



        <div class="mb-6 px-4 sm:px-0">

            <div class="relative max-w-md">

                <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">

                    <svg class="h-5 w-5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">

                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>

                    </svg>

                </div>

                <input type="text" id="documentSearch" placeholder="Rechercher un document..." 

                       class="w-full pl-11 pr-4 py-3 bg-white border border-slate-200 rounded-lg text-sm text-slate-700 placeholder-slate-400 outline-none focus:border-teal-400 focus:ring-2 focus:ring-teal-100 transition-all shadow-sm">

            </div>

        </div>



        <div class="bg-white shadow-sm sm:shadow-lg sm:rounded-lg border-0 sm:border border-slate-200 overflow-hidden">

            

            <div class="px-4 sm:px-6 py-4 border-b border-slate-100 bg-gradient-to-r from-slate-50 to-white">

                <div class="flex items-center justify-between">

                    <h2 class="text-sm font-black text-slate-600 uppercase tracking-wider">Espace Documentaire</h2>

                    {% set totalDocs = rootDocs|length + folderDocsMap|reduce((carry, docs) => carry + docs|length, 0) %}

                    <span class="text-xs text-slate-400 font-medium">

                        {{ rootFolders|length }} dossier{{ rootFolders|length > 1 ? 's' : '' }} • 

                        {{ totalDocs }} document{{ totalDocs > 1 ? 's' : '' }}

                    </span>

                </div>

            </div>



            <div class="p-4 sm:p-6" id="treeContainer">

                

                {% if rootFolders|length == 0 and rootDocs|length == 0 %}

                    <div class="text-center py-12">

                        <div class="w-16 h-16 mx-auto mb-4 bg-slate-100 rounded-full flex items-center justify-center">

                            <svg width="24" height="24" fill="none" stroke="#94a3b8" stroke-width="1.5" viewBox="0 0 24 24">

                                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/>

                            </svg>

                        </div>

                        <h3 class="text-lg font-bold text-slate-700 mb-1">Votre espace documentaire est vide</h3>

                        <p class="text-sm text-slate-400 mb-4">Commencez par créer un dossier ou ajouter un document</p>

                        {% if isAdmin %}

                            <a href="{{ path('app_document_new') }}" class="inline-flex items-center gap-2 px-4 py-2 bg-teal-500 text-white rounded-lg text-sm font-bold hover:bg-teal-600 transition-colors">

                                <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">

                                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/>

                                </svg>

                                Ajouter un document

                            </a>

                        {% endif %}

                    </div>

                {% else %}

                    <div class="space-y-2">

                        {% for folder in rootFolders %}

                            {{ _self.renderFolderCard(folder, folderDocsMap, isAdmin, 0, visibleFolderIds) }}

                        {% endfor %}

                        

                        {% if rootDocs|length > 0 %}

                            <div class="pt-4 border-t border-slate-100">

                                <h3 class="text-xs font-black text-slate-400 uppercase tracking-wider mb-3 px-3">Documents sans dossier</h3>

                                <div class="space-y-2">

                                    {% for doc in rootDocs %}

                                        {{ _self.renderDocumentCard(doc, isAdmin) }}

                                    {% endfor %}

                                </div>

                            </div>

                        {% endif %}

                    </div>

                {% endif %}

            </div>

        </div>

        

        <div class="mt-4 text-center px-4 sm:px-0">

            <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">

                Les documents sont organisés par dossier avec contrôle d'accès par rôle

            </p>

        </div>

    </div>

</div>

{% endblock %}



{% block javascripts %}

{{ parent() }}

<script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>

<script>

    document.addEventListener('DOMContentLoaded', function() {

        const searchInput = document.getElementById('documentSearch');

        const container = document.getElementById('treeContainer');

        

        if (searchInput && container) {

            searchInput.addEventListener('input', function(e) {

                const term = e.target.value.toLowerCase();

                const items = container.querySelectorAll('.group');

                

                items.forEach(item => {

                    const text = item.textContent.toLowerCase();

                    if (text.includes(term)) {

                        item.style.display = '';

                    } else {

                        item.style.display = 'none';

                    }

                });

            });

        }

    });

</script>

{% endblock %}



