{% extends 'base.html.twig' %}

{% block title %}404 - Page Introuvable | Plateforme LSDJ{% endblock %}

{% block body %}
<div class="error-container">
    <div class="stars"></div>
    <div class="glow-sphere"></div>
    
    <div class="error-card">
        <div class="error-content">
            <div class="glitch-wrapper">
                <div class="glitch" data-text="404">404</div>
            </div>
            
            <div class="divider"></div>
            
            <h2>SYSTÈME : PAGE INTROUVABLE</h2>
            <p>La ressource que vous tentez d'atteindre est cryptée, déplacée ou n'existe plus dans cette dimension.</p>
            
            <div class="controls">
                <button onclick="window.history.back()" class="cyber-btn secondary">
                    <span class="btn-glitch"></span>
                    <span class="btn-label">RETOUR</span>
                </button>
                <a href="{{ path('app_home') }}" class="cyber-btn primary">
                    <span class="btn-glitch"></span>
                    <span class="btn-label">ACCUEIL</span>
                </a>
            </div>
        </div>
    </div>
</div>

<style>
    :root {
        --neon-blue: #00d2ff;
        --neon-purple: #9d50bb;
        --dark-bg: #0b0e14;
        --glass-bg: rgba(255, 255, 255, 0.03);
        --glass-border: rgba(255, 255, 255, 0.1);
    }

    .error-container {
        min-height: calc(100vh - 100px);
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--dark-bg);
        position: relative;
        overflow: hidden;
        font-family: 'Outfit', sans-serif;
        color: #fff;
    }

    .stars {
        position: absolute;
        top: 0; left: 0; width: 100%; height: 100%;
        background: radial-gradient(1px 1px at 20% 30%, #fff, rgba(0,0,0,0)),
                    radial-gradient(1.5px 1.5px at 50% 70%, #fff, rgba(0,0,0,0)),
                    radial-gradient(2px 2px at 80% 40%, #fff, rgba(0,0,0,0));
        background-size: 200px 200px;
        animation: stardrift 100s linear infinite;
        opacity: 0.3;
    }

    @keyframes stardrift {
        from { transform: translateY(0); }
        to { transform: translateY(-1000px); }
    }

    .glow-sphere {
        position: absolute;
        width: 600px;
        height: 600px;
        background: radial-gradient(circle, rgba(0, 210, 255, 0.15) 0%, rgba(157, 80, 187, 0.05) 50%, rgba(0,0,0,0) 70%);
        filter: blur(80px);
        animation: pulseGlow 10s ease-in-out infinite alternate;
    }

    @keyframes pulseGlow {
        from { transform: translate(-20%, -20%) scale(1); }
        to { transform: translate(20%, 20%) scale(1.2); }
    }

    .error-card {
        background: var(--glass-bg);
        backdrop-filter: blur(20px);
        border: 1px solid var(--glass-border);
        padding: 60px;
        border-radius: 24px;
        position: relative;
        max-width: 500px;
        width: 90%;
        text-align: center;
        box-shadow: 0 40px 100px rgba(0,0,0,0.5);
    }

    .error-card::before {
        content: '';
        position: absolute;
        top: -2px; left: -2px; right: -2px; bottom: -2px;
        background: linear-gradient(45deg, var(--neon-blue), var(--neon-purple));
        border-radius: 26px;
        z-index: -1;
        opacity: 0.3;
    }

    .glitch {
        font-size: 10rem;
        font-weight: 900;
        position: relative;
        text-shadow: 0.05em 0 0 rgba(255,0,0,0.75),
                    -0.025em -0.05em 0 rgba(0,255,0,0.75),
                    0.025em 0.05em 0 rgba(0,0,255,0.75);
        animation: glitch 500ms infinite;
        margin-bottom: 20px;
        letter-spacing: -5px;
    }

    @keyframes glitch {
        0% { text-shadow: 0.05em 0 0 rgba(255,0,0,0.75), -0.05em -0.025em 0 rgba(0,255,0,0.75), -0.025em 0.05em 0 rgba(0,0,255,0.75); }
        14% { text-shadow: 0.05em 0 0 rgba(255,0,0,0.75), -0.05em -0.025em 0 rgba(0,255,0,0.75), -0.025em 0.05em 0 rgba(0,0,255,0.75); }
        15% { text-shadow: -0.05em -0.025em 0 rgba(255,0,0,0.75), 0.025em 0.025em 0 rgba(0,255,0,0.75), -0.05em -0.05em 0 rgba(0,0,255,0.75); }
        49% { text-shadow: -0.05em -0.025em 0 rgba(255,0,0,0.75), 0.025em 0.025em 0 rgba(0,255,0,0.75), -0.05em -0.05em 0 rgba(0,0,255,0.75); }
        50% { text-shadow: 0.025em 0.05em 0 rgba(255,0,0,0.75), 0.05em 0.025em 0 rgba(0,255,0,0.75), 0.05em -0.05em 0 rgba(0,0,255,0.75); }
        99% { text-shadow: 0.025em 0.05em 0 rgba(255,0,0,0.75), 0.05em 0.025em 0 rgba(0,255,0,0.75), 0.05em -0.05em 0 rgba(0,0,255,0.75); }
        100% { text-shadow: -0.025em 0 0 rgba(255,0,0,0.75), -0.025em -0.025em 0 rgba(0,255,0,0.75), -0.025em -0.05em 0 rgba(0,0,255,0.75); }
    }

    .divider {
        height: 1px;
        background: linear-gradient(90deg, transparent, var(--glass-border), transparent);
        margin: 30px 0;
    }

    h2 {
        font-size: 1rem;
        text-transform: uppercase;
        letter-spacing: 5px;
        margin-bottom: 15px;
        color: var(--neon-blue);
        font-weight: 700;
    }

    p {
        font-size: 1.1rem;
        line-height: 1.6;
        color: rgba(255, 255, 255, 0.7);
        margin-bottom: 40px;
    }

    .controls {
        display: flex;
        gap: 20px;
        justify-content: center;
    }

    .cyber-btn {
        position: relative;
        padding: 15px 35px;
        background: transparent;
        color: #fff;
        border: none;
        cursor: pointer;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 2px;
        font-size: 0.8rem;
        transition: all 0.3s;
        text-decoration: none;
        display: inline-block;
    }

    .cyber-btn.primary {
        background: var(--neon-blue);
        box-shadow: 0 0 20px rgba(0, 210, 255, 0.3);
    }

    .cyber-btn.secondary {
        border: 1px solid var(--glass-border);
    }

    .cyber-btn:hover {
        transform: scale(1.05);
        filter: brightness(1.2);
    }

    .cyber-btn.secondary:hover {
        border-color: var(--neon-purple);
        box-shadow: 0 0 20px rgba(157, 80, 187, 0.3);
    }

    @media (max-width: 600px) {
        .glitch { font-size: 6rem; }
        .error-card { padding: 40px 20px; }
        .controls { flex-direction: column; }
    }
</style>
{% endblock %}


