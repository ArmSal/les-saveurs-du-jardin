{% extends 'base.html.twig' %}

{% block title %}Mes Notifications | Plateforme LSDJ{% endblock %}

{% block body %}
	<!-- Enterprise Header -->
	<div class="mb-8 flex flex-col md:flex-row md:items-end justify-between gap-4 pb-6 border-b border-slate-100 transition-all">
		<div class="space-y-0.5">
			<div class="inline-flex items-center gap-1.5 px-2 py-0.5 rounded-md bg-indigo-50 border-indigo-100 border mb-1">
				<span class="w-1.5 h-1.5 rounded-full bg-indigo-500"></span>
				<span class="text-[9px] font-black uppercase tracking-widest text-indigo-600">Centre de Communication</span>
			</div>
			<h1 class="text-2xl font-black text-slate-900 tracking-tight leading-none">
				Historique <span class="text-indigo-600">Notifications</span>
			</h1>
			<p class="text-slate-400 text-xs font-medium">Flux d'archivage des alertes système et messages logistiques.</p>
		</div>

		{% if pagination.getTotalItemCount > 0 %}
			<button id="mark-all-page" onclick="markAllNotificationsAsRead(event)" class="group flex items-center gap-2 px-4 py-2.5 bg-white hover:bg-slate-50 text-slate-500 text-[10px] font-black uppercase tracking-widest rounded-lg transition-all border border-slate-200 cursor-pointer w-fit">
				<svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"></path></svg>
				Tout marquer comme lu
			</button>
		{% endif %}
	</div>

	<div class="bg-white border border-slate-100 rounded-xl shadow-sm overflow-hidden mb-8">
		<div class="px-6 py-4 bg-slate-50 border-b border-slate-100 flex justify-between items-center">
			<span class="text-[9px] font-black uppercase tracking-widest text-slate-400">Journal des Messages</span>
			<span class="text-[9px] font-black text-indigo-600 uppercase tracking-widest bg-indigo-50 px-2 py-0.5 rounded border border-indigo-100">{{ pagination.getTotalItemCount }} ENTRIES</span>
		</div>

		<div class="divide-y divide-slate-50" id="notif-page-list">
			{% for notif in pagination %}
				<div class="notif-row group relative p-5 transition-all hover:bg-slate-50/50 flex gap-5 {{ notif.isRead ? '' : 'is-unread border-l-2 border-indigo-600' }}" id="notif-page-item-{{ notif.id }}">
					<div class="shrink-0">
						{% if notif.type == 'CONGE_APPROVED' %}
                            <div class="w-10 h-10 rounded-lg bg-emerald-50 text-emerald-600 flex items-center justify-center border border-emerald-100">
                                <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"/></svg>
                            </div>
						{% elseif notif.type == 'CONGE_REJECTED' %}
                            <div class="w-10 h-10 rounded-lg bg-rose-50 text-rose-600 flex items-center justify-center border border-rose-100">
                                <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M6 18L18 6M6 6l12 12"/></svg>
                            </div>
						{% elseif 'ORDER' in notif.type or 'COMMAND' in notif.type %}
                            <div class="w-10 h-10 rounded-lg bg-indigo-50 text-indigo-600 flex items-center justify-center border border-indigo-100">
                                <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg>
                            </div>
						{% else %}
                            <div class="w-10 h-10 rounded-lg bg-slate-50 text-slate-400 flex items-center justify-center border border-slate-200">
                                <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>
                            </div>
						{% endif %}
					</div>
					<div class="flex-1 min-w-0">
						<div class="flex items-center justify-between gap-2 mb-1">
							<h3 class="font-black text-slate-900 text-[13px] uppercase tracking-tight truncate">{{ notif.title }}</h3>
							<span class="text-[9px] font-bold text-slate-300 uppercase tracking-widest">{{ notif.createdAt|date('d/m/Y H:i') }}</span>
						</div>
						<p class="text-slate-500 text-xs leading-relaxed mb-3">{{ notif.content }}</p>
						<div class="flex items-center gap-4">
                            {% if notif.link %}
                                <a href="{{ notif.link }}" onclick="handleNotifClick('{{ notif.id }}', event)" class="inline-flex items-center gap-1.5 text-[9px] font-black uppercase tracking-[0.1em] text-indigo-600 hover:text-slate-900 transition-colors">
                                    Consulter le document
                                    <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
                                </a>
                            {% endif %}
                            {% if not notif.isRead %}
                                <button onclick="handleNotifClick('{{ notif.id }}', event)" class="bg-transparent border-0 p-0 text-[9px] font-black uppercase tracking-[0.1em] text-slate-300 hover:text-indigo-600 cursor-pointer transition-colors">
                                    Marquer comme lu
                                </button>
                            {% endif %}
                        </div>
					</div>
				</div>
			{% else %}
				<div class="py-24 text-center">
					<div class="w-16 h-16 bg-slate-50 rounded-xl flex items-center justify-center mx-auto mb-4 border border-slate-100">
						<svg width="24" height="24" fill="none" stroke="#cbd5e1" stroke-width="2.5" viewBox="0 0 24 24"><path d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>
					</div>
					<h3 class="text-slate-900 font-black text-sm uppercase tracking-tight">Journal Vierge</h3>
					<p class="text-slate-400 text-xs font-medium">Vous n'avez pas encore reçu de notifications système.</p>
				</div>
			{% endfor %}
		</div>
	</div>

	{% if pagination.getTotalItemCount > 0 %}
		<div class="flex justify-center mb-16">
			<div class="p-2 bg-white rounded-xl border border-slate-100 shadow-sm">
				{{ knp_pagination_render(pagination, 'parts/_premium_pagination.html.twig') }}
			</div>
		</div>
	{% endif %}

    <style>
        .notif-row.is-unread { background-color: #fcfdfe; }
    </style>
{% endblock %}
