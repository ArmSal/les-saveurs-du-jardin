{% set statusConfig = {
    'delivered': {'bg': 'bg-emerald-50', 'text': 'text-emerald-700', 'border': 'border-emerald-100', 'dot': 'bg-emerald-500'},
    'canceled':  {'bg': 'bg-rose-50',    'text': 'text-rose-700',    'border': 'border-rose-100',    'dot': 'bg-rose-500'},
    'pending':   {'bg': 'bg-amber-50',   'text': 'text-amber-700',   'border': 'border-amber-100',   'dot': 'bg-amber-500'},
    'updated':   {'bg': 'bg-orange-50',  'text': 'text-orange-700',  'border': 'border-orange-100',  'dot': 'bg-orange-500'},
    'processing':{'bg': 'bg-indigo-50',  'text': 'text-indigo-700',  'border': 'border-indigo-100',  'dot': 'bg-indigo-500'},
    'confirmed': {'bg': 'bg-sky-50',     'text': 'text-sky-700',     'border': 'border-sky-100',     'dot': 'bg-sky-500'},
    'processed': {'bg': 'bg-emerald-500','text': 'text-white',       'border': 'border-emerald-500', 'dot': 'bg-white'},
    'archived':  {'bg': 'bg-slate-100',  'text': 'text-slate-500',   'border': 'border-slate-200',   'dot': 'bg-slate-400'}
} %}

{# Count badge #}
<div class="px-4 sm:px-6 py-3 bg-slate-50 border-b border-slate-100 flex items-center justify-between">
    <span class="text-[9px] font-black text-slate-400 uppercase tracking-widest">Résultats</span>
    <span class="text-[9px] font-black text-indigo-600 uppercase tracking-widest bg-indigo-50 px-2 py-1 rounded border border-indigo-100/50">
        {{ commandes.getTotalItemCount }} entrée{{ commandes.getTotalItemCount > 1 ? 's' : '' }}
    </span>
</div>

{# Desktop Table #}
<div class="hidden md:block overflow-x-auto">
    <table class="w-full text-left border-collapse">
        <thead>
            <tr class="border-b border-slate-100">
                <th class="px-6 py-4 text-[9px] font-black text-slate-400 uppercase tracking-widest">Référence</th>
                <th class="px-6 py-4 text-[9px] font-black text-slate-400 uppercase tracking-widest">Client &amp; Magasin</th>
                <th class="px-6 py-4 text-[9px] font-black text-slate-400 uppercase tracking-widest">Date</th>
                <th class="px-6 py-4 text-[9px] font-black text-slate-400 uppercase tracking-widest">Statut</th>
                <th class="px-6 py-4 text-[9px] font-black text-slate-400 uppercase tracking-widest text-right">Action</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-slate-50">
            {% for c in commandes %}
                {% set sc = statusConfig[c.status] | default({'bg': 'bg-slate-100', 'text': 'text-slate-700', 'border': 'border-slate-200', 'dot': 'bg-slate-500'}) %}
                <tr class="group hover:bg-slate-50/50 transition-all">
                    <td class="px-6 py-4">
                        <div class="flex items-center gap-3">
                            <div class="w-8 h-8 rounded-lg bg-slate-900 text-white flex items-center justify-center text-[10px] font-black shadow-sm shrink-0">{{ c.id }}</div>
                            <div>
                                <div class="text-[10px] font-black text-slate-900 uppercase tracking-tight">CMD-{{ c.id|format('%04d') }}</div>
                                <div class="text-[8px] font-bold text-slate-300 uppercase tracking-widest">{{ c.slug|slice(0,8)|upper }}</div>
                            </div>
                        </div>
                    </td>
                    <td class="px-6 py-4">
                        <div class="text-[11px] font-black text-slate-900 uppercase tracking-tight">{{ c.user.nom }} {{ c.user.prenom }}</div>
                        <div class="text-[9px] font-bold text-indigo-500/60 uppercase tracking-widest">{{ c.user.magasin|default('CLIENT') }}</div>
                    </td>
                    <td class="px-6 py-4">
                        <div class="text-[10px] font-black text-slate-600">{{ c.createdAt|date('d/m/Y') }}</div>
                        <div class="text-[9px] font-bold text-slate-300">{{ c.createdAt|date('H:i') }}</div>
                    </td>
                    <td class="px-6 py-4">
                        <div class="inline-flex items-center gap-1.5 px-2 py-0.5 rounded-md {{ sc.bg }} {{ sc.text }} border {{ sc.border }}">
                            <span class="w-1 h-1 rounded-full {{ sc.dot }}"></span>
                            <span class="text-[9px] font-black uppercase tracking-widest">{{ c.statusLabelFr }}</span>
                        </div>
                    </td>
                    <td class="px-6 py-4 text-right">
                        <a href="{{ path('admin_commandes_show', {id: c.id}) }}"
                           class="inline-flex items-center gap-2 px-3 py-1.5 bg-white hover:bg-indigo-50 text-slate-600 hover:text-indigo-600 text-[10px] font-black uppercase tracking-widest rounded-lg transition-all border border-slate-200 shadow-sm group-hover:border-indigo-200">
                            Détails
                            <svg width="11" height="11" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                        </a>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="5" class="py-24 text-center">
                        <div class="w-14 h-14 bg-slate-50 rounded-xl flex items-center justify-center mx-auto mb-4 border border-slate-100">
                            <svg width="22" height="22" fill="none" stroke="#cbd5e1" stroke-width="2.5" viewBox="0 0 24 24"><path d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                        </div>
                        <h3 class="text-slate-900 font-black text-sm uppercase tracking-tight">Aucune commande</h3>
                        <p class="text-slate-400 text-xs mt-1">Aucun résultat pour ce filtre.</p>
                    </td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
</div>

{# Mobile Cards #}
<div class="md:hidden divide-y divide-slate-100">
    {% for c in commandes %}
        {% set sc = statusConfig[c.status] | default({'bg': 'bg-slate-100', 'text': 'text-slate-700', 'border': 'border-slate-200', 'dot': 'bg-slate-500'}) %}
        <div class="p-5 bg-white hover:bg-slate-50/50 transition-colors">
            <div class="flex items-start justify-between gap-3 mb-4">
                <div class="flex items-center gap-3 min-w-0">
                    <div class="w-10 h-10 rounded-xl bg-slate-900 text-white flex items-center justify-center text-xs font-black shadow-md shrink-0">{{ c.id }}</div>
                    <div class="min-w-0">
                        <div class="text-[11px] font-black text-slate-900 uppercase tracking-tight truncate">CMD-{{ c.id|format('%04d') }}</div>
                        <div class="text-[9px] font-bold text-slate-300 uppercase tracking-widest">{{ c.createdAt|date('d/m/Y — H:i') }}</div>
                    </div>
                </div>
                <div class="inline-flex shrink-0 items-center gap-1.5 px-2 py-1 rounded-lg {{ sc.bg }} {{ sc.text }} border {{ sc.border }}">
                    <span class="w-1.5 h-1.5 rounded-full {{ sc.dot }}"></span>
                    <span class="text-[9px] font-black uppercase tracking-widest">{{ c.statusLabelFr }}</span>
                </div>
            </div>
            <div class="flex items-center gap-3 p-3 bg-slate-50 rounded-xl border border-slate-100 mb-4">
                <div class="min-w-0">
                    <div class="text-[11px] font-black text-slate-900 uppercase tracking-tight truncate">{{ c.user.nom }} {{ c.user.prenom }}</div>
                    <div class="text-[9px] font-bold text-indigo-500/60 uppercase tracking-widest truncate">{{ c.user.magasin|default('DIRECT CLIENT') }}</div>
                </div>
            </div>
            <a href="{{ path('admin_commandes_show', {id: c.id}) }}"
               class="flex items-center justify-center gap-2 w-full h-10 bg-white border border-slate-200 hover:border-indigo-500 hover:text-indigo-600 text-slate-600 text-[10px] font-black uppercase tracking-widest rounded-xl transition-all shadow-sm active:scale-95">
                Consulter le Manifeste
                <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </a>
        </div>
    {% else %}
        <div class="py-20 text-center px-6">
            <div class="w-14 h-14 bg-slate-50 rounded-xl flex items-center justify-center mx-auto mb-4 border border-slate-100">
                <svg width="22" height="22" fill="none" stroke="#cbd5e1" stroke-width="2.5" viewBox="0 0 24 24"><path d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
            </div>
            <h3 class="text-slate-900 font-black text-sm uppercase tracking-tight">Aucune commande</h3>
            <p class="text-slate-400 text-xs mt-1">Aucun résultat pour ce filtre.</p>
        </div>
    {% endfor %}
</div>

{# Pagination #}
{% if commandes.pageCount > 1 %}
<div class="flex justify-center py-4 border-t border-slate-100">
    <div class="p-2 bg-white rounded-xl border border-slate-100 shadow-sm" id="pagination-wrapper">
        {{ knp_pagination_render(commandes, 'parts/_premium_pagination.html.twig') }}
    </div>
</div>
{% endif %}
