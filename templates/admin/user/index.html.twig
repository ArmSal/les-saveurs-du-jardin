{% extends 'base.html.twig' %}

{% block title %}Personnel | LSDJ{% endblock %}

{% block body %}
<div class="min-h-screen bg-slate-50 py-2 sm:py-4 px-0 sm:px-4 lg:px-8">
    <div class="max-w-7xl mx-auto">
        
        {# Header - Dashboard Style #}
        <div class="mb-4 sm:mb-6 px-3 sm:px-0">
            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
                <div>
                    <h1 class="text-xl sm:text-2xl font-black text-slate-900 tracking-tight">Gestion du Personnel</h1>
                </div>
                {% if is_granted('MODULE_EDIT', 'users') %}
                    <a href="{{ path('admin_users_new') }}" class="inline-flex items-center gap-2 bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-2 px-4 rounded-lg transition-all text-xs uppercase tracking-wider shadow-sm">
                        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 4v16m8-8H4"></path></svg>
                        Nouveau
                    </a>
                {% endif %}
            </div>
        </div>

        {# Quick Stats Cards — Only for ACCES_TOTAL #}
        {% if accessLevel == 'ACCES_TOTAL' %}
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-2 sm:gap-3 mb-4 sm:mb-6 px-3 sm:px-0">
            <div class="bg-white rounded-xl p-2.5 sm:p-3 shadow-sm border border-slate-200 transition-all hover:shadow-md group">
                <div class="flex items-center justify-between mb-1">
                    <div class="text-[9px] font-bold text-slate-400 uppercase tracking-widest">Total</div>
                    <div class="p-1 bg-indigo-50 rounded-lg text-indigo-500">
                        <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
                    </div>
                </div>
                <div class="text-lg font-black text-slate-900 leading-none mb-1 group-hover:text-indigo-600 transition-colors">{{ users.getTotalItemCount }}</div>
                <div class="text-[8px] font-bold text-slate-400 uppercase">Employés</div>
            </div>
            <div class="bg-white rounded-xl p-2.5 sm:p-3 shadow-sm border border-slate-200 transition-all hover:shadow-md group">
                <div class="flex items-center justify-between mb-1">
                    <div class="text-[9px] font-bold text-slate-400 uppercase tracking-widest">Actifs</div>
                    <div class="p-1 bg-emerald-50 rounded-lg text-emerald-500">
                        <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    </div>
                </div>
                <div class="text-lg font-black text-slate-900 leading-none mb-1 group-hover:text-emerald-600 transition-colors">{{ users|filter(u => u.isActive)|length }}</div>
                <div class="text-[8px] font-bold text-slate-400 uppercase">En ligne</div>
            </div>
            <div class="bg-white rounded-xl p-2.5 sm:p-3 shadow-sm border border-slate-200 transition-all hover:shadow-md group">
                <div class="flex items-center justify-between mb-1">
                    <div class="text-[9px] font-bold text-slate-400 uppercase tracking-widest">Magasins</div>
                    <div class="p-1 bg-cyan-50 rounded-lg text-cyan-500">
                        <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg>
                    </div>
                </div>
                <div class="text-lg font-black text-slate-900 leading-none mb-1 group-hover:text-cyan-600 transition-colors">{{ magasins|length }}</div>
                <div class="text-[8px] font-bold text-slate-400 uppercase">Sites</div>
            </div>
            <div class="bg-white rounded-xl p-2.5 sm:p-3 shadow-sm border border-slate-200 transition-all hover:shadow-md group">
                <div class="flex items-center justify-between mb-1">
                    <div class="text-[9px] font-bold text-slate-400 uppercase tracking-widest">Rôles</div>
                    <div class="p-1 bg-amber-50 rounded-lg text-amber-500">
                        <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.587 0 3.42 3.42 0 001.946.806 3.42 3.42 0 003.138 0 3.42 3.42 0 001.946-.806 3.42 3.42 0 014.587 0 3.42 3.42 0 001.946.806"></path></svg>
                    </div>
                </div>
                <div class="text-lg font-black text-slate-900 leading-none mb-1 group-hover:text-amber-600 transition-colors">
                    {% set uniqueRoles = [] %}
                    {% for u in users %}
                        {% if u.roles[0] not in uniqueRoles %}
                            {% set uniqueRoles = uniqueRoles|merge([u.roles[0]]) %}
                        {% endif %}
                    {% endfor %}
                    {{ uniqueRoles|length }}
                </div>
                <div class="text-[8px] font-bold text-slate-400 uppercase">Niveaux</div>
            </div>
        </div>
        {% endif %}

        {# Filter Bar - Hidden for ACCES_PERSONNEL (only sees own card) #}
        {% if not isPersonnelOnly %}
        <div class="px-3 sm:px-0 mb-4 sm:mb-6">
            <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-2 sm:p-3">
                <form method="get" action="{{ path('admin_users_index') }}" class="flex flex-col sm:flex-row gap-2">
                    <div class="flex-1 relative">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none text-slate-400">
                            <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
                        </div>
                        <input type="text" name="q" value="{{ q }}" placeholder="Nom, prénom..." class="w-full pl-9 pr-3 py-1.5 bg-slate-50 border border-slate-200 rounded-lg text-xs font-bold text-slate-700 placeholder-slate-400 outline-none focus:border-indigo-400 focus:ring-1 focus:ring-indigo-100 transition-all h-9">
                    </div>
                    <div class="w-full sm:w-44 relative">
                        <select name="magasin" onchange="this.form.submit()" class="w-full pl-3 pr-8 py-1.5 bg-slate-50 border border-slate-200 rounded-lg text-xs font-bold text-slate-700 outline-none focus:border-indigo-400 focus:ring-1 focus:ring-indigo-100 cursor-pointer appearance-none h-9">
                            <option value="">Tous les sites</option>
                            {% for m in magasins %}
                                <option value="{{ m.id }}" {{ selectedMagasinId == m.id ? 'selected' : '' }}>{{ m.nom }}</option>
                            {% endfor %}
                        </select>
                        <div class="absolute inset-y-0 right-0 pr-2 flex items-center pointer-events-none text-slate-400">
                            <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M19 9l-7 7-7-7"/></svg>
                        </div>
                    </div>
                    <div class="flex items-center gap-2 sm:ml-auto">
                        <button type="submit" class="px-4 py-1.5 bg-indigo-600 text-white font-black text-[10px] uppercase tracking-wider rounded-lg hover:bg-indigo-700 transition-all shadow-sm h-9">
                            Filtrer
                        </button>
                        <a href="{{ path('admin_users_index') }}" class="px-4 py-1.5 bg-white border border-slate-300 text-slate-600 font-black text-[10px] uppercase tracking-wider rounded-lg hover:bg-slate-50 hover:border-slate-400 transition-all h-9 flex items-center gap-1.5">
                            <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M6 18L18 6M6 6l12 12"></path></svg>
                            Réinitialiser
                        </a>
                    </div>
                </form>
            </div>
        </div>
        {% endif %}
        {# Active Employees Grid #}
        <div class="px-3 sm:px-0 mb-4">
            <div class="grid grid-cols-2 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 2xl:grid-cols-6 gap-2 sm:gap-3">
                {% for u in users %}
                    <div class="bg-white border border-slate-200 rounded-xl shadow-sm hover:shadow-md transition-all duration-300 overflow-hidden flex flex-col p-2 group animate-in">
                        <!-- Photo: Rigid 1:1 Square & Ribbons -->
                        <div class="relative w-full pb-[100%] mb-2 overflow-hidden rounded-lg bg-slate-100 shrink-0">
                            {% if u.photo %}
                                <img src="{{ path('app_media_user', {filename: u.photo}) }}" class="absolute inset-0 w-full h-full object-cover shadow-sm group-hover:scale-105 transition-transform duration-500">
                            {% else %}
                                <div class="absolute inset-0 w-full h-full bg-slate-100 text-slate-300 flex items-center justify-center font-black text-2xl">
                                    {{ u.nom|slice(0,1)|upper }}{{ u.prenom|slice(0,1)|upper }}
                                </div>
                            {% endif %}
                            
                            <!-- Magasin Ribbon (Rotate -45 at Top-Left) -->
                            <div class="absolute top-0 left-0 w-28 h-4 bg-slate-900/90 backdrop-blur-md text-white flex items-center justify-center -translate-x-8 translate-y-2.5 -rotate-45 z-20 shadow-lg">
                                <span class="text-[5px] font-black uppercase tracking-wider text-center w-full px-1">
                                    {{ u.magasinEntity ? u.magasinEntity.nom : 'Siège' }}
                                </span>
                            </div>

                            <!-- Role Badge Overlay (Bottom-Left) -->
                            <div class="absolute bottom-1.5 left-1.5 z-20">
                                {% set badge_class = u.roleEntity ? 
                                    (u.roleEntity.name == 'ROLE_DIRECTEUR' ? 'badge-access-total' : 
                                     u.roleEntity.name == 'ROLE_RESPONSABLE' ? 'badge-access-admin' : 
                                     'badge-access-lecture-totale') : 'badge-access-aucun' 
                                %}
                                <span class="text-[5px] font-black uppercase tracking-wider px-1 py-0.5 rounded bg-white/80 backdrop-blur-md border border-slate-200 shadow-sm {{ badge_class }}">
                                    {{ u.roleEntity ? u.roleEntity.label : 'Client' }}
                                </span>
                            </div>
                            <span class="absolute top-1 right-1 w-3 h-3 bg-emerald-500 border-2 border-white rounded-full z-20"></span>
                        </div>

                        <!-- Info Section: Under the picture -->
                        <div class="px-0.5 flex-1 text-center">
                            <h3 class="font-black text-slate-900 text-[9px] sm:text-[10px] leading-tight mb-1 truncate">
                                {{ u.prenom }} {{ u.nom }}
                            </h3>
                            
                            <div class="space-y-0.5 mb-2">
                                {% if u.telephone %}
                                    <a href="tel:{{ u.telephone|replace({' ': ''}) }}" class="contact-link flex items-center justify-center gap-1 text-slate-600 hover:text-indigo-600 transition-colors" title="{{ u.telephone }}">
                                        <svg width="7" height="7" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
                                        <span class="text-[7px] font-bold">{{ u.telephone }}</span>
                                    </a>
                                {% else %}
                                    <div class="flex items-center justify-center gap-1 text-slate-400">
                                        <svg width="7" height="7" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
                                        <span class="text-[7px] font-bold">-- -- -- --</span>
                                    </div>
                                {% endif %}
                                <a href="mailto:{{ u.email }}" class="contact-link flex items-center justify-center gap-1 text-slate-600 hover:text-indigo-600 transition-colors overflow-hidden" title="{{ u.email }}">
                                    <svg width="7" height="7" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24" class="shrink-0"><path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                                    <span class="text-[7px] font-bold truncate">{{ u.email }}</span>
                                </a>
                            </div>
                        </div>

                        <!-- Card Footer: Action -->
                        {% if is_granted('MODULE_EDIT', 'users') %}
                            <div class="mt-auto">
                                <a href="{{ path('admin_users_edit', {id: u.id}) }}" class="w-full h-7 bg-slate-900 text-white text-[7px] font-black uppercase tracking-widest rounded-lg hover:bg-black transition-all shadow-sm flex items-center justify-center gap-1">
                                    Éditer
                                </a>
                            </div>
                        {% endif %}
                    </div>
                {% else %}
                    <div class="col-span-full bg-white border-2 border-dashed border-slate-200 rounded-[3rem] p-16 text-center">
                        <div class="w-20 h-20 bg-slate-50 rounded-full flex items-center justify-center mx-auto mb-4 text-slate-300">
                            <svg width="32" height="32" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
                        </div>
                        <h3 class="text-lg font-black text-slate-900 tracking-tight">Aucun collaborateur actif trouvé</h3>
                        <p class="text-xs font-bold text-slate-400 mt-1">Ajustez vos filtres ou effectuez une nouvelle recherche.</p>
                    </div>
                {% endfor %}
            </div>
        </div>

        {# Pagination #}
        {% if users is not empty %}
            <div class="px-3 sm:px-0 mb-6 sm:mb-8">
                <div class="flex flex-col sm:flex-row items-center justify-between gap-4 bg-white rounded-xl shadow-sm border border-slate-200 p-2 sm:p-3">
                    <div class="text-[10px] sm:text-[11px] font-bold text-slate-500 order-2 sm:order-1">
                        Affichage <span class="text-indigo-600 font-black">{{ (users.currentPageNumber - 1) * users.itemNumberPerPage + 1 }}-{{ min(users.currentPageNumber * users.itemNumberPerPage, users.getTotalItemCount) }}</span> sur <span class="text-slate-900 font-black">{{ users.getTotalItemCount }}</span>
                    </div>
                    <div class="w-full sm:w-auto order-1 sm:order-2">
                        {{ knp_pagination_render(users, 'parts/_premium_pagination.html.twig') }}
                    </div>
                </div>
            </div>
        {% endif %}

        {# Inactive Users Section #}
        {% if inactiveUsers is not empty and is_granted('MODULE_EDIT', 'users') %}
            <div class="px-3 sm:px-0 mb-6">
                <div class="bg-slate-100 border border-slate-200 rounded-lg overflow-hidden">
                    <button onclick="toggleInactiveUsers()" class="w-full p-3 flex items-center justify-between group text-left">
                        <div class="flex items-center gap-2">
                            <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" class="text-rose-500"><path d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
                            <h2 class="text-sm font-black text-slate-900 tracking-tight">Collaborateurs Suspendus</h2>
                            <span class="text-[10px] font-bold text-slate-500 bg-white px-2 py-0.5 rounded-full">{{ inactiveUsers|length }}</span>
                        </div>
                        <div id="inactiveChevron" class="w-8 h-8 bg-white rounded-lg flex items-center justify-center text-slate-400 group-hover:bg-rose-50 group-hover:text-rose-500 transition-all">
                            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M19 9l-7 7-7-7"></path></svg>
                        </div>
                    </button>

                    <div id="inactiveContent" class="hidden px-3 pb-3 border-t border-slate-200">
                        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 xl:grid-cols-6 gap-2 pt-3">
                            {% for u in inactiveUsers %}
                                <div class="bg-white/80 border border-slate-200 border-dashed rounded-xl p-2 flex flex-col items-center text-center opacity-70 hover:opacity-100 transition-all">
                                    <div class="relative w-12 h-12 mb-2 overflow-hidden rounded-lg bg-slate-50 shrink-0">
                                        {% if u.photo %}
                                            <img src="{{ path('app_media_user', {filename: u.photo}) }}" class="w-full h-full object-cover grayscale">
                                        {% else %}
                                            <div class="w-full h-full bg-slate-50 text-slate-300 flex items-center justify-center font-black text-lg">
                                                {{ u.nom|slice(0,1)|upper }}{{ u.prenom|slice(0,1)|upper }}
                                            </div>
                                        {% endif %}
                                    </div>
                                    <h3 class="font-black text-slate-700 text-[9px] tracking-tight truncate w-full">{{ u.prenom }} {{ u.nom }}</h3>
                                    <form id="activate-form-{{ u.id }}" method="post" action="{{ path('admin_users_activate', {id: u.id}) }}" class="w-full mt-1">
                                        <input type="hidden" name="_token" value="{{ csrf_token('activate_user_' ~ u.id) }}">
                                        <button type="button" onclick="showConfirmActivation('{{ u.prenom }} {{ u.nom|upper }}', 'activate-form-{{ u.id }}')" class="w-full py-1 bg-white border border-slate-200 text-emerald-600 text-[8px] font-black uppercase tracking-wider rounded hover:bg-emerald-500 hover:text-white transition-all">
                                            Activer
                                        </button>
                                    </form>
                                </div>
                            {% endfor %}
                        </div>
                    </div>
                </div>
            </div>
        {% endif %}

	<!-- Modal: Global Confirmation (Premium UX) -->
	<div id="confirmModal" class="fixed inset-0 z-[100] hidden items-center justify-center p-4">
		<!-- Backdrop -->
		<div class="absolute inset-0 bg-slate-900/40 backdrop-blur-md" onclick="closeConfirmModal()"></div>
		
		<!-- Modal Content -->
		<div class="relative w-full max-w-md bg-white/95 backdrop-blur-xl rounded-[2.5rem] shadow-2xl border border-white/60 p-8 transform scale-95 opacity-0 transition-all duration-300 overflow-hidden" id="modalContainer">
			<!-- Decoration -->
			<div class="absolute top-0 right-0 -translate-y-1/2 translate-x-1/2 w-48 h-48 bg-emerald-500/10 rounded-full blur-3xl pointer-events-none"></div>
			
			<div class="text-center relative z-10">
				<!-- Success Icon -->
				<div class="w-16 h-16 bg-emerald-50 rounded-2xl flex items-center justify-center mx-auto mb-6 text-emerald-500 shadow-sm">
					<svg width="32" height="32" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
				</div>
				
				<h2 class="text-xl font-black text-slate-900 tracking-tight mb-2 uppercase">Réactivation</h2>
				<p class="text-[11px] font-bold text-slate-400 uppercase tracking-widest leading-relaxed mb-8">
					Voulez-vous vraiment restaurer l'accès de <br>
					<span id="modalTargetName" class="text-slate-900 font-black">---</span> ?
				</p>

				<div class="flex flex-col sm:flex-row gap-3">
					<button onclick="closeConfirmModal()" class="flex-1 h-12 bg-slate-50 text-slate-400 text-[10px] font-black uppercase tracking-widest rounded-xl hover:bg-slate-100 transition-all">
						Annuler
					</button>
					<button onclick="executeAction()" class="flex-1 h-12 bg-emerald-500 text-white text-[10px] font-black uppercase tracking-widest rounded-xl hover:bg-emerald-600 shadow-lg shadow-emerald-200 transition-all flex items-center justify-center gap-2">
						Réactiver
					</button>
				</div>
			</div>
		</div>
	</div>

	<script>
		let pendingFormId = null;

		function showConfirmActivation(name, formId) {
			pendingFormId = formId;
			document.getElementById('modalTargetName').innerText = name;
			
			const modal = document.getElementById('confirmModal');
			const container = document.getElementById('modalContainer');
			
			modal.classList.remove('hidden');
			modal.classList.add('flex');
			
			// Trigger animation
			setTimeout(() => {
				container.classList.remove('scale-95', 'opacity-0');
				container.classList.add('scale-100', 'opacity-100');
			}, 10);
		}

		function closeConfirmModal() {
			const modal = document.getElementById('confirmModal');
			const container = document.getElementById('modalContainer');
			
			container.classList.remove('scale-100', 'opacity-100');
			container.classList.add('scale-95', 'opacity-0');
			
			setTimeout(() => {
				modal.classList.add('hidden');
				modal.classList.remove('flex');
				pendingFormId = null;
			}, 300);
		}

		function executeAction() {
			if (pendingFormId) {
				document.getElementById(pendingFormId).submit();
			}
		}

		function toggleInactiveUsers() {
			const content = document.getElementById('inactiveContent');
			const chevron = document.getElementById('inactiveChevron');
			content.classList.toggle('hidden');
			chevron.classList.toggle('rotate-180');
		}
	</script>

	<style>
		@keyframes animate-in {
			from { opacity: 0; transform: translateY(20px); }
			to { opacity: 1; transform: translateY(0); }
		}
		.animate-in {
			animation: animate-in 0.6s ease-out backwards;
		}
		{% for i in 1..24 %}
			.animate-in:nth-child({{ i }}) { animation-delay: {{ i * 0.05 }}s; }
		{% endfor %}

		/* Clickable contact links with tooltip */
		.contact-link {
			position: relative;
			cursor: pointer;
			text-decoration: none;
		}
		.contact-link:hover span {
			text-decoration: underline;
		}
		/* Custom tooltip on hover — shows full email/phone */
		.contact-link::after {
			content: attr(title);
			position: absolute;
			bottom: calc(100% + 6px);
			left: 50%;
			transform: translateX(-50%) scale(0.95);
			background: #1e293b;
			color: #fff;
			font-size: 10px;
			font-weight: 700;
			padding: 4px 10px;
			border-radius: 6px;
