{% extends 'base.html.twig' %}

{% block title %}Modifier Employé | LSDJ{% endblock %}

{% block body %}
<div class="min-h-screen bg-slate-50 py-2 sm:py-4 px-0 sm:px-4 lg:px-8">
    <div class="max-w-3xl mx-auto">
        
        {# Header - Compact Dashboard Style #}
        <div class="mb-4 sm:mb-6 px-3 sm:px-0">
            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
                <div>
                    <h1 class="text-xl sm:text-2xl font-black text-slate-900 tracking-tight">Modifier Employé</h1>
                </div>
                <a href="{{ path('admin_users_index') }}" class="inline-flex items-center gap-2 text-[10px] font-black uppercase tracking-widest text-slate-400 hover:text-indigo-600 transition-colors group">
                    <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24" class="group-hover:-translate-x-1 transition-transform"><path d="M15 19l-7-7 7-7"></path></svg>
                    Retour
                </a>
            </div>
        </div>

        {{ form_start(form) }}
        <div class="px-3 sm:px-0 space-y-4">

            <!-- Photo Section - First and Bigger -->
            <div class="bg-white border border-slate-200 rounded-xl overflow-hidden shadow-sm">
                <div class="px-4 py-3 border-b border-slate-100 bg-slate-50/50">
                    <h2 class="text-[9px] font-black text-slate-900 uppercase tracking-[0.15em] flex items-center gap-2">
                        <span class="w-1 h-3 bg-amber-500 rounded-full"></span>
                        Photo de Profil
                    </h2>
                </div>
                <div class="p-4">
                    <div class="flex flex-col sm:flex-row items-center gap-4">
                        <div id="photo-placeholder" onclick="document.getElementById('{{ form.photo_file.vars.id }}').click()" class="w-32 h-32 sm:w-40 sm:h-40 bg-slate-100 border-2 border-dashed border-slate-300 rounded-xl flex items-center justify-center text-slate-400 overflow-hidden shrink-0 cursor-pointer hover:border-indigo-400 hover:bg-slate-50 transition-all">
                            {% if userEntity.photo %}
                                <img src="{{ path('app_media_user', {filename: userEntity.photo}) }}" class="w-full h-full object-cover">
                            {% else %}
                                <svg width="48" height="48" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
                            {% endif %}
                        </div>
                        <div class="flex-1 text-center sm:text-left">
                            <button type="button" onclick="document.getElementById('{{ form.photo_file.vars.id }}').click()" class="inline-flex items-center gap-2 bg-white border border-slate-300 text-slate-600 font-bold py-2 px-4 rounded-lg hover:bg-slate-50 transition-all text-xs uppercase tracking-wider shadow-sm">
                                <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                                {% if userEntity.photo %}Changer la photo{% else %}Choisir une photo{% endif %}
                            </button>
                            <p class="text-[8px] text-slate-400 mt-2">JPG, PNG - Max 2Mo</p>
                            <div class="hidden">{{ form_widget(form.photo_file) }}</div>
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- Section: Accès & Sécurité -->
            <div class="bg-white border border-slate-200 rounded-xl overflow-hidden shadow-sm">
                <div class="px-4 py-3 border-b border-slate-100 flex items-center justify-between bg-slate-50/50">
                    <h2 class="text-[9px] font-black text-slate-900 uppercase tracking-[0.15em] flex items-center gap-2">
                        <span class="w-1 h-3 bg-indigo-500 rounded-full"></span>
                        Accès & Sécurité
                    </h2>
                    <label class="relative inline-flex items-center {{ form.is_active.vars.disabled ? 'cursor-not-allowed opacity-60' : 'cursor-pointer' }} group">
                        {{ form_widget(form.is_active, {'attr': {'class': 'sr-only peer'}}) }}
                        <div class="w-8 h-4 bg-slate-200 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border-slate-300 after:border after:rounded-full after:h-3 after:w-3 after:transition-all peer-checked:bg-emerald-500"></div>
                        <span class="ms-2 text-[8px] font-black uppercase tracking-widest text-slate-400 peer-checked:text-emerald-600">Actif</span>
                        {% if form.is_active.vars.disabled %}
                            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="ms-1 text-slate-300"><path d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
                        {% endif %}
                    </label>
                </div>
                <div class="p-4 grid grid-cols-1 sm:grid-cols-2 gap-4">
                    <div class="sm:col-span-2">
                        <label class="text-[7px] font-black text-slate-400 uppercase tracking-widest mb-1 flex items-center gap-1">
                            Email Professionnel
                            {% if form.email.vars.disabled %}
                                <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="text-slate-300"><path d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
                            {% endif %}
                        </label>
                        {{ form_widget(form.email, {'attr': {'class': 'w-full h-9 bg-slate-50 border border-slate-200 rounded-lg px-3 text-xs font-bold text-slate-700 focus:border-indigo-400 focus:ring-1 focus:ring-indigo-100 transition-all' ~ (form.email.vars.disabled ? ' opacity-60' : '')}}) }}
                    </div>
                    <div>
                        <label class="text-[7px] font-black text-slate-400 uppercase tracking-widest mb-1 flex items-center gap-1">
                            Niveau d'Accès
                            {% if form.roleEntity.vars.disabled %}
                                <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="text-slate-300"><path d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
                            {% endif %}
                        </label>
                        {{ form_widget(form.roleEntity, {'attr': {'class': 'w-full h-9 bg-slate-50 border border-slate-200 rounded-lg px-3 text-xs font-bold text-slate-700' ~ (form.roleEntity.vars.disabled ? ' opacity-60 cursor-not-allowed' : ' focus:border-indigo-400 focus:ring-1 focus:ring-indigo-100')}}) }}
                    </div>
                    <div>
                        <label class="text-[7px] font-black text-slate-400 uppercase tracking-widest mb-1 block">Affectation Magasin</label>
                        {{ form_widget(form.magasinEntity, {'attr': {'class': 'w-full h-9 bg-slate-50 border border-slate-200 rounded-lg px-3 text-xs font-bold text-slate-700 focus:border-indigo-400 focus:ring-1 focus:ring-indigo-100'}}) }}
                        {{ form_errors(form.magasinEntity) }}
                    </div>
                    <div>
                        <label class="text-[7px] font-black text-slate-400 uppercase tracking-widest mb-1 block">Matricule</label>
                        {{ form_widget(form.client_number, {'attr': {'class': 'w-full h-9 bg-slate-50 border border-slate-200 rounded-lg px-3 text-xs font-black text-slate-900 font-mono'}}) }}
                    </div>
                    <div>
                        <label class="text-[7px] font-black text-slate-400 uppercase tracking-widest mb-1 block">Mot de passe (Modif.)</label>
                        <div class="relative">
                            {{ form_widget(form.plainPassword, {'attr': {'class': 'w-full h-9 bg-slate-50 border border-slate-200 rounded-lg px-3 text-xs font-bold text-slate-700 pr-10', 'placeholder': 'Nouveau pass'}}) }}
                            <button type="button" class="absolute right-2 top-1/2 -translate-y-1/2 w-6 h-6 flex items-center justify-center text-slate-400 hover:text-indigo-600 transition-colors" onclick="togglePassword(this)">
                                <svg width="14" height="14" fill="none" class="eye-open" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg>
                                <svg width="14" height="14" fill="none" class="eye-closed hidden" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l18 18"></path></svg>
                            </button>
                        </div>
                        {{ form_errors(form.plainPassword) }}
                    </div>
                </div>
            </div>

            <!-- Section: Identité -->
            <div class="bg-white border border-slate-200 rounded-xl overflow-hidden shadow-sm">
                <div class="px-4 py-3 border-b border-slate-100 bg-slate-50/50">
                    <h2 class="text-[9px] font-black text-slate-900 uppercase tracking-[0.15em] flex items-center gap-2">
                        <span class="w-1 h-3 bg-emerald-500 rounded-full"></span>
                        Identité & Informations
                    </h2>
                </div>
                <div class="p-4 flex flex-col gap-4">
                    <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
                        <div>
                            <label class="text-[7px] font-black text-slate-400 uppercase tracking-widest mb-1 block">Civilité</label>
                            {{ form_widget(form.civility, {'attr': {'class': 'w-full h-9 bg-white border border-slate-200 rounded-lg px-3 text-xs font-bold text-slate-700 cursor-pointer'}}) }}
                            {{ form_errors(form.civility) }}
                        </div>
                        <div class="col-span-2 sm:col-span-1">
                            <label class="text-[7px] font-black text-slate-400 uppercase tracking-widest mb-1 block">Nom *</label>
                            {{ form_widget(form.nom, {'attr': {'class': 'w-full h-9 bg-white border border-slate-200 rounded-lg px-3 text-xs font-black text-slate-900'}}) }}
                            {{ form_errors(form.nom) }}
                        </div>
                        <div class="col-span-2 sm:col-span-1">
                            <label class="text-[7px] font-black text-slate-400 uppercase tracking-widest mb-1 block">Prénom *</label>
                            {{ form_widget(form.prenom, {'attr': {'class': 'w-full h-9 bg-white border border-slate-200 rounded-lg px-3 text-xs font-bold text-slate-700'}}) }}
                            {{ form_errors(form.prenom) }}
                        </div>
                    </div>
                    
                    <div class="grid grid-cols-2 sm:grid-cols-3 gap-3 border-t border-dashed border-slate-200 pt-4">
                        <div>
                            <label class="text-[7px] font-black text-slate-400 uppercase tracking-widest mb-1 block">Date Naissance *</label>
                            {{ form_widget(form.date_naissance, {'attr': {'class': 'w-full h-9 bg-white border border-slate-200 rounded-lg px-3 text-xs font-bold text-slate-700'}}) }}
                            {{ form_errors(form.date_naissance) }}
                        </div>
                        <div>
                            <label class="text-[7px] font-black text-slate-400 uppercase tracking-widest mb-1 block">Téléphone *</label>
                            {{ form_widget(form.telephone, {'attr': {'class': 'w-full h-9 bg-white border border-slate-200 rounded-lg px-3 text-xs font-bold text-slate-700'}}) }}
                            {{ form_errors(form.telephone) }}
                        </div>
                        <div>
                            <label class="text-[7px] font-black text-slate-400 uppercase tracking-widest mb-1 block">Code Postal *</label>
                            {{ form_widget(form.code_postal, {'attr': {'class': 'w-full h-9 bg-white border border-slate-200 rounded-lg px-3 text-xs font-bold text-slate-700'}}) }}
                            {{ form_errors(form.code_postal) }}
                        </div>
                        <div class="col-span-2">
                            <label class="text-[7px] font-black text-slate-400 uppercase tracking-widest mb-1 block">Adresse *</label>
                            {{ form_widget(form.adresse, {'attr': {'class': 'w-full h-9 bg-white border border-slate-200 rounded-lg px-3 text-xs font-bold text-slate-700'}}) }}
                            {{ form_errors(form.adresse) }}
                        </div>
                        <div>
                            <label class="text-[7px] font-black text-slate-400 uppercase tracking-widest mb-1 block">Complément</label>
                            {{ form_widget(form.adresse_complement, {'attr': {'class': 'w-full h-9 bg-white border border-slate-200 rounded-lg px-3 text-xs font-bold text-slate-700'}}) }}
                            {{ form_errors(form.adresse_complement) }}
                        </div>
                    </div>

                    </div>
                </div>
            </div>

            <!-- Actions Footer -->
            <div class="flex items-center justify-end gap-3 pt-2">
                <a href="{{ path('admin_users_index') }}" class="inline-flex items-center gap-2 bg-white border border-slate-300 text-slate-600 font-bold py-2 px-4 rounded-lg hover:bg-slate-50 hover:border-slate-400 transition-all text-xs uppercase tracking-wider shadow-sm">
                    Annuler
                </a>
                <button type="submit" class="inline-flex items-center gap-2 bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-2 px-4 rounded-lg transition-all text-xs uppercase tracking-wider shadow-sm">
                    <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"></path></svg>
                    Sauvegarder
                </button>
            </div>

            <!-- Hidden Fields -->
            <div class="hidden">
                {% if form.validation_horaire is defined %}{{ form_row(form.validation_horaire) }}{% endif %}
                {% if form.demande_conge is defined %}{{ form_row(form.demande_conge) }}{% endif %}
                {% if form.documents_rh is defined %}{{ form_row(form.documents_rh) }}{% endif %}
                {{ form_rest(form) }}
            </div>
        </div>
        {{ form_end(form) }}
    </div>

    <script>
        const inputs = {
            nom: document.getElementById('{{ form.nom.vars.id }}'),
            prenom: document.getElementById('{{ form.prenom.vars.id }}'),
            email: document.getElementById('{{ form.email.vars.id }}'),
            photo: document.getElementById('{{ form.photo_file.vars.id }}')
        };
        
        const photoPlaceholder = document.getElementById('photo-placeholder');

        // PascalCase transformation function
        function toPascalCase(str) {
            if (!str) return str;
            return str.toLowerCase().replace(/\b\w/g, char => char.toUpperCase());
        }

        // Apply PascalCase on blur for nom and prenom
        [inputs.nom, inputs.prenom].forEach(el => {
            el.addEventListener('blur', function() {
                this.value = toPascalCase(this.value);
            });
        });

        // Transform to PascalCase on form submission as safety net
        document.querySelector('form').addEventListener('submit', function() {
            inputs.nom.value = toPascalCase(inputs.nom.value);
            inputs.prenom.value = toPascalCase(inputs.prenom.value);
        });

        // Photo preview
        inputs.photo.addEventListener('change', function() {
            const file = this.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    photoPlaceholder.innerHTML = `<img src="${e.target.result}" class="w-full h-full object-cover rounded-lg">`;
                    photoPlaceholder.classList.remove('border-dashed', 'border-slate-300', 'bg-slate-100', 'text-slate-400');
                    photoPlaceholder.classList.add('border-solid', 'border-slate-200');
                }
                reader.readAsDataURL(file);
            }
        });

        window.togglePassword = function(btn) {
            const input = btn.parentElement.querySelector('input');
            const eyeOpen = btn.querySelector('.eye-open');
            const eyeClosed = btn.querySelector('.eye-closed');
            if (input.type === 'password') {
                input.type = 'text';
                eyeOpen.classList.add('hidden');
                eyeClosed.classList.remove('hidden');
            } else {
                input.type = 'password';
                eyeOpen.classList.remove('hidden');
                eyeClosed.classList.add('hidden');
            }
        };
    </script>
</div>
{% endblock %}

