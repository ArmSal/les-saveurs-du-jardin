{# templates/admin/parts/_mini_pagination.html.twig #}
<div class="flex items-center gap-0.5">
    {% if previous is defined %}
        <a href="{{ path(route, query|merge({(pageParameterName): previous})) }}" class="w-7 h-7 flex items-center justify-center rounded-md hover:bg-slate-50 text-slate-400 hover:text-indigo-600 transition-all">
            <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path d="M15 19l-7-7 7-7"></path></svg>
        </a>
    {% else %}
        <div class="w-7 h-7 flex items-center justify-center rounded-md text-slate-200">
            <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path d="M15 19l-7-7 7-7"></path></svg>
        </div>
    {% endif %}

    {% if next is defined %}
        <a href="{{ path(route, query|merge({(pageParameterName): next})) }}" class="w-7 h-7 flex items-center justify-center rounded-md hover:bg-slate-50 text-slate-400 hover:text-indigo-600 transition-all">
            <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path d="M9 5l7 7-7 7"></path></svg>
        </a>
    {% else %}
        <div class="w-7 h-7 flex items-center justify-center rounded-md text-slate-200">
            <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path d="M9 5l7 7-7 7"></path></svg>
        </div>
    {% endif %}
</div>
