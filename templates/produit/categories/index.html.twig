{% extends 'base.html.twig' %}

{% block title %}Gestion des Catégories | Plateforme LSDJ{% endblock %}

{% block body %}
	<!-- Premium Header -->
	<div class="mb-8 flex flex-col lg:flex-row lg:items-end justify-between gap-6 pb-6 border-b border-slate-200/60 transition-all duration-500 animate-in fade-in slide-in-from-top-4">
		<div class="space-y-1">
			<div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-slate-900 border-slate-800 border mb-2">
				<span class="relative flex h-2 w-2">
					<span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-indigo-400 opacity-75"></span>
					<span class="relative inline-flex rounded-full h-2 w-2 bg-indigo-600"></span>
				</span>
				<span class="text-[10px] font-bold uppercase tracking-widest text-white">Administration Catalogue</span>
			</div>
			<h1 class="text-3xl sm:text-4xl font-black text-slate-900 tracking-tight leading-tight">
				Gestion <span class="text-indigo-600">Catégories</span>
			</h1>
			<p class="text-slate-500 text-sm max-w-xl font-medium">
				Organisez vos produits en définissant des catégories logistiques personnalisées.
			</p>
		</div>

		<div class="flex flex-wrap items-center gap-3 sm:gap-4">
			<a href="{{ path('app_produit_index') }}" class="group flex items-center gap-2 px-6 py-3.5 bg-slate-100 hover:bg-slate-200 text-slate-600 text-xs font-black uppercase tracking-widest rounded-2xl transition-all transform active:scale-95 border-0 cursor-pointer">
				<svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path d="M11 17l-5-5m0 0l5-5m-5 5h12"></path></svg>
				Retour aux Produits
			</a>
			<a href="{{ path('app_produit_category_new') }}" class="group flex items-center gap-2 px-6 py-3.5 bg-indigo-600 hover:bg-indigo-700 text-white text-xs font-black uppercase tracking-widest rounded-2xl transition-all shadow-xl shadow-indigo-100 transform active:scale-95 border-0 cursor-pointer">
				<div class="w-5 h-5 rounded-lg bg-white/20 flex items-center justify-center group-hover:rotate-90 transition-transform duration-300">
					<svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path d="M12 4v16m8-8H4"></path></svg>
				</div>
				Nouvelle Catégorie
			</a>
		</div>
	</div>

	<!-- Unified Categories View -->
	<div class="animate-in fade-in slide-in-from-bottom-4 duration-700">
		<!-- Mobile-only Card Listing -->
		<div class="md:hidden space-y-4">
			{% for category in categories %}
				<div class="bg-white border border-slate-200/60 rounded-3xl p-6 shadow-sm group">
					<div class="flex items-center gap-4 mb-6 pb-4 border-b border-slate-50">
						<div class="w-12 h-12 rounded-2xl bg-indigo-50 flex items-center justify-center text-indigo-600 font-black text-lg shadow-sm">
							{{ category.nom|first|upper }}
						</div>
						<div class="min-w-0">
							<h3 class="text-base font-black text-slate-900 uppercase tracking-tight truncate leading-tight mb-1">{{ category.nom }}</h3>
							<span class="text-[9px] font-black text-indigo-400 uppercase tracking-widest">{{ category.products|length }} PRODUITS EN CATALOGUE</span>
						</div>
					</div>
					
					<div class="flex items-center gap-3">
						<a href="{{ path('app_produit_category_edit', {id: category.id}) }}" class="flex-1 h-12 bg-slate-50 hover:bg-indigo-50 text-slate-400 hover:text-indigo-600 rounded-xl flex items-center justify-center gap-2 transition-all active:scale-95 border border-slate-100 text-[10px] font-black uppercase tracking-widest">
							<svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"></path></svg>
							Modifier
						</a>
						<form method="post" action="{{ path('app_produit_category_delete', {id: category.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cette catégorie ?');" class="flex-1">
							<input type="hidden" name="_token" value="{{ csrf_token('delete' ~ category.id) }}">
							<button class="w-full h-12 bg-slate-50 hover:bg-rose-50 text-slate-400 hover:text-rose-600 rounded-xl flex items-center justify-center gap-2 transition-all active:scale-95 border border-slate-100 cursor-pointer text-[10px] font-black uppercase tracking-widest" type="submit">
								<svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
								Supprimer
							</button>
						</form>
					</div>
				</div>
			{% else %}
				<div class="py-16 text-center bg-white rounded-3xl border border-dashed border-slate-200">
					<p class="text-slate-400 italic">Aucune catégorie définie.</p>
				</div>
			{% endfor %}
		</div>

		<!-- Desktop-only Premium Table -->
		<div class="hidden md:block bg-white border border-slate-200/60 rounded-3xl overflow-hidden shadow-sm">
			<div class="overflow-x-auto">
				<table class="w-full text-left border-collapse">
					<thead>
						<tr class="bg-slate-50/50 border-b border-slate-100">
							<th class="px-8 py-5 text-[10px] font-black text-slate-400 uppercase tracking-widest">Nom de la Catégorie</th>
							<th class="px-8 py-5 text-[10px] font-black text-slate-400 uppercase tracking-widest text-center">Nombre de Produits</th>
							<th class="px-8 py-5 text-[10px] font-black text-slate-400 uppercase tracking-widest text-right">Actions</th>
						</tr>
					</thead>
					<tbody class="divide-y divide-slate-50">
						{% for category in categories %}
							<tr class="group hover:bg-slate-50/50 transition-colors">
								<td class="px-8 py-5">
									<div class="flex items-center gap-3">
										<div class="w-10 h-10 rounded-xl bg-indigo-50 flex items-center justify-center text-indigo-600 font-black text-sm">
											{{ category.nom|first|upper }}
										</div>
										<span class="text-sm font-bold text-slate-900 group-hover:text-indigo-600 transition-colors uppercase tracking-tight">{{ category.nom }}</span>
									</div>
								</td>
								<td class="px-8 py-5 text-center">
									<span class="px-3 py-1 bg-slate-100 text-slate-500 text-[10px] font-black rounded-full uppercase tracking-widest border border-slate-200/50">
										{{ category.products|length }} PRODUITS
									</span>
								</td>
								<td class="px-8 py-5">
									<div class="flex items-center justify-end gap-2">
										<a href="{{ path('app_produit_category_edit', {id: category.id}) }}" class="w-9 h-9 bg-slate-50 hover:bg-indigo-50 text-slate-400 hover:text-indigo-600 rounded-lg flex items-center justify-center transition-all hover:scale-105 active:scale-95 border border-slate-100" title="Modifier">
											<svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.2" viewBox="0 0 24 24"><path d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"></path></svg>
										</a>
										<form method="post" action="{{ path('app_produit_category_delete', {id: category.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cette catégorie ?');" style="display: inline-block;">
											<input type="hidden" name="_token" value="{{ csrf_token('delete' ~ category.id) }}">
											<button class="w-9 h-9 bg-slate-50 hover:bg-rose-50 text-slate-400 hover:text-rose-600 rounded-lg flex items-center justify-center transition-all hover:scale-105 active:scale-95 border border-slate-100 cursor-pointer" type="submit" title="Supprimer">
												<svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.2" viewBox="0 0 24 24"><path d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
											</button>
										</form>
									</div>
								</td>
							</tr>
						{% endfor %}
					</tbody>
				</table>
			</div>
		</div>
	</div>

	<style>
		@keyframes animate-in {
			from { opacity: 0; transform: translateY(20px); }
			to { opacity: 1; transform: translateY(0); }
		}
		.animate-in {
			animation: animate-in 0.6s ease-out backwards;
		}
	</style>
{% endblock %}
