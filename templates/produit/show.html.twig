{% extends 'base.html.twig' %}

{% block title %}{{ produit.designation }} | LSDJ{% endblock %}

{% block body %}
<div class="min-h-screen bg-slate-50 py-2 sm:py-4 px-0 sm:px-4 lg:px-8">
    <div class="max-w-3xl mx-auto">
        
        {# Header - Compact Dashboard Style #}
        <div class="mb-4 sm:mb-6 px-3 sm:px-0">
            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
                <div>
                    <h1 class="text-xl sm:text-2xl font-black text-slate-900 tracking-tight">Détail Produit</h1>
                    <p class="text-xs text-slate-500 mt-0.5">{{ produit.reference }}</p>
                </div>
                <div class="flex items-center gap-2">
                    <a href="{{ path('app_produit_index') }}" class="inline-flex items-center gap-2 text-[10px] font-black uppercase tracking-widest text-slate-400 hover:text-indigo-600 transition-colors group">
                        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24" class="group-hover:-translate-x-1 transition-transform"><path d="M15 19l-7-7 7-7"></path></svg>
                        Retour
                    </a>
                    {% if canEdit %}
                    <a href="{{ path('app_produit_edit', {id: produit.id}) }}" class="inline-flex items-center gap-2 bg-indigo-600 hover:bg-indigo-700 text-white text-[10px] font-black uppercase tracking-wider py-2 px-4 rounded-lg transition-all">
                        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"></path></svg>
                        Modifier
                    </a>
                    {% endif %}
                </div>
            </div>
        </div>

        <div class="px-3 sm:px-0 space-y-4">
            <!-- Photo Section -->
            <div class="bg-white border border-slate-200 rounded-xl overflow-hidden shadow-sm">
                <div class="px-4 py-3 border-b border-slate-100 bg-slate-50/50">
                    <h2 class="text-[9px] font-black text-slate-900 uppercase tracking-[0.15em] flex items-center gap-2">
                        <span class="w-1 h-3 bg-amber-500 rounded-full"></span>
                        Photo du Produit
                    </h2>
                </div>
                <div class="p-4 flex items-center justify-center">
                    {% if produit.imageUrl %}
                        <div class="w-48 h-48 sm:w-56 sm:h-56 rounded-xl overflow-hidden border border-slate-200">
                            <img src="{{ path('app_media_product', {filename: produit.imageUrl}) }}" alt="{{ produit.designation }}" class="w-full h-full object-cover">
                        </div>
                    {% else %}
                        {% set initials = produit.designation|slice(0, 2)|upper %}
                        <div class="w-48 h-48 sm:w-56 sm:h-56 bg-gradient-to-br from-indigo-100 to-slate-100 border-2 border-dashed border-indigo-200 rounded-xl flex items-center justify-center text-indigo-400 font-black text-6xl shadow-inner tracking-tighter">
                            {{ initials }}
                        </div>
                    {% endif %}
                </div>
            </div>

            <!-- Product Information -->
            <div class="bg-white border border-slate-200 rounded-xl overflow-hidden shadow-sm">
                <div class="px-4 py-3 border-b border-slate-100 bg-slate-50/50">
                    <h2 class="text-[9px] font-black text-slate-900 uppercase tracking-[0.15em] flex items-center gap-2">
                        <span class="w-1 h-3 bg-emerald-500 rounded-full"></span>
                        Informations Produit
                    </h2>
                </div>
                <div class="p-4 flex flex-col gap-4">
                    <div class="grid grid-cols-2 gap-3">
                        <div>
                            <label class="text-[7px] font-black text-slate-400 uppercase tracking-widest mb-1 block">Référence</label>
                            <div class="w-full h-9 bg-slate-100 border border-slate-200 rounded-lg px-3 flex items-center text-xs font-bold text-slate-700">{{ produit.reference }}</div>
                        </div>
                        <div>
                            <label class="text-[7px] font-black text-slate-400 uppercase tracking-widest mb-1 block">Catégorie</label>
                            <div class="w-full h-9 bg-slate-100 border border-slate-200 rounded-lg px-3 flex items-center text-xs font-bold text-slate-700">{{ produit.categoryEntity.nom|default('AUTRE') }}</div>
                        </div>
                    </div>
                    <div>
                        <label class="text-[7px] font-black text-slate-400 uppercase tracking-widest mb-1 block">Désignation</label>
                        <div class="w-full h-9 bg-slate-100 border border-slate-200 rounded-lg px-3 flex items-center text-xs font-bold text-slate-900">{{ produit.designation }}</div>
                    </div>
                    <div class="grid grid-cols-3 gap-3">
                        <div>
                            <label class="text-[7px] font-black text-slate-400 uppercase tracking-widest mb-1 block">Prix HT</label>
                            <div class="relative">
                                <div class="w-full h-9 bg-slate-100 border border-slate-200 rounded-lg px-3 pr-8 flex items-center text-xs font-bold text-slate-700">{{ produit.prix }}</div>
                                <span class="absolute right-3 top-1/2 -translate-y-1/2 text-xs font-bold text-slate-400">€</span>
                            </div>
                        </div>
                        <div>
                            <label class="text-[7px] font-black text-slate-400 uppercase tracking-widest mb-1 block">Unité</label>
                            <div class="w-full h-9 bg-slate-100 border border-slate-200 rounded-lg px-3 flex items-center text-xs font-bold text-slate-700">{{ produit.unite }}</div>
                        </div>
                        <div>
                            <label class="text-[7px] font-black text-slate-400 uppercase tracking-widest mb-1 block">Stock</label>
                            <div class="w-full h-9 {% if produit.qte_stock > 0 %}bg-emerald-50 border-emerald-200 text-emerald-700{% else %}bg-rose-50 border-rose-200 text-rose-700{% endif %} border rounded-lg px-3 flex items-center text-xs font-bold">
                                {{ produit.qte_stock > 0 ? produit.qte_stock ~ ' en stock' : 'Rupture' }}
                            </div>
                        </div>
                    </div>
                    <div>
                        <label class="text-[7px] font-black text-slate-400 uppercase tracking-widest mb-1 block">Description</label>
                        <div class="w-full min-h-20 bg-slate-100 border border-slate-200 rounded-lg px-3 py-2 text-xs font-bold text-slate-700">
                            {{ produit.description|nl2br ?: 'Aucune description' }}
                        </div>
                    </div>

                    <!-- Add to Cart -->
                    <form method="post" action="{{ path('app_cart_add', {id: produit.id}) }}" class="pt-2 border-t border-slate-200">
                        <input type="hidden" name="_token" value="{{ csrf_token('cart_add_' ~ produit.id) }}">
                        <div class="flex items-center gap-3">
                            <div class="flex items-center bg-white border border-slate-200 rounded-lg h-9">
                                <button type="button" onclick="adjustQty(-1)" class="w-8 h-full flex items-center justify-center text-slate-600 hover:bg-slate-50 border-r border-slate-200 rounded-l-lg">
                                    <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20 12H4"></path></svg>
                                </button>
                                <input type="number" name="qty" id="qtyInput" value="1" min="1" class="w-12 h-full border-0 text-center text-xs font-bold text-slate-900 [appearance:textfield]">
                                <button type="button" onclick="adjustQty(1)" class="w-8 h-full flex items-center justify-center text-slate-600 hover:bg-slate-50 border-l border-slate-200 rounded-r-lg">
                                    <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 4v16m8-8H4"></path></svg>
                                </button>
                            </div>
                            <div class="flex-1 flex items-center gap-2">
                                <a href="{{ path('app_produit_index') }}" class="flex-1 h-9 flex items-center justify-center border border-slate-200 text-slate-600 rounded-lg text-xs font-bold uppercase tracking-wider hover:bg-slate-50 transition-all">Annuler</a>
                                <button type="submit" class="flex-1 h-9 flex items-center justify-center gap-2 bg-indigo-600 hover:bg-indigo-700 text-white rounded-lg text-xs font-bold uppercase tracking-wider transition-all">
                                    <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path></svg>
                                    Ajouter
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <script>
        function adjustQty(delta) {
            const input = document.getElementById('qtyInput');
            let val = parseInt(input.value) || 1;
            val = Math.max(1, val + delta);
            input.value = val;
        }
    </script>
</div>
{% endblock %}
