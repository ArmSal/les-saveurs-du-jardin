{% extends 'base.html.twig' %}

{% block title %}{{ title }} | Plateforme LSDJ{% endblock %}

{% block body %}
    <div class="flex flex-col items-center justify-center min-h-[60vh] text-center px-4">
        <div class="w-20 h-20 bg-indigo-50 text-indigo-600 rounded-2xl flex items-center justify-center mb-6 shadow-sm border border-indigo-100">
            <svg width="32" height="32" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
            </svg>
        </div>
        <h1 class="text-3xl font-extrabold text-slate-900 mb-4 tracking-tight">{{ title }}</h1>
        <p class="text-slate-500 max-w-md mx-auto leading-relaxed">{{ description }}</p>
        <div class="mt-10">
            <a href="{{ path('app_home') }}" class="btn btn-primary px-8 py-3 rounded-xl shadow-lg shadow-indigo-200">
                Retour à l'accueil
            </a>
        </div>
    </div>
{% endblock %}

