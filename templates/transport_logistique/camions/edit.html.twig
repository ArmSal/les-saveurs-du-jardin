{% extends 'base.html.twig' %}

{% block title %}Modifier camion | Transport & Logistique{% endblock %}

{% block body %}
<div class="min-h-screen bg-slate-50 py-2 sm:py-4 px-0 sm:px-4 lg:px-8">
    <div class="max-w-2xl mx-auto">
        
        {# Header #}
        <div class="mb-6 px-3 sm:px-0">
            <a href="{{ path('app_transport_logistique_camion_index') }}" class="inline-flex items-center gap-2 text-[11px] font-bold text-slate-500 hover:text-slate-700 transition-colors mb-3">
                <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M19 12H5m7 7l-7-7 7-7"></path></svg>
                Retour à la liste
            </a>
            <h1 class="text-xl sm:text-2xl font-black text-slate-900 tracking-tight">Modifier le camion</h1>
            <p class="text-xs text-slate-500 mt-0.5">{{ camion.nom }} ({{ camion.immatriculation }})</p>
        </div>

        {# Form Card #}
        <div class="bg-white border border-slate-200 rounded-2xl shadow-sm overflow-hidden">
            <div class="p-6">
                {{ form_start(form, {'attr': {'class': 'space-y-6'}}) }}

                    {# Nom #}
                    <div>
                        {{ form_label(form.nom, null, {'label_attr': {'class': 'block text-[10px] font-black text-slate-600 uppercase tracking-widest mb-2'}}) }}
                        {{ form_widget(form.nom) }}
                        {{ form_errors(form.nom, {'attr': {'class': 'text-xs text-rose-500 mt-1'}}) }}
                    </div>

                    {# Immatriculation #}
                    <div>
                        {{ form_label(form.immatriculation, null, {'label_attr': {'class': 'block text-[10px] font-black text-slate-600 uppercase tracking-widest mb-2'}}) }}
                        {{ form_widget(form.immatriculation) }}
                        {{ form_errors(form.immatriculation, {'attr': {'class': 'text-xs text-rose-500 mt-1'}}) }}
                    </div>

                    {# Active #}
                    <div>
                        <label class="flex items-center gap-3 cursor-pointer group">
                            {{ form_widget(form.isActive, {'attr': {'class': 'w-5 h-5 rounded border-slate-300 text-indigo-600 focus:ring-indigo-500 cursor-pointer'}}) }}
                            <div>
                                <span class="block text-[12px] font-bold text-slate-700 group-hover:text-slate-900 transition-colors">Actif</span>
                                <span class="block text-[10px] text-slate-500">Le camion est disponible pour les tournées</span>
                            </div>
                        </label>
                        {{ form_errors(form.isActive, {'attr': {'class': 'text-xs text-rose-500 mt-1'}}) }}
                    </div>

                    {# Actions #}
                    <div class="flex items-center justify-between pt-4 border-t border-slate-100">
                        <a href="{{ path('app_transport_logistique_camion_delete', {id: camion.id}) }}?_token={{ csrf_token('delete_camion' ~ camion.id) }}" onclick="return confirm('Êtes-vous sûr de vouloir supprimer ce camion ?');" class="inline-flex items-center gap-2 px-4 py-2 bg-rose-50 hover:bg-rose-100 text-rose-600 text-[11px] font-bold uppercase tracking-wider rounded-lg transition-all">
                            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                            Supprimer
                        </a>
                        <div class="flex items-center gap-3">
                            <a href="{{ path('app_transport_logistique_camion_index') }}" class="px-4 py-2 bg-slate-100 hover:bg-slate-200 text-slate-700 text-[11px] font-bold uppercase tracking-wider rounded-lg transition-all">
                                Annuler
                            </a>
                            <button type="submit" class="px-6 py-2 bg-indigo-600 hover:bg-indigo-700 text-white text-[11px] font-black uppercase tracking-wider rounded-lg transition-all">
                                Enregistrer
                            </button>
                        </div>
                    </div>

                {{ form_end(form) }}
            </div>
        </div>
    </div>
</div>
{% endblock %}
