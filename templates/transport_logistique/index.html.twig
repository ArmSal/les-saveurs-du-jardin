{% extends 'base.html.twig' %}

{% block title %}Transport & Logistique | Plateforme LSDJ{% endblock %}

{% block body %}
<div class="min-h-screen bg-slate-50 py-2 sm:py-4 px-0 sm:px-4 lg:px-8">
    <div class="max-w-7xl mx-auto">
        
        {# Header #}
        <div class="mb-4 sm:mb-6 px-3 sm:px-0">
            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
                <div>
                    <h1 class="text-xl sm:text-2xl font-black text-slate-900 tracking-tight">Transport & Logistique</h1>
                    <p class="text-xs text-slate-500 mt-0.5">Suivi des tournées des camions vers les magasins</p>
                </div>
                <div class="flex items-center gap-2">
                    <button type="button" onclick="document.getElementById('reportModal').classList.remove('hidden')" class="inline-flex items-center gap-2 bg-emerald-600 hover:bg-emerald-700 text-white text-[10px] font-black uppercase tracking-wider py-2 px-4 rounded-lg transition-all">
                        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                        Rapport PDF
                    </button>
                    {% if canEdit %}
                    <a href="{{ path('app_transport_logistique_camion_index') }}" class="inline-flex items-center gap-2 bg-slate-800 hover:bg-slate-700 text-white text-[10px] font-black uppercase tracking-wider py-2 px-4 rounded-lg transition-all">
                        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M8 14h.01M16 14h.01M5 8h14M5 8a2 2 0 00-2 2v6a2 2 0 002 2h14a2 2 0 002-2v-6a2 2 0 00-2-2M5 8l1-3h12l1 3M9 14v1m6-1v1"></path></svg>
                        Camions
                    </a>
                    <a href="{{ path('app_transport_logistique_new') }}" class="inline-flex items-center gap-2 bg-indigo-600 hover:bg-indigo-700 text-white text-[10px] font-black uppercase tracking-wider py-2 px-4 rounded-lg transition-all">
                        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 4v16m8-8H4"></path></svg>
                        Nouvelle tournée
                    </a>
                    {% endif %}
                </div>
            </div>
        </div>

        {# Filters #}
        <div class="bg-white/50 backdrop-blur-sm border border-slate-200/60 rounded-2xl mb-8 overflow-hidden animate-in fade-in slide-in-from-top-6 duration-700">
            <div class="p-4">
                <form method="get" action="{{ path('app_transport_logistique') }}" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 items-center gap-4">
                    
                    {# Date From #}
                    <div class="relative">
                        <label class="block text-[10px] font-black text-slate-500 uppercase tracking-widest mb-1.5">Date début</label>
                        <input type="date" name="dateFrom" value="{{ dateFrom }}" class="w-full px-3 py-2 bg-white border border-slate-200 rounded-xl text-[11px] font-semibold text-slate-700 focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 transition-all">
                    </div>

                    {# Date To #}
                    <div class="relative">
                        <label class="block text-[10px] font-black text-slate-500 uppercase tracking-widest mb-1.5">Date fin</label>
                        <input type="date" name="dateTo" value="{{ dateTo }}" class="w-full px-3 py-2 bg-white border border-slate-200 rounded-xl text-[11px] font-semibold text-slate-700 focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 transition-all">
                    </div>

                    {# Camion Filter #}
                    <div class="relative">
                        <label class="block text-[10px] font-black text-slate-500 uppercase tracking-widest mb-1.5">Camion</label>
                        <select name="camion" class="w-full px-3 py-2 bg-white border border-slate-200 rounded-xl text-[11px] font-semibold text-slate-700 focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 transition-all appearance-none">
                            <option value="">Tous les camions</option>
                            {% for camion in camions %}
                                <option value="{{ camion.id }}" {% if currentCamion == camion.id %}selected{% endif %}>{{ camion.nom }}</option>
                            {% endfor %}
                        </select>
                    </div>

                    {# Magasin Filter #}
                    <div class="relative">
                        <label class="block text-[10px] font-black text-slate-500 uppercase tracking-widest mb-1.5">Magasin</label>
                        <select name="magasin" class="w-full px-3 py-2 bg-white border border-slate-200 rounded-xl text-[11px] font-semibold text-slate-700 focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 transition-all appearance-none">
                            <option value="">Tous les magasins</option>
                            {% for magasin in magasins %}
                                <option value="{{ magasin.id }}" {% if currentMagasin == magasin.id %}selected{% endif %}>{{ magasin.nom }}</option>
                            {% endfor %}
                        </select>
                    </div>

                    {# Actions #}
                    <div class="flex items-end gap-2 lg:justify-end">
                        <button type="submit" class="inline-flex items-center gap-2 bg-indigo-600 hover:bg-indigo-700 text-white text-[10px] font-black uppercase tracking-wider py-2 px-4 rounded-lg transition-all">
                            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                            Filtrer
                        </button>
                        <a href="{{ path('app_transport_logistique') }}" class="p-2 bg-slate-100 hover:bg-rose-50 hover:text-rose-600 text-slate-400 rounded-lg transition-all" title="Réinitialiser">
                            <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path d="M6 18L18 6M6 6l12 12"></path></svg>
                        </a>
                    </div>
                </form>
            </div>
        </div>

        {# Tours Table #}
        <div class="bg-white border border-slate-200 rounded-2xl overflow-hidden shadow-sm">
            <div class="overflow-x-auto">
                <table class="w-full">
                    <thead class="bg-slate-50 border-b border-slate-200">
                        <tr>
                            <th class="px-4 py-3 text-left text-[10px] font-black text-slate-600 uppercase tracking-widest">Date</th>
                            <th class="px-4 py-3 text-left text-[10px] font-black text-slate-600 uppercase tracking-widest">Camion</th>
                            <th class="px-4 py-3 text-left text-[10px] font-black text-slate-600 uppercase tracking-widest">Magasins</th>
                            <th class="px-4 py-3 text-left text-[10px] font-black text-slate-600 uppercase tracking-widest">Observation</th>
                            {% if canEdit %}
                            <th class="px-4 py-3 text-right text-[10px] font-black text-slate-600 uppercase tracking-widest">Actions</th>
                            {% endif %}
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100">
                        {% for tour in tours %}
                        <tr class="hover:bg-slate-50/50 transition-colors">
                            <td class="px-4 py-3">
                                <span class="inline-flex items-center gap-1.5 px-2.5 py-1 bg-indigo-50 text-indigo-700 rounded-lg text-[11px] font-black uppercase tracking-wide">
                                    <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                                    {{ tour.date|date('d/m/Y') }}
                                </span>
                            </td>
                            <td class="px-4 py-3">
                                <div class="flex items-center gap-2">
                                    <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" class="text-slate-400"><path d="M8 14h.01M16 14h.01M5 8h14M5 8a2 2 0 00-2 2v6a2 2 0 002 2h14a2 2 0 002-2v-6a2 2 0 00-2-2M5 8l1-3h12l1 3M9 14v1m6-1v1"></path></svg>
                                    <div>
                                        <div class="text-[12px] font-bold text-slate-700">{{ tour.camion.nom }}</div>
                                        <div class="text-[10px] text-slate-500">{{ tour.camion.immatriculation }}</div>
                                    </div>
                                </div>
                            </td>
                            <td class="px-4 py-3">
                                <div class="flex flex-wrap gap-1">
                                    {% for magasin in tour.magasins %}
                                        <span class="inline-flex items-center px-2 py-0.5 bg-emerald-50 text-emerald-700 rounded text-[10px] font-bold uppercase tracking-wide border border-emerald-100">
                                            {{ magasin.nom }}
                                        </span>
                                    {% else %}
                                        <span class="text-[11px] text-slate-400 italic">Aucun magasin</span>
                                    {% endfor %}
                                </div>
                            </td>
                            <td class="px-4 py-3">
                                {% if tour.observation %}
                                    <span class="text-[11px] text-slate-600 line-clamp-2" title="{{ tour.observation }}">{{ tour.observation }}</span>
                                {% else %}
                                    <span class="text-[11px] text-slate-400 italic">-</span>
                                {% endif %}
                            </td>
                            {% if canEdit %}
                            <td class="px-4 py-3">
                                <div class="flex items-center justify-end gap-1">
                                    <a href="{{ path('app_transport_logistique_edit', {id: tour.id}) }}" class="w-7 h-7 bg-indigo-50 hover:bg-indigo-100 text-indigo-600 rounded-lg flex items-center justify-center transition-all" title="Modifier">
                                        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"></path></svg>
                                    </a>
                                    <form method="post" action="{{ path('app_transport_logistique_delete', {id: tour.id}) }}" class="inline" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cette tournée ?');">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ tour.id) }}">
                                        <button type="submit" class="w-7 h-7 bg-rose-50 hover:bg-rose-100 text-rose-600 rounded-lg flex items-center justify-center transition-all" title="Supprimer">
                                            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                                        </button>
                                    </form>
                                </div>
                            </td>
                            {% endif %}
                        </tr>
                        {% else %}
                        <tr>
                            <td colspan="{% if canEdit %}5{% else %}4{% endif %}" class="px-4 py-12 text-center">
                                <div class="w-16 h-16 bg-slate-50 rounded-2xl flex items-center justify-center mx-auto mb-4">
                                    <svg width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.5" class="text-slate-300" viewBox="0 0 24 24">
                                        <path d="M8 14h.01M16 14h.01M5 8h14M5 8a2 2 0 00-2 2v6a2 2 0 002 2h14a2 2 0 002-2v-6a2 2 0 00-2-2M5 8l1-3h12l1 3M9 14v1m6-1v1"></path>
                                    </svg>
                                </div>
                                <p class="text-sm font-bold text-slate-700 mb-1">Aucune tournée trouvée</p>
                                <p class="text-xs text-slate-500">Ajoutez une nouvelle tournée pour commencer</p>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
            
            {# Pagination #}
            {% if tours.getPageCount() > 1 %}
            <div class="px-4 py-3 border-t border-slate-200 bg-slate-50/50">
                {{ knp_pagination_render(tours, 'parts/_premium_pagination.html.twig') }}
            </div>
            {% endif %}
        </div>
    </div>
</div>

{# Report Modal #}
<div id="reportModal" class="fixed inset-0 bg-slate-900/60 backdrop-blur-sm z-[100] hidden flex items-center justify-center p-4">
    <div class="bg-white rounded-2xl w-full max-w-md overflow-hidden shadow-xl transform transition-all">
        <div class="p-6 border-b border-slate-100 flex items-center justify-between">
            <h3 class="text-lg font-black text-slate-800">Rapport Mensuel PDF</h3>
            <button type="button" onclick="document.getElementById('reportModal').classList.add('hidden')" class="text-slate-400 hover:text-slate-600 transition-colors">
                <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M6 18L18 6M6 6l12 12"></path></svg>
            </button>
        </div>
        <form action="{{ path('app_transport_logistique_report') }}" method="GET" target="_blank" class="p-6">
            <div class="space-y-4">
                <div>
                    <label class="block text-[10px] font-black text-slate-500 uppercase tracking-widest mb-1.5">Mois</label>
                    <select name="mois" required class="w-full px-3 py-2 bg-white border border-slate-200 rounded-xl text-[13px] font-semibold text-slate-700 focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 transition-all">
                        <option value="1"{% if "now"|date('m') == '01' %} selected{% endif %}>Janvier</option>
                        <option value="2"{% if "now"|date('m') == '02' %} selected{% endif %}>Février</option>
                        <option value="3"{% if "now"|date('m') == '03' %} selected{% endif %}>Mars</option>
                        <option value="4"{% if "now"|date('m') == '04' %} selected{% endif %}>Avril</option>
                        <option value="5"{% if "now"|date('m') == '05' %} selected{% endif %}>Mai</option>
                        <option value="6"{% if "now"|date('m') == '06' %} selected{% endif %}>Juin</option>
                        <option value="7"{% if "now"|date('m') == '07' %} selected{% endif %}>Juillet</option>
                        <option value="8"{% if "now"|date('m') == '08' %} selected{% endif %}>Août</option>
                        <option value="9"{% if "now"|date('m') == '09' %} selected{% endif %}>Septembre</option>
                        <option value="10"{% if "now"|date('m') == '10' %} selected{% endif %}>Octobre</option>
                        <option value="11"{% if "now"|date('m') == '11' %} selected{% endif %}>Novembre</option>
                        <option value="12"{% if "now"|date('m') == '12' %} selected{% endif %}>Décembre</option>
                    </select>
                </div>
                <div>
                    <label class="block text-[10px] font-black text-slate-500 uppercase tracking-widest mb-1.5">Année</label>
                    <select name="annee" required class="w-full px-3 py-2 bg-white border border-slate-200 rounded-xl text-[13px] font-semibold text-slate-700 focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 transition-all">
                        {% set currentYear = "now"|date("Y") %}
                        <option value="{{ currentYear - 1 }}">{{ currentYear - 1 }}</option>
                        <option value="{{ currentYear }}" selected>{{ currentYear }}</option>
                        <option value="{{ currentYear + 1 }}">{{ currentYear + 1 }}</option>
                    </select>
                </div>
                <div>
                    <label class="block text-[10px] font-black text-slate-500 uppercase tracking-widest mb-1.5">Camion</label>
                    <select name="camion" required class="w-full px-3 py-2 bg-white border border-slate-200 rounded-xl text-[13px] font-semibold text-slate-700 focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 transition-all">
                        <option value="" disabled selected>Sélectionnez un camion</option>
                        {% for camion in camions %}
                            <option value="{{ camion.id }}">{{ camion.nom }} ({{ camion.immatriculation ?: 'Sans plaque' }})</option>
                        {% endfor %}
                    </select>
                </div>
            </div>
            <div class="mt-8 flex justify-end gap-3">
                <button type="button" onclick="document.getElementById('reportModal').classList.add('hidden')" class="px-5 py-2 text-sm font-bold text-slate-500 hover:text-slate-800 transition-colors">
                    Annuler
                </button>
                <button type="submit" onclick="setTimeout(() => document.getElementById('reportModal').classList.add('hidden'), 500)" class="px-5 py-2 bg-emerald-600 hover:bg-emerald-700 text-white text-sm font-bold rounded-lg shadow-sm transition-all focus:ring-4 focus:ring-emerald-500/20 flex items-center gap-2">
                    <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                    Générer
                </button>
            </div>
        </form>
    </div>
</div>
{% endblock %}
