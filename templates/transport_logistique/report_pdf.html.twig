<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Rapport Tournées {{ camion.nom }}</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            font-size: 12px;
            color: #333;
            line-height: 1.4;
        }
        .header {
            text-align: center;
            margin-bottom: 30px;
            border-bottom: 2px solid #2c3e50;
            padding-bottom: 10px;
        }
        .header h1 {
            margin: 0;
            color: #2c3e50;
            font-size: 24px;
        }
        .header p {
            margin: 5px 0 0;
            font-size: 14px;
            color: #7f8c8d;
        }
        .info-section {
            margin-bottom: 30px;
        }
        .info-table {
            width: 100%;
            border-collapse: collapse;
        }
        .info-table td {
            padding: 5px 0;
        }
        .info-table .label {
            font-weight: bold;
            color: #2c3e50;
            width: 150px;
        }
        .data-table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 20px;
        }
        .data-table th, .data-table td {
            border: 1px solid #bdc3c7;
            padding: 8px;
            text-align: left;
        }
        .data-table th {
            background-color: #ecf0f1;
            font-weight: bold;
            color: #2c3e50;
        }
        .data-table tr:nth-child(even) {
            background-color: #f9f9f9;
        }
        .badge {
            background-color: #e8f5e9;
            color: #2e7d32;
            padding: 2px 5px;
            border-radius: 3px;
            font-size: 10px;
            font-weight: bold;
            display: inline-block;
            margin-right: 3px;
            margin-bottom: 3px;
            border: 1px solid #c8e6c9;
        }
        .no-data {
            text-align: center;
            padding: 20px;
            font-style: italic;
            color: #95a5a6;
        }
        .footer {
            margin-top: 50px;
            text-align: center;
            font-size: 10px;
            color: #95a5a6;
            border-top: 1px solid #bdc3c7;
            padding-top: 10px;
        }
    </style>
</head>
<body>
    <div class="header">
        <h1>Plateforme LSDJ - Transport & Logistique</h1>
        <p>Relevé Mensuel des Tournées</p>
    </div>

    <div class="info-section">
        <table class="info-table">
            <tr>
                <td class="label">Camion :</td>
                <td>{{ camion.nom }}</td>
                <td class="label">Période :</td>
                <td>
                    {% set months = ['Janvier', 'Février', 'Mars', 'Avril', 'Mai', 'Juin', 'Juillet', 'Août', 'Septembre', 'Octobre', 'Novembre', 'Décembre'] %}
                    {{ months[mois - 1] }} {{ annee }}
                </td>
            </tr>
            <tr>
                <td class="label">Immatriculation :</td>
                <td>{{ camion.immatriculation ?: 'Non spécifiée' }}</td>
                <td class="label">Total Tournées :</td>
                <td>{{ tours|length }}</td>
            </tr>
        </table>
    </div>

    <table class="data-table">
        <thead>
            <tr>
                <th style="width: 15%">Date</th>
                <th style="width: 45%">Magasins Livrés</th>
                <th style="width: 40%">Observation</th>
            </tr>
        </thead>
        <tbody>
            {% for tour in tours %}
                <tr>
                    <td>{{ tour.date|date('d/m/Y') }}</td>
                    <td>
                        {% for magasin in tour.magasins %}
                            <span class="badge">{{ magasin.nom }}</span>
                        {% else %}
                            <span style="color: #95a5a6; font-style: italic;">Aucun magasin</span>
                        {% endfor %}
                    </td>
                    <td>{{ tour.observation|default('-') }}</td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="3" class="no-data">Aucune tournée enregistrée pour ce camion ce mois-ci.</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>

    <div class="footer">
        Généré le {{ 'now'|date('d/m/Y à H:i') }}
    </div>
</body>
</html>
