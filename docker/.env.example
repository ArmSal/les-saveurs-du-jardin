# =============================================================================
# MODÈLE DE CONFIGURATION - Les Saveurs du Jardin
# =============================================================================
# Copier ce fichier vers docker/.env et remplir toutes les valeurs.
# Ce fichier est commité dans Git (sans secrets). docker/.env ne l'est pas.
# =============================================================================


# --- BASE DE DONNÉES (MySQL 8) -----------------------------------------------

MYSQL_DATABASE=lsj_db
MYSQL_ROOT_PASSWORD=CHANGER_MOI_ROOT
MYSQL_USER=app
MYSQL_PASSWORD=CHANGER_MOI_APP

# DSN pour mysqld-exporter Prometheus  — même mot de passe que MYSQL_PASSWORD
MYSQL_EXPORTER_DSN=app:CHANGER_MOI_APP@tcp(db:3306)/

# URL Symfony/Doctrine — encoder le & du mot de passe en %26
DATABASE_URL="mysql://app:CHANGER_MOI_APP@db:3306/lsj_db?serverVersion=8.0&charset=utf8mb4"


# --- SYMFONY APPLICATION -----------------------------------------------------

APP_ENV=dev
# Générer avec : php -r "echo bin2hex(random_bytes(16));"
APP_SECRET=CHANGER_MOI_32_CHARS_HEX


# --- GRAFANA -----------------------------------------------------------------

GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=CHANGER_MOI_GRAFANA


# --- ALERTMANAGER / DISCORD --------------------------------------------------
# Créer un webhook dans les paramètres du serveur Discord > Intégrations > Webhooks
# ⚠  Copier aussi cette valeur dans : docker/alertmanager/discord_webhook_url

DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN
