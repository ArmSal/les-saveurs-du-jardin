{
  "description": "Application monitoring (Nginx, PHP-FPM)",
  "editable": true,
  "id": null,
  "panels": [
    {
      "title": "Nginx Status",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "id": 1,
      "title": "Nginx Status",
      "type": "stat",
      "targets": [
        { "expr": "nginx_up", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "from": 0.5, "result": { "color": "green", "text": "UP" }, "to": 1.5 }, "type": "range" },
            { "options": { "from": -0.5, "result": { "color": "red", "text": "DOWN" }, "to": 0.5 }, "type": "range" }
          ]
        }
      }
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 18, "x": 6, "y": 1 },
      "id": 2,
      "title": "Nginx Requests per Second",
      "type": "timeseries",
      "targets": [
        { "expr": "rate(nginx_http_requests_total[5m])", "legendFormat": "Req/s", "refId": "A" }
      ]
    },
    {
      "title": "PHP-FPM Status",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 }
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "id": 3,
      "title": "PHP-FPM Workers (Active vs Total)",
      "type": "timeseries",
      "targets": [
        { "expr": "phpfpm_active_processes", "legendFormat": "Active", "refId": "A" },
        { "expr": "phpfpm_total_processes", "legendFormat": "Total", "refId": "B" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "id": 4,
      "title": "PHP-FPM Requests Rate",
      "type": "timeseries",
      "targets": [
        { "expr": "rate(phpfpm_requests_total[5m])", "legendFormat": "Req/s", "refId": "A" }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 36,
  "style": "dark",
  "tags": ["lsdj", "app"],
  "timezone": "browser",
  "title": "LSDJ - 2. Application",
  "uid": "lsdj-app",
  "version": 1
}
